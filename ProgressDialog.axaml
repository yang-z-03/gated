<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="gated.ProgressDialog"
        MinWidth="250"
        Width="520"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        x:CompileBindings="False"
        Title="Please wait"
        Background="{DynamicResource AppBrushWindowBackground}">
    <Border Padding="22" MinWidth="420">
        <StackPanel Spacing="10">
            <TextBlock Text="{Binding DialogTitle}" TextAlignment="Center"
                       Foreground="{DynamicResource SemiColorText0}"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding Subtitle}" TextAlignment="Center"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       Width="460" Margin="0 -4 0 4"
                       Foreground="{DynamicResource SemiColorText2}" />
            <ProgressBar Minimum="0"
                         Maximum="100"
                         Height="8"
                         IsVisible="{Binding ShowProgress}"
                         IsIndeterminate="{Binding IsIndeterminate}"
                         Value="{Binding ProgressValue}" />
        </StackPanel>
    </Border>
</Window>
