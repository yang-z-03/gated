<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" Width="400" Height="415" CanResize="False"
        x:Class="gated.AboutWindow" WindowStartupLocation="CenterOwner"
        Title="About Gated" FontSize="{StaticResource SemiFontSizeRegular}"
        FontFamily="{StaticResource SemiFontFamilyRegular}"
        Background="{DynamicResource AppBrushBackground2}">
    <StackPanel Orientation="Vertical">
        <Grid x:Name="HeaderRack" Width="400" Height="94" Margin="0 0 0 10" Background="{DynamicResource AppBrushBackground2}">
            <Canvas x:Name="PixelCanvas" Width="400" Height="84" Margin="0 10 0 0" HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsVisible="False" Opacity="0" IsHitTestVisible="False"/>
            <StackPanel x:Name="TitlePanel" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 10 0 0">
                <Image x:Name="AboutIcon" Width="64" Height="64" Source="avares://gated/gated.ico" PointerPressed="about_icon_pointer_pressed"/>
                <Label HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15 10 0 10" FontSize="30"
                       Foreground="{DynamicResource AppBrushText1}" FontWeight="Light">
                    Gated
                </Label>
            </StackPanel>
        </Grid>

        <Label HorizontalAlignment="Center" Margin="0 5 0 0" FontSize="12" Foreground="{DynamicResource AppBrushText2}" FontWeight="Regular">
            Copyright © Zheng Yang, 2025 - 2026
        </Label>
        <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                   LineHeight="18"
                   Margin="30 10" FontSize="12" Foreground="{DynamicResource AppBrushText6}" FontWeight="Regular">
            This program is free software: you can redistribute it and/or modify it under the terms
            of the <Bold Foreground="{DynamicResource AppBrushText3}">GNU General Public License</Bold> as published by
            the Free Software Foundation, either <Bold Foreground="{DynamicResource AppBrushText3}">version 3</Bold> of
            the license, or (at your opinion) any later version.
        </TextBlock>
        <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                   LineHeight="18"
                   Margin="30 10" FontSize="12" Foreground="{DynamicResource AppBrushText6}" FontWeight="Regular">
            This program is distributed in the hope that it will be useful, but
            <Bold Foreground="{DynamicResource AppBrushText3}">without any warranty</Bold>; without even the implied warranty
            of <Bold Foreground="{DynamicResource AppBrushText3}">merchantability</Bold> or
            <Bold Foreground="{DynamicResource AppBrushText3}">fitness of a particular purpose</Bold>. See the
            GNU General Public License for details.
        </TextBlock>
        <TextBlock HorizontalAlignment="Center" Margin="30 5 30 10" LineHeight="18" TextWrapping="Wrap" TextAlignment="Center"
               FontSize="12" Foreground="{DynamicResource AppBrushText6}" FontWeight="Regular">
            The source code of this software is deposited at https://github.com/yang-z-03/gated.
        </TextBlock>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 5 0 5" Spacing="6">
            <Label x:Name="version" Padding="0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource AppBrushText2}" FontWeight="Regular">
                Version
            </Label>
            <Button Width="24" Height="24" Padding="4" Background="Transparent" BorderBrush="Transparent"
                    Click="path_info_button_click" Classes="Small">
                <Image Width="14" Height="14" Source="{SvgImage avares://gated/Resources/info.svg}" />
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
