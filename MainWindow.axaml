<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:gated.Controls"
        xmlns:shared="using:gated.Shared"
        xmlns:platforms="using:gated.ViewModels.Platforms"
        x:Class="gated.MainWindow"
        x:CompileBindings="False"
        Width="1500" Height="850"
        MinWidth="1275" MinHeight="700"
        Title="Gated"

        ExtendClientAreaChromeHints="Default"
        SystemDecorations="Full"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="0"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SemiColorBackground0}">

    <Window.Resources>
        <shared:CoordinateScaleIconConverter x:Key="CoordinateScaleIconConverter" />
        <shared:CoordinateScaleToolTipConverter x:Key="CoordinateScaleToolTipConverter" />
        <LinearGradientBrush x:Key="AxisTitleComboTextFadeMask"
                             StartPoint="0%,0%"
                             EndPoint="100%,0%">
            <GradientStop Color="Black" Offset="0" />
            <GradientStop Color="Black" Offset="0.82" />
            <GradientStop Color="Transparent" Offset="1" />
        </LinearGradientBrush>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="RadioButton.GateToolButton">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.GateToolButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource SemiColorBackground2}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}" />
        </Style>
        <Style Selector="RadioButton.GateToolButton:checked">
            <Setter Property="Background" Value="{DynamicResource AppBrushTheme1}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushTheme2}" />
        </Style>
        <Style Selector="RadioButton.GateToolButton:checked:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppBrushTheme2}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushTheme3}" />
        </Style>
        <Style Selector="RadioButton.GateToolButton:disabled">
            <Setter Property="Opacity" Value="0.32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="No" />
        </Style>
        <Style Selector="ComboBox.SampleSwitcher">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="ComboBox.SampleSwitcher:pointerover">
            <Setter Property="Background" Value="{DynamicResource SemiColorBackground2}" />
        </Style>
        <Style Selector="Button.ChannelIconButton">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="23" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Border.PageModeSwitchHit">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Border.PageModeSwitchHitVisual">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.16" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.PageModeSwitchHit:pointerover Border.PageModeSwitchHitVisual">
            <Setter Property="Background" Value="{DynamicResource AppBrushOverlayHighlightSoft}" />
        </Style>
        <Style Selector="Border.PageModeSwitchHit:pressed Border.PageModeSwitchHitVisual">
            <Setter Property="Background" Value="{DynamicResource AppBrushOverlayHighlight}" />
        </Style>
        <Style Selector="Border#mainModeSwitch:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppBrushBackground3}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushBorder4}" />
        </Style>
        <Style Selector="Border#mainModeSwitch:pointerover Border#mainModeSwitchThumb">
            <Setter Property="Background" Value="{DynamicResource AppBrushText1}" />
        </Style>
        <Style Selector="ToggleButton.LogLevelToggle /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppBrushBackground3}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushBorder3}" />
        </Style>
        <Style Selector="ToggleButton.LogLevelToggle">
            <Setter Property="Opacity" Value="0.62" />
        </Style>
        <Style Selector="ToggleButton.LogLevelToggle:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppBrushBorder2}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushBorder4}" />
        </Style>
        <Style Selector="ToggleButton.LogLevelToggle:focus /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppBrushBackground3}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushBorder3}" />
        </Style>
        <Style Selector="ToggleButton.LogLevelToggle:pointerover">
            <Setter Property="Opacity" Value="0.84" />
        </Style>
        <Style Selector="ToggleButton.LogLevelToggle:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppBrushTheme1}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushTheme2}" />
        </Style>
        <Style Selector="ToggleButton.LogLevelToggle:checked:focus /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppBrushTheme1}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushTheme2}" />
        </Style>
        <Style Selector="ToggleButton.LogLevelToggle:checked">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="ToggleButton.LogLevelToggle:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppBrushTheme1}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBrushTheme3}" />
        </Style>
        <Style Selector="ListBox#spillover_control_table ListBoxItem">
            <Setter Property="Margin" Value="0,0" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="ListBox#spectral_control_table ListBoxItem">
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="ListBox#mass_normalization_table ListBoxItem">
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="ListBox#mass_spillover_table ListBoxItem">
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="DataGrid.ControlSampleGrid DataGridRow">
            <Setter Property="Margin" Value="4,0,4,0" />
            <Setter Property="MinHeight" Value="28" />
        </Style>
        <Style Selector="DataGrid.ControlSampleGrid DataGridRow /template/ Border#BackgroundBorder">
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="DataGrid.ControlSampleGrid DataGridCell">
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="28" />
        </Style>
        <Style Selector="DataGrid.ControlSampleGrid ComboBox">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="DataGrid.ControlSampleGrid Button">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="DataGrid.ControlSampleGrid StackPanel.IconRow">
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Styles>

    <DockPanel x:Name="window">
        <Border x:Name="titleBar" DockPanel.Dock="Top" Background="{DynamicResource AppBrushBackground4}" BorderThickness="0,0,0,0" BorderBrush="{DynamicResource AppBrushBorder3}">
          <Grid Height="40">
            <Rectangle Fill="{DynamicResource AppBrushBackground4}" PointerPressed="title_bar_pressed"/>
            <DockPanel>
              <Border BorderBrush="{DynamicResource AppBrushBackground4}" BorderThickness="0 0 0 0"/>

              <!-- Page mode switch -->
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Border x:Name="mainModeSwitch"
                        Margin="5 6 8 6"
                        Width="220"
                        Height="28"
                        CornerRadius="7"
                        Background="{DynamicResource AppBrushBackground2}"
                        BorderBrush="{DynamicResource AppBrushBorder3}"
                        BorderThickness="1"
                        ClipToBounds="True">
                  <Border.Transitions>
                    <Transitions>
                      <BrushTransition Property="Background" Duration="0:0:0.16" />
                      <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
                    </Transitions>
                  </Border.Transitions>
                  <Grid ColumnDefinitions="*,*,*">
                    <Border x:Name="mainModeSwitchThumb"
                            Grid.ColumnSpan="3"
                            Width="68"
                            Height="20"
                            Margin="3,3,3,3"
                            HorizontalAlignment="Left"
                            CornerRadius="5"
                            Background="{DynamicResource AppBrushText2}"
                            BoxShadow="0 1 5 0 #80000000">
                        <Border.Transitions>
                            <Transitions>
                                <ThicknessTransition Property="Margin" Duration="0:0:0.20" />
                                <BrushTransition Property="Background" Duration="0:0:0.16" />
                            </Transitions>
                        </Border.Transitions>
                    </Border>
                    <TextBlock x:Name="mainModeAnalysisText"
                               Grid.Column="0"
                               Text="Analysis"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppBrushBackground4}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Transitions>
                            <Transitions>
                                <BrushTransition Property="Foreground" Duration="0:0:0.16" />
                            </Transitions>
                        </TextBlock.Transitions>
                    </TextBlock>
                    <TextBlock x:Name="mainModeLayoutText"
                               Grid.Column="1"
                               Text="Layout"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppBrushText4}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Transitions>
                            <Transitions>
                                <BrushTransition Property="Foreground" Duration="0:0:0.16" />
                            </Transitions>
                        </TextBlock.Transitions>
                    </TextBlock>
                    <TextBlock x:Name="mainModeCodeText"
                               Grid.Column="2"
                               Text="Code"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppBrushText4}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Transitions>
                            <Transitions>
                                <BrushTransition Property="Foreground" Duration="0:0:0.16" />
                            </Transitions>
                        </TextBlock.Transitions>
                    </TextBlock>
                    <Border Grid.Column="0" ZIndex="1" Classes="PageModeSwitchHit" PointerPressed="analysis_mode_tab_pressed">
                        <Border Classes="PageModeSwitchHitVisual" />
                    </Border>
                    <Border Grid.Column="1" ZIndex="1" Classes="PageModeSwitchHit" PointerPressed="layout_mode_tab_pressed">
                        <Border Classes="PageModeSwitchHitVisual" />
                    </Border>
                    <Border Grid.Column="2" ZIndex="1" Classes="PageModeSwitchHit" PointerPressed="code_mode_tab_pressed">
                        <Border Classes="PageModeSwitchHitVisual" />
                    </Border>
                  </Grid>
                </Border>

                <Button x:Name="minimizeButton" Width="30" Height="30" Margin="5 5 0 5" Click="window_minimize" Classes="Title">
                  <TextBlock IsHitTestVisible="False" FontFamily="{DynamicResource SemiFontFamilyIcon}" Text="&#xe1d8;"
                             HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                </Button>
                <Button Width="30" Height="30" Margin="5 5 5 5" Click="window_close" Classes="Close">
                  <TextBlock IsHitTestVisible="False" FontFamily="{DynamicResource SemiFontFamilyIcon}" Text="&#xe10a;"
                             HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                </Button>
              </StackPanel>
              <Grid>
                <StackPanel IsHitTestVisible="False" Margin="2 5 2 2" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Stretch">
                  <Image Width="16" Height="16" Source="avares://gated/gated-32.png"/>
                  <Grid Width="10"/>
                  <TextBlock Text="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" VerticalAlignment="Center"
                             FontWeight="Bold" Foreground="{DynamicResource AppBrushText2}" FontSize="13"/>
                </StackPanel>
              </Grid>
            </DockPanel>
          </Grid>
        </Border>

        <Menu x:Name="main_menu" DockPanel.Dock="Top" Background="{DynamicResource AppBrushBackground4}">
            <MenuItem Header="_File">
                <MenuItem Header="Open workspace ..." InputGesture="Ctrl + Shift + O" Click="open_workspace_menu_item_click" />
                <MenuItem Header="Open FCS ..." InputGesture="Ctrl + O" Click="open_fcs_menu_item_click" />
                <MenuItem Header="Save workspace ..." InputGesture="Ctrl + S" Click="save_workspace_menu_item_click" />
                <MenuItem Header="Rename workspace" Command="{Binding RenameWorkspaceCommand}" InputGesture="F2" />
                <MenuItem Header="Close workspace" Click="close_workspace_menu_item_click" />
                <Separator />
                <MenuItem x:Name="recent_items_menu" Header="Recent items" />
            </MenuItem>
            <MenuItem Header="_Samples">
                <MenuItem Header="Create group" Command="{Binding CreateGroupCommand}" InputGesture="Ctrl + G"/>
                <MenuItem Header="Rename group" Command="{Binding RenameGroupCommand}" InputGesture="F2"/>
                <MenuItem Header="Delete group" Command="{Binding DeleteSelectedCommand}" InputGesture="Delete"/>
                <Separator />
                <MenuItem Header="Append samples to groups" Click="open_fcs_menu_item_click" />
                <MenuItem Header="Add control samples ..." Click="add_control_samples_menu_item_click" />
                <MenuItem Header="Delete selected samples" Command="{Binding DeleteSelectedCommand}" InputGesture="Delete"/>
                <MenuItem Header="Delete selected embedding" Command="{Binding DeleteSelectedCommand}" InputGesture="Delete"/>
                <MenuItem Header="Concatenate" Click="concatenate_samples_menu_item_click" />
                <MenuItem Header="Subsample sample ..." Click="subsample_sample_menu_item_click" />
                <MenuItem Header="Copy hierarchy view options to group" Command="{Binding CopyHierarchyViewOptionsToGroupCommand}" />
                <MenuItem Header="Select equivalent nodes" IsEnabled="False" />
                <Separator />
                <MenuItem Header="Expand" Command="{Binding ExpandProjectTreeCommand}" InputGesture="Ctrl + E"/>
                <MenuItem Header="Collapse" Command="{Binding CollapseProjectTreeCommand}" />
                <Separator />
                <MenuItem Header="Preferences ..." Click="preferences_menu_item_click" />
            </MenuItem>
            <MenuItem Header="_Plotting" IsEnabled="{Binding IsDefaultAnalysisMode}">
                <MenuItem Header="Density" ToggleType="Radio" IsChecked="{Binding IsDensityPlotMode, Mode=OneWay}" Click="density_menu_item_click" />
                <MenuItem Header="Dotplot" ToggleType="Radio" IsChecked="{Binding IsDotplotPlotMode, Mode=OneWay}" Click="dotplot_menu_item_click" />
                <MenuItem Header="Contour" ToggleType="Radio" IsChecked="{Binding IsContourPlotMode, Mode=OneWay}" Click="contour_menu_item_click" />
                <MenuItem Header="Zebra" ToggleType="Radio" IsChecked="{Binding IsZebraPlotMode, Mode=OneWay}" Click="zebra_menu_item_click" />
                <MenuItem Header="Histogram" ToggleType="Radio" IsChecked="{Binding IsHistogramPlotMode, Mode=OneWay}" Click="histogram_menu_item_click" />
                <Separator />
                <MenuItem Header="Show outlier points" ToggleType="CheckBox" IsChecked="{Binding ShowOutlierPoints, Mode=TwoWay}" />
                <MenuItem Header="Draw large dots" ToggleType="CheckBox" IsChecked="{Binding DrawLargeDots, Mode=TwoWay}" />
                <MenuItem Header="Show gridlines" ToggleType="CheckBox" IsChecked="{Binding ShowGridlines, Mode=TwoWay}" />
                <MenuItem Header="Show gate annotations" ToggleType="CheckBox" IsChecked="{Binding ShowGateAnnotations, Mode=TwoWay}" />
                <MenuItem Header="Show gate annotation names" ToggleType="CheckBox" IsChecked="{Binding ShowGateAnnotationNames, Mode=TwoWay}" />
                <Separator />
                <MenuItem x:Name="toggle_plot_properties_menu_item" Header="Show properties panel" ToggleType="CheckBox" IsChecked="True" InputGesture="Ctrl + R" Click="toggle_plot_properties_menu_item_click" />
                <Separator />
                <MenuItem x:Name="editor_x_channel_menu" Header="X selected channel" />
                <MenuItem x:Name="editor_y_channel_menu" Header="Y selected channel" />
                <MenuItem x:Name="editor_color_channel_menu" Header="Dot color" />
                <MenuItem Header="Coloring in log scale" ToggleType="CheckBox" IsChecked="{Binding DotColor.UseLogScale, Mode=TwoWay}" />
                <MenuItem x:Name="editor_density_palette_menu" Header="Density palette" />
                <MenuItem x:Name="editor_dot_color_palette_menu" Header="Dot color palette" />
                <MenuItem Header="X axis scale">
                    <MenuItem Header="Linear" ToggleType="Radio" IsChecked="{Binding IsEditorXAxisLinearScale, Mode=TwoWay}" />
                    <MenuItem Header="Logicle" ToggleType="Radio" IsChecked="{Binding IsEditorXAxisLogicleScale, Mode=TwoWay}" />
                    <MenuItem Header="Signed log" ToggleType="Radio" IsChecked="{Binding IsEditorXAxisLogScale, Mode=TwoWay}" />
                    <MenuItem Header="Arcsinh" ToggleType="Radio" IsChecked="{Binding IsEditorXAxisArcsinhScale, Mode=TwoWay}" />
                </MenuItem>
                <MenuItem Header="Y axis scale">
                    <MenuItem Header="Linear" ToggleType="Radio" IsChecked="{Binding IsEditorYAxisLinearScale, Mode=TwoWay}" />
                    <MenuItem Header="Logicle" ToggleType="Radio" IsChecked="{Binding IsEditorYAxisLogicleScale, Mode=TwoWay}" />
                    <MenuItem Header="Signed log" ToggleType="Radio" IsChecked="{Binding IsEditorYAxisLogScale, Mode=TwoWay}" />
                    <MenuItem Header="Arcsinh" ToggleType="Radio" IsChecked="{Binding IsEditorYAxisArcsinhScale, Mode=TwoWay}" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Layouts" IsEnabled="{Binding IsPageEditorMode}">
                <MenuItem Header="Create layout" Command="{Binding CreateLayoutCommand}" InputGesture="Ctrl + L"/>
                <MenuItem Header="Rename layout" Command="{Binding RenameLayoutCommand}" InputGesture="F2"/>
                <Separator />
                <MenuItem Header="Density" ToggleType="Radio" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding IsLayoutDensityPlotMode, Mode=TwoWay}" />
                <MenuItem Header="Dotplot" ToggleType="Radio" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding IsLayoutDotplotPlotMode, Mode=TwoWay}" />
                <MenuItem Header="Contour" ToggleType="Radio" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding IsLayoutContourPlotMode, Mode=TwoWay}" />
                <MenuItem Header="Zebra" ToggleType="Radio" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding IsLayoutZebraPlotMode, Mode=TwoWay}" />
                <MenuItem Header="Histogram" ToggleType="Radio" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding IsLayoutHistogramPlotMode, Mode=TwoWay}" />
                <Separator />
                <MenuItem Header="Show outlier points" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.ShowOutlierPoints, Mode=TwoWay}" />
                <MenuItem Header="Draw large dots" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.DrawLargeDots, Mode=TwoWay}" />
                <MenuItem Header="Show gridlines" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.ShowGridlines, Mode=TwoWay}" />
                <MenuItem Header="Show tick labels" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.ShowTickLabels, Mode=TwoWay}" />
                <MenuItem Header="Density pseudocolor" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.UsePseudocolor, Mode=TwoWay}" />
                <MenuItem Header="Show gates" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.ShowGates, Mode=TwoWay}" />
                <MenuItem Header="Show gate annotations" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.ShowGateAnnotations, Mode=TwoWay}" />
                <MenuItem Header="Show gate annotation names" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.ShowGateAnnotationNames, Mode=TwoWay}" />
                <Separator />
                <MenuItem x:Name="toggle_layout_properties_menu_item" Header="Show properties panel" ToggleType="CheckBox" IsChecked="True" InputGesture="Ctrl + R" Click="toggle_plot_properties_menu_item_click" />
                <Separator />
                <MenuItem x:Name="layout_x_channel_menu" Header="X selected channel" IsEnabled="{Binding HasSelectedPageElement}" />
                <MenuItem x:Name="layout_y_channel_menu" Header="Y selected channel" IsEnabled="{Binding HasSelectedPageElement}" />
                <MenuItem x:Name="layout_color_channel_menu" Header="Dot color" IsEnabled="{Binding HasSelectedPageElement}" />
                <MenuItem Header="Coloring in log scale" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.DotColor.UseLogScale, Mode=TwoWay}" />
                <MenuItem x:Name="layout_density_palette_menu" Header="Density palette" IsEnabled="{Binding HasSelectedPageElement}" />
                <MenuItem x:Name="layout_dot_color_palette_menu" Header="Dot color palette" IsEnabled="{Binding HasSelectedPageElement}" />
                <MenuItem Header="X axis scale" IsEnabled="{Binding HasSelectedPageElement}">
                    <MenuItem Header="Linear" ToggleType="Radio" IsChecked="{Binding IsLayoutXAxisLinearScale, Mode=TwoWay}" />
                    <MenuItem Header="Logicle" ToggleType="Radio" IsChecked="{Binding IsLayoutXAxisLogicleScale, Mode=TwoWay}" />
                    <MenuItem Header="Signed log" ToggleType="Radio" IsChecked="{Binding IsLayoutXAxisLogScale, Mode=TwoWay}" />
                    <MenuItem Header="Arcsinh" ToggleType="Radio" IsChecked="{Binding IsLayoutXAxisArcsinhScale, Mode=TwoWay}" />
                </MenuItem>
                <MenuItem Header="Y axis scale" IsEnabled="{Binding HasSelectedPageElement}">
                    <MenuItem Header="Linear" ToggleType="Radio" IsChecked="{Binding IsLayoutYAxisLinearScale, Mode=TwoWay}" />
                    <MenuItem Header="Logicle" ToggleType="Radio" IsChecked="{Binding IsLayoutYAxisLogicleScale, Mode=TwoWay}" />
                    <MenuItem Header="Signed log" ToggleType="Radio" IsChecked="{Binding IsLayoutYAxisLogScale, Mode=TwoWay}" />
                    <MenuItem Header="Arcsinh" ToggleType="Radio" IsChecked="{Binding IsLayoutYAxisArcsinhScale, Mode=TwoWay}" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Gating" IsEnabled="{Binding IsDefaultAnalysisMode}">
                <MenuItem Header="View" ToggleType="Radio" IsChecked="{Binding IsViewTool, Mode=OneWay}" Click="view_tool_menu_item_click" />
                <MenuItem Header="Polygon gate" ToggleType="Radio" IsEnabled="{Binding CanCreateTwoDimensionalGate}" IsChecked="{Binding IsPolygonTool, Mode=OneWay}" Click="polygon_tool_menu_item_click" />
                <MenuItem Header="Rectangle gate" ToggleType="Radio" IsEnabled="{Binding CanCreateTwoDimensionalGate}" IsChecked="{Binding IsRectangleTool, Mode=OneWay}" Click="rectangle_tool_menu_item_click" />
                <MenuItem Header="Quad gate" ToggleType="Radio" IsEnabled="{Binding CanCreateTwoDimensionalGate}" IsChecked="{Binding IsQuadrantTool, Mode=OneWay}" Click="quadrant_tool_menu_item_click" />
                <MenuItem Header="Curly quad gate" ToggleType="Radio" IsEnabled="{Binding CanCreateTwoDimensionalGate}" IsChecked="{Binding IsCurlyQuadrantTool, Mode=OneWay}" Click="curly_quadrant_tool_menu_item_click" />
                <MenuItem Header="Offset quad gate" ToggleType="Radio" IsEnabled="{Binding CanCreateTwoDimensionalGate}" IsChecked="{Binding IsOffsetQuadrantTool, Mode=OneWay}" Click="offset_quadrant_tool_menu_item_click" />
                <MenuItem Header="Threshold gate" ToggleType="Radio" IsEnabled="{Binding CanCreateOneDimensionalGate}" IsChecked="{Binding IsThresholdTool, Mode=OneWay}" Click="threshold_tool_menu_item_click" />
                <MenuItem Header="Range gate" ToggleType="Radio" IsEnabled="{Binding CanCreateOneDimensionalGate}" IsChecked="{Binding IsRangeTool, Mode=OneWay}" Click="range_tool_menu_item_click" />
                <Separator />
                <MenuItem Header="Merge" Command="{Binding AddMergeGateCommand}" />
                <MenuItem Header="Exclude" Command="{Binding AddExcludeGateCommand}" />
                <MenuItem Header="Overlap" Command="{Binding AddOverlapGateCommand}" />
                <Separator />
                <MenuItem Header="Rename gate" Command="{Binding RenameGateCommand}" InputGesture="F2"/>
                <MenuItem Header="Delete selected gate" Command="{Binding DeleteSelectedCommand}" InputGesture="Delete"/>
            </MenuItem>
            <MenuItem Header="_Compensation">
                <MenuItem Header="Apply selected compensation" Command="{Binding ApplyCompensationCommand}"/>
                <MenuItem Header="Compensation table editor ..." Command="{Binding EditCompensationCommand}" InputGesture="Ctrl + P"/>
                <MenuItem Header="Auto-compensation" Command="{Binding OpenSpilloverCompensationCommand}"/>
            </MenuItem>
            <MenuItem Header="_Statistics">
                <MenuItem Header="Mean" Command="{Binding AddMeanStatisticCommand}" />
                <MenuItem Header="Median" Command="{Binding AddMedianStatisticCommand}" />
                <MenuItem Header="Geometric mean" Command="{Binding AddGeometricMeanStatisticCommand}" />
                <MenuItem Header="Coefficient of variation (CV)" Command="{Binding AddCoefficientOfVariationStatisticCommand}" />
                <MenuItem Header="Standard deviation (SD)" Command="{Binding AddStandardDeviationStatisticCommand}" />
                <MenuItem Header="Frequency of parent population" Command="{Binding AddFrequencyOfParentStatisticCommand}" />
                <MenuItem Header="Frequency of all" Command="{Binding AddFrequencyOfAllStatisticCommand}" />
                <MenuItem Header="Number of events" Command="{Binding AddCountStatisticCommand}" />
                <MenuItem Header="Delete selected statistic" Command="{Binding DeleteSelectedCommand}" InputGesture="Delete" />
                <Separator />
                <MenuItem Header="Manage extension packages ..." Click="manage_extension_packages_menu_item_click" />
                <Separator />
                <MenuItem Header="Create macro" InputGesture="Ctrl + Shift + P" Click="create_macro_menu_item_click" />
                <MenuItem x:Name="run_macros_menu" Header="Run macros" />
                <MenuItem x:Name="edit_macros_menu" Header="Edit macros" />
                <Separator />
                <MenuItem Header="Create Python statistic" Click="create_statistic_script_menu_item_click" />
                <MenuItem x:Name="python_statistics_menu" Header="Python statistics" />
                <MenuItem x:Name="edit_python_statistics_menu" Header="Edit Python statistics" />
                <Separator />
                <MenuItem Header="Create platform">
                    <MenuItem Header="Integration" Command="{Binding CreatePlatformCommand}" CommandParameter="Integration" />
                    <MenuItem Header="Cell cycle" Command="{Binding CreatePlatformCommand}" CommandParameter="CellCycle" />
                    <MenuItem Header="Proliferation" Command="{Binding CreatePlatformCommand}" CommandParameter="Proliferation" />
                    <MenuItem Header="Intensity comparison" Command="{Binding CreatePlatformCommand}" CommandParameter="IntensityComparison" />
                </MenuItem>
                <MenuItem Header="Rename platform" Command="{Binding RenamePlatformCommand}" InputGesture="F2"/>
                <MenuItem Header="Delete platform" Command="{Binding DeleteSelectedCommand}" InputGesture="Delete"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Check for updates ..." Click="check_for_updates_menu_item_click" />
                <MenuItem Header="About Gated ..." Click="about_menu_item_click" />
            </MenuItem>
        </Menu>

        <Grid DockPanel.Dock="Top" Height="6" Background="{DynamicResource SemiColorSplits}" />

        <Border DockPanel.Dock="Bottom"
                Height="28"
                BorderBrush="{DynamicResource AppBrushBorder3}"
                BorderThickness="0,1,0,0"
                Background="{DynamicResource AppBrushBackground4}">
            <Grid ColumnDefinitions="*,Auto"
                  Margin="10,0,10,2">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SemiColorText2}"
                           Text="{Binding StatusText}" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{DynamicResource SemiColorText2}"
                               Text="{Binding PythonEngineStatusText}" />
                    <ProgressBar Width="120"
                                 Height="5"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsPythonEngineProgressVisible}"
                                 IsIndeterminate="{Binding IsPythonEngineProgressIndeterminate}"
                                 Value="{Binding PythonEngineProgress}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="main_workspace_grid" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="500" MinWidth="300" />
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="770"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource SemiColorSplits}"
                    BorderThickness="0,0,1,0"
                    Background="{DynamicResource AppBrushBackground1}">
                <Grid RowDefinitions="30,*" Margin="8">
                    <Grid Grid.Row="0" ColumnDefinitions="*,100">
                        <TextBlock Text="Workspace"
                                   Foreground="{DynamicResource SemiColorText2}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0" />
                        <TextBlock Grid.Column="1"
                                   Text="Statistics"
                                   Foreground="{DynamicResource SemiColorText2}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0" />
                    </Grid>
                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <controls:ProjectTreeView x:Name="project_tree"
                                                  Nodes="{Binding ProjectNodes}"
                                                  SelectNodeCommand="{Binding SelectProjectNodeCommand}"
                                                  ToggleNodeCommand="{Binding ToggleProjectNodeCommand}"
                                                  DropNodeCommand="{Binding DropProjectNodeCommand}" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource SemiColorSplits}"
                          ResizeDirection="Columns" />

            <Grid x:Name="analysis_mode_grid"
                  Grid.Column="2"
                  IsVisible="{Binding IsDefaultAnalysisMode}"
                  RowDefinitions="*,5,250"
                  Background="{DynamicResource AppBrushBackground2}">
                <Grid x:Name="analysis_plot_grid"
                      Grid.Row="0"
                      ColumnDefinitions="*,346">
                    <Grid Grid.Column="0"
                          RowDefinitions="Auto,*">
                        <Border Grid.Row="0"
                                HorizontalAlignment="Center"
                                Margin="0,16,0,8"
                                Padding="10"
                                CornerRadius="8"
                                BorderBrush="{DynamicResource SemiColorBorder}"
                                BorderThickness="1"
                                Background="{DynamicResource AppBrushBackground3}">
                            <DockPanel LastChildFill="False">
                              <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
                                <RadioButton GroupName="GateTools" Classes="GateToolButton" IsChecked="{Binding IsViewTool, Mode=OneWay}" Click="view_tool_menu_item_click">
                                    <shared:ThemeIcon Width="28" Height="28" Icon="pointer.svg" />
                                </RadioButton>
                                <RadioButton GroupName="GateTools" Classes="GateToolButton" IsChecked="{Binding IsPolygonTool, Mode=OneWay}" IsEnabled="{Binding CanCreateTwoDimensionalGate}" Click="polygon_tool_menu_item_click">
                                    <shared:ThemeIcon Width="28" Height="28" Icon="polygon.svg" />
                                </RadioButton>
                                <RadioButton GroupName="GateTools" Classes="GateToolButton" IsChecked="{Binding IsQuadrantTool, Mode=OneWay}" IsEnabled="{Binding CanCreateTwoDimensionalGate}" Click="quadrant_tool_menu_item_click">
                                    <shared:ThemeIcon Width="28" Height="28" Icon="cross.svg" />
                                </RadioButton>
                                <RadioButton GroupName="GateTools" Classes="GateToolButton" IsChecked="{Binding IsThresholdTool, Mode=OneWay}" IsEnabled="{Binding CanCreateOneDimensionalGate}" Click="threshold_tool_menu_item_click">
                                    <shared:ThemeIcon Width="28" Height="28" Icon="threshold.svg" />
                                </RadioButton>
                                <RadioButton GroupName="GateTools" Classes="GateToolButton" IsChecked="{Binding IsRangeTool, Mode=OneWay}" IsEnabled="{Binding CanCreateOneDimensionalGate}" Click="range_tool_menu_item_click">
                                    <shared:ThemeIcon Width="28" Height="28" Icon="range.svg" />
                                </RadioButton>
                              </StackPanel>
                              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" Margin="18,0,0,0" VerticalAlignment="Center">
                                <Button Classes="Small" Width="32" Height="32" Padding="6" Command="{Binding SelectPreviousEquivalentSampleCommand}">
                                    <shared:ThemeIcon Width="18" Height="18" Icon="back.svg" />
                                </Button>
                                <ComboBox Width="210"
                                          Classes="SampleSwitcher"
                                          VerticalAlignment="Center"
                                          ItemsSource="{Binding EquivalentSampleChoices}"
                                          SelectedItem="{Binding SelectedEquivalentSampleChoice, Mode=TwoWay}">
                                    <ComboBox.SelectionBoxItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SampleName}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource SemiColorText0}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding CountText}"
                                                           IsVisible="{Binding HasCount}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SemiColorText2}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.SelectionBoxItemTemplate>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding SampleName}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SemiColorText0}" />
                                                <TextBlock Text="{Binding CountText}"
                                                           IsVisible="{Binding HasCount}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SemiColorText2}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Classes="Small" Width="32" Height="32" Padding="6" Command="{Binding SelectNextEquivalentSampleCommand}">
                                    <shared:ThemeIcon Width="18" Height="18" Icon="right.svg" />
                                </Button>
                              </StackPanel>
                            </DockPanel>
                        </Border>

                        <Canvas Grid.Row="1" Margin="16" ClipToBounds="True">
                            <controls:FlowPlotView x:Name="editor_plot"
                                                   Width="{Binding Bounds.Width, RelativeSource={RelativeSource AncestorType=Canvas}}"
                                                   Height="{Binding Bounds.Height, RelativeSource={RelativeSource AncestorType=Canvas}}"
                                                   Group="{Binding SelectedGroup}"
                                                   Sample="{Binding SelectedSample}"
                                                   Gate="{Binding PlotGate}"
                                                   Gates="{Binding PlotGates}"
                                                   Population="{Binding PlotPopulation}"
                                                   XAxis="{Binding XAxis}"
                                                   YAxis="{Binding YAxis}"
                                                   DotColor="{Binding DotColor}"
                                                   PlotMode="{Binding EffectivePlotMode}"
                                                   ShowOutlierPoints="{Binding ShowOutlierPoints}"
                                                   DrawLargeDots="{Binding DrawLargeDots}"
                                                   ShowGridlines="{Binding ShowGridlines}"
                                                   ShowGateAnnotations="{Binding ShowGateAnnotations}"
                                                   ShowGateAnnotationNames="{Binding ShowGateAnnotationNames}"
                                                   ContourLevelCount="{Binding ContourLevelCount}"
                                                   DensitySmoothing="{Binding DensitySmoothing}"
                                                   DensityPalette="{Binding SelectedDensityColorMap.Palette}"
                                                   ActiveTool="{Binding ActiveTool}"
                                                   GateCreatedCommand="{Binding AddCanvasGateCommand}"
                                                   GateEditedCommand="{Binding GateEditedCommand}"
                                                   TransformPreparing="{Binding IsEditorPlotCalculating}" />
                            <Border HorizontalAlignment="Center"
                                    Canvas.Left="{Binding PlotAxisControlLeft, ElementName=editor_plot}"
                                    Canvas.Top="{Binding PlotAxisControlTop, ElementName=editor_plot}"
                                    Width="{Binding PlotAxisControlWidth, ElementName=editor_plot}"
                                    Padding="4"
                                    Background="{DynamicResource AppBrushBackground3}"
                                    BorderBrush="{DynamicResource SemiColorBorder}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Opacity="{Binding PlotAxisControlsOpacity, ElementName=editor_plot}"
                                    IsVisible="{Binding PlotAxisControlsVisible, ElementName=editor_plot}">
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
                                    </Transitions>
                                </Border.Transitions>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Spacing="4">
                                    <ComboBox Classes='Small'
                                              Width="{Binding PlotAxisChannelControlWidth, ElementName=editor_plot}"
                                              ItemsSource="{Binding AxisChoices}"
                                              SelectedItem="{Binding SelectedXAxisChoice, Mode=TwoWay}">
                                        <ComboBox.SelectionBoxItemTemplate>
                                            <DataTemplate>
                                                <Border ClipToBounds="True"
                                                        OpacityMask="{StaticResource AxisTitleComboTextFadeMask}">
                                                    <TextBlock Text="{Binding DisplayLabel}"
                                                               Foreground="{DynamicResource SemiColorText1}"
                                                               TextTrimming="None"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </ComboBox.SelectionBoxItemTemplate>
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                                                    <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ComboBox Classes='Small'
                                              Width="48"
                                              ItemsSource="{Binding CoordinateScaleChoices}"
                                              SelectedItem="{Binding XAxis.ScaleKind}">
                                        <ComboBox.SelectionBoxItemTemplate>
                                            <DataTemplate>
                                                <PathIcon Width="16"
                                                          Height="16"
                                                          Data="{Binding Converter={StaticResource CoordinateScaleIconConverter}}"
                                                          ToolTip.Tip="{Binding Converter={StaticResource CoordinateScaleToolTipConverter}}" />
                                            </DataTemplate>
                                        </ComboBox.SelectionBoxItemTemplate>
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <PathIcon Width="16"
                                                          Height="16"
                                                          Data="{Binding Converter={StaticResource CoordinateScaleIconConverter}}"
                                                          ToolTip.Tip="{Binding Converter={StaticResource CoordinateScaleToolTipConverter}}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                            <LayoutTransformControl Canvas.Left="{Binding PlotYAxisControlLeft, ElementName=editor_plot}"
                                                    Canvas.Top="{Binding PlotYAxisControlTop, ElementName=editor_plot}"
                                                    Opacity="{Binding PlotAxisControlsOpacity, ElementName=editor_plot}"
                                                    IsVisible="{Binding PlotAxisControlsVisible, ElementName=editor_plot}">
                                <LayoutTransformControl.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
                                    </Transitions>
                                </LayoutTransformControl.Transitions>
                                <LayoutTransformControl.LayoutTransform>
                                    <RotateTransform Angle="-90" />
                                </LayoutTransformControl.LayoutTransform>
                                <Border Padding="4"
                                        Background="{DynamicResource AppBrushBackground3}"
                                        BorderBrush="{DynamicResource SemiColorBorder}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <ComboBox Classes='Small'
                                                  Width="{Binding PlotAxisChannelControlWidth, ElementName=editor_plot}"
                                                  IsEnabled="{Binding IsYAxisEnabled}"
                                                  ItemsSource="{Binding AxisChoices}"
                                                  SelectedItem="{Binding SelectedYAxisChoice, Mode=TwoWay}">
                                            <ComboBox.SelectionBoxItemTemplate>
                                                <DataTemplate>
                                                    <Border ClipToBounds="True"
                                                            OpacityMask="{StaticResource AxisTitleComboTextFadeMask}">
                                                        <TextBlock Text="{Binding DisplayLabel}"
                                                                   Foreground="{DynamicResource SemiColorText1}"
                                                                   TextTrimming="None"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                </DataTemplate>
                                            </ComboBox.SelectionBoxItemTemplate>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                                                        <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <ComboBox Classes='Small'
                                                  Width="48"
                                                  IsEnabled="{Binding IsYAxisEnabled}"
                                                  ItemsSource="{Binding CoordinateScaleChoices}"
                                                  SelectedItem="{Binding YAxis.ScaleKind}">
                                            <ComboBox.SelectionBoxItemTemplate>
                                                <DataTemplate>
                                                    <PathIcon Width="16"
                                                              Height="16"
                                                              Data="{Binding Converter={StaticResource CoordinateScaleIconConverter}}"
                                                              ToolTip.Tip="{Binding Converter={StaticResource CoordinateScaleToolTipConverter}}" />
                                                </DataTemplate>
                                            </ComboBox.SelectionBoxItemTemplate>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <PathIcon Width="16"
                                                              Height="16"
                                                              Data="{Binding Converter={StaticResource CoordinateScaleIconConverter}}"
                                                              ToolTip.Tip="{Binding Converter={StaticResource CoordinateScaleToolTipConverter}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>
                            </LayoutTransformControl>
                            <Button Classes="Small"
                                    Canvas.Left="{Binding PlotAxisSwapButtonLeft, ElementName=editor_plot}"
                                    Canvas.Top="{Binding PlotAxisSwapButtonTop, ElementName=editor_plot}"
                                    Width="32"
                                    Height="32"
                                    Padding="7"
                                    Command="{Binding SwapEditorAxesCommand}"
                                    IsEnabled="{Binding IsYAxisEnabled}"
                                    Opacity="{Binding PlotAxisControlsOpacity, ElementName=editor_plot}"
                                    IsVisible="{Binding PlotAxisControlsVisible, ElementName=editor_plot}"
                                    ToolTip.Tip="Swap axes">
                                <Button.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
                                    </Transitions>
                                </Button.Transitions>
                                <shared:ThemeIcon Width="18"
                                       Height="18" Icon="swap.svg" />
                            </Button>
                            <Border Canvas.Left="{Binding PlotLeft, ElementName=editor_plot}"
                                    Canvas.Top="{Binding PlotTop, ElementName=editor_plot}"
                                    Width="{Binding PlotSize, ElementName=editor_plot}"
                                    Height="{Binding PlotSize, ElementName=editor_plot}"
                                    IsHitTestVisible="False"
                                    IsVisible="{Binding IsEditorPlotCalculating}">
                                <Border Width="96"
                                        Height="96"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        CornerRadius="10"
                                        Background="{DynamicResource AppBrushBackground3}"
                                        BorderBrush="{DynamicResource AppBrushBorder1}"
                                        BorderThickness="1"
                                        Opacity="0.5"
                                        Padding="24">
                                    <Grid HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Width="48" Height="48">
                                        <controls:SpinnerView Width="48"
                                                              Height="48"/>
                                    </Grid>
                                </Border>
                            </Border>
                        </Canvas>
                    </Grid>

                    <Border x:Name="analysis_properties_panel"
                            Grid.Column="1"
                            BorderBrush="{DynamicResource SemiColorSplits}"
                            BorderThickness="1,0,0,0"
                            Background="{DynamicResource AppBrushBackground1}"
                            Padding="8">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                          <StackPanel>
                            <StackPanel Spacing="8" Margin="16, 8, 16, 16"
                                        Grid.IsSharedSizeScope="True"
                                        IsVisible="{Binding IsPlotPropertiesMode}">
                                <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Properties" />

                                <Expander Header="X axis" IsExpanded="False">
                                    <StackPanel Spacing="8" Margin="0,8,0,16">
                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Selected channel" />
                                        <ComboBox Classes='Small'
                                                  ItemsSource="{Binding AxisChoices}"
                                                  SelectedItem="{Binding SelectedXAxisChoice, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                                                        <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <StackPanel>
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Minimum" />
                                                <TextBox Text="{Binding XAxis.Minimum, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Maximum" />
                                                <TextBox Text="{Binding XAxis.Maximum, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Axis scale" />
                                        <ComboBox Classes='Small'
                                                  ItemsSource="{Binding CoordinateScaleChoices}"
                                                  SelectedItem="{Binding XAxis.ScaleKind}" />

                                        <Grid IsVisible="{Binding XAxis.IsLogicle}" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="8">
                                            <StackPanel>
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Top of scale (T)" />
                                                <TextBox Text="{Binding XAxis.LogicleTopOfScale, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Number of decades (M)" />
                                                <TextBox Text="{Binding XAxis.LogicleDecades, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Linearization width (W)" />
                                                <TextBox Text="{Binding XAxis.LogicleLinearizationWidth, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Negative decades (A)" />
                                                <TextBox Text="{Binding XAxis.LogicleNegativeDecades, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel IsVisible="{Binding XAxis.IsArcsinh}">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Arcsinh cofactor" />
                                            <TextBox Text="{Binding XAxis.ArcsinhCofactor, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Y axis" IsExpanded="False">
                                    <StackPanel Spacing="8" Margin="0,8,0,16">
                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Selected channel" />
                                        <ComboBox Classes='Small'
                                                  IsEnabled="{Binding IsYAxisEnabled}"
                                                  ItemsSource="{Binding AxisChoices}"
                                                  SelectedItem="{Binding SelectedYAxisChoice, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                                                        <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <StackPanel>
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Minimum" />
                                                <TextBox IsEnabled="{Binding IsYAxisEnabled}" Text="{Binding YAxis.Minimum, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Maximum" />
                                                <TextBox IsEnabled="{Binding IsYAxisEnabled}" Text="{Binding YAxis.Maximum, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Axis scale" />
                                        <ComboBox Classes='Small'
                                                  IsEnabled="{Binding IsYAxisEnabled}"
                                                  ItemsSource="{Binding CoordinateScaleChoices}"
                                                  SelectedItem="{Binding YAxis.ScaleKind}" />

                                        <Grid IsVisible="{Binding YAxis.IsLogicle}" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="8">
                                            <StackPanel>
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Top of scale (T)" />
                                                <TextBox IsEnabled="{Binding IsYAxisEnabled}" Text="{Binding YAxis.LogicleTopOfScale, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Number of decades (M)" />
                                                <TextBox IsEnabled="{Binding IsYAxisEnabled}" Text="{Binding YAxis.LogicleDecades, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Linearization width (W)" />
                                                <TextBox IsEnabled="{Binding IsYAxisEnabled}" Text="{Binding YAxis.LogicleLinearizationWidth, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Negative decades (A)" />
                                                <TextBox IsEnabled="{Binding IsYAxisEnabled}" Text="{Binding YAxis.LogicleNegativeDecades, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel IsVisible="{Binding YAxis.IsArcsinh}">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Arcsinh cofactor" />
                                            <TextBox Text="{Binding YAxis.ArcsinhCofactor, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Plot style" IsExpanded="True">
                                    <StackPanel Spacing="8" Margin="0,8,0,16">
                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Plot type" />
                                        <ComboBox Classes='Small'
                                                  ItemsSource="{Binding PlotModeChoices}"
                                                  SelectedItem="{Binding SelectedPlotMode}" />

                                        <StackPanel Spacing="8" IsVisible="{Binding ShowDensityStyleOptions}">
                                            <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Density palette" />
                                            <ComboBox Classes='Small'
                                                      ItemsSource="{Binding PlotColorMapChoices}"
                                                      SelectedItem="{Binding SelectedDensityColorMap}">
                                                <ComboBox.SelectionBoxItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <controls:ColorMapPreview Width="64" Height="14" ColorMap="{Binding}" />
                                                            <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.SelectionBoxItemTemplate>
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <controls:ColorMapPreview Width="64" Height="14" ColorMap="{Binding}" />
                                                            <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Margin="0,8,0,0" Spacing="8">
                                            <CheckBox Content="Show gridlines" Margin="0,0,12,0"
                                                      IsChecked="{Binding ShowGridlines}" />
                                            <CheckBox Content="Show gate annotations" Margin="0,0,12,0"
                                                      IsChecked="{Binding ShowGateAnnotations}" />
                                            <CheckBox Content="Show annotation names" Margin="0,0,12,0"
                                                      IsChecked="{Binding ShowGateAnnotationNames}" />
                                        </StackPanel>

                                        <StackPanel Spacing="8" IsVisible="{Binding ShowDotplotStyleOptions}">
                                            <CheckBox Content="Draw large dots" Margin="0,0,12,0"
                                                      IsChecked="{Binding DrawLargeDots}" />
                                            <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Dot color" />
                                            <ComboBox Classes='Small'
                                                      ItemsSource="{Binding ColorChoices}"
                                                      SelectedItem="{Binding SelectedDotColorChoice}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                                                            <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Color palette" />
                                            <ComboBox Classes='Small'
                                                      ItemsSource="{Binding PlotColorMapChoices}"
                                                      SelectedItem="{Binding SelectedDotColorMap}">
                                                <ComboBox.SelectionBoxItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <controls:ColorMapPreview Width="64" Height="14" ColorMap="{Binding}" />
                                                            <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.SelectionBoxItemTemplate>
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <controls:ColorMapPreview Width="64" Height="14" ColorMap="{Binding}" />
                                                            <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <CheckBox Content="Coloring in log scale" Margin="0,4,0,0"
                                                      IsEnabled="{Binding CanUseDotColorLogScale}"
                                                      IsChecked="{Binding DotColor.UseLogScale}" />
                                            <controls:ColorMapRangeSlider Height="58"
                                                                          Settings="{Binding DotColor}" />
                                        </StackPanel>

                                        <StackPanel Spacing="8" IsVisible="{Binding ShowContourDensityStyleOptions}">
                                            <CheckBox Content="Draw large dots" Margin="0,0,12,0"
                                                      IsChecked="{Binding DrawLargeDots}" />
                                            <CheckBox Content="Show outlier points" Margin="0,0,12,0"
                                                      IsChecked="{Binding ShowOutlierPoints}" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <StackPanel>
                                                    <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Contour levels" />
                                                    <TextBox Text="{Binding ContourLevelCount, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Density smoothing" />
                                                    <TextBox Text="{Binding DensitySmoothing, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                          </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <GridSplitter Grid.Row="1"
                              Height="5"
                              HorizontalAlignment="Stretch"
                              Background="{DynamicResource SemiColorSplits}"
                              ResizeDirection="Rows" />

                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource SemiColorSplits}"
                        BorderThickness="0,1,0,0"
                        Background="{DynamicResource AppBrushBackground1}"
                        Padding="16">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Gate statistics" />
                        <TextBlock Grid.Row="1"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource SemiColorText0}"
                                   Text="{Binding SelectedGateName}"
                                   FontWeight="SemiBold" />
                        <DataGrid Grid.Row="2"
                                  Margin="0,12,0,0"
                                  x:Name="statistics"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  ItemsSource="{Binding StatisticTableView}" />
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="layout_mode_grid"
                  Grid.Column="2"
                  IsVisible="{Binding IsPageEditorMode}"
                  ColumnDefinitions="*,346"
                  Background="{DynamicResource AppBrushBackground1}">
                <controls:PageEditorView x:Name="page_editor"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         Elements="{Binding PageElements}"
                                         SelectedElement="{Binding SelectedPageElement, Mode=TwoWay}"
                                         RefreshRevision="{Binding LayoutRefreshRevision}"
                                         AddElementCommand="{Binding AddPageElementCommand}" />

                <Border x:Name="layout_properties_panel"
                        Grid.Column="1"
                        BorderBrush="{DynamicResource SemiColorSplits}"
                        BorderThickness="1,0,0,0"
                        Background="{DynamicResource AppBrushBackground1}"
                        Padding="8">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="10" Margin="16 8 16 16">
                            <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Page layout" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="export_page_png_click" Classes="Small">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                    <shared:ThemeIcon Width="16" Height="16" Icon="export.svg" />
                                    <TextBlock VerticalAlignment="Center" Text="PNG" />
                                    </StackPanel>
                                </Button>
                                <Button Click="export_page_jpg_click" Classes="Small">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                    <shared:ThemeIcon Width="16" Height="16" Icon="export.svg" />
                                    <TextBlock VerticalAlignment="Center" Text="JPG" />
                                    </StackPanel>
                                </Button>
                                <Button Click="export_page_svg_click" Classes="Small">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                    <shared:ThemeIcon Width="16" Height="16" Icon="export.svg" />
                                    <TextBlock VerticalAlignment="Center" Text="SVG" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding DeletePageElementCommand}" Classes="Small Danger">
                                    <shared:ThemeIcon Width="16" Height="16" Icon="delete.svg" />
                                </Button>
                            </StackPanel>

                            <CheckBox Content="Rasterization resolution for density scatter" Margin="0 8 0 0"
                                      IsChecked="{Binding ExportBitmapApplyRasterizationResolution}" />
                            <CheckBox Content="Background transparency"
                                      IsChecked="{Binding ExportBitmapTransparentBackground}" />
                            <Grid ColumnDefinitions="Auto,100" ColumnSpacing="8" Margin="0 4 0 0">
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{DynamicResource SemiColorText2}"
                                           Text="Bitmap DPI" />
                                <NumericUpDown Grid.Column="1"
                                               Classes="Small"
                                               Minimum="72"
                                               Maximum="1200"
                                               Increment="25"
                                               Value="{Binding ExportBitmapDpi}" />
                            </Grid>

                            <Expander Header="Selected plot" Margin="0 8 0 0" IsExpanded="True">
                                <StackPanel Spacing="8" Margin="0,8,0,16" IsEnabled="{Binding HasSelectedPageElement}">
                                    <StackPanel>
                                        <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Title" />
                                        <TextBox IsEnabled="{Binding CanEditSelectedPageTitle}"
                                                 Text="{Binding SelectedPageElement.Title, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                                        <StackPanel>
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="X" />
                                            <TextBox Text="{Binding SelectedPageElement.X, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Y" />
                                            <TextBox Text="{Binding SelectedPageElement.Y, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Width" />
                                            <TextBox IsEnabled="{Binding CanEditSelectedPageWidth}"
                                                     Text="{Binding SelectedPageElement.Width, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Height" />
                                            <TextBox IsEnabled="{Binding CanEditSelectedPageHeight}"
                                                     Text="{Binding SelectedPageElement.Height, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel>
                                    <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Plot mode" />
                                    <ComboBox Classes="Small" Margin="0 0 0 4"
                                              IsEnabled="{Binding CanEditSelectedPagePlotMode}"
                                              ItemsSource="{Binding PlotModeChoices}"
                                              SelectedItem="{Binding SelectedPageElement.PlotMode}" />
                                    </StackPanel>

                                    <CheckBox Content="Show gridlines"
                                              IsEnabled="{Binding CanEditSelectedPageGridTickOptions}"
                                              IsChecked="{Binding SelectedPageElement.ShowGridlines}" />
                                    <CheckBox Content="Show tick labels"
                                              IsEnabled="{Binding CanEditSelectedPageGridTickOptions}"
                                              IsChecked="{Binding SelectedPageElement.ShowTickLabels}" />
                                    <CheckBox Content="Show gates"
                                              IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                              IsChecked="{Binding SelectedPageElement.ShowGates}" />
                                    <CheckBox Content="Show gate annotations"
                                              IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                              IsChecked="{Binding SelectedPageElement.ShowGateAnnotations}" />
                                    <CheckBox Content="Show annotation names"
                                              IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                              IsChecked="{Binding SelectedPageElement.ShowGateAnnotationNames}" />

                                    <StackPanel Spacing="8" IsVisible="{Binding ShowSelectedPageDensityStyleOptions}">
                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Density palette" />
                                        <ComboBox Classes="Small"
                                                  IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                                  ItemsSource="{Binding PlotColorMapChoices}"
                                                  SelectedItem="{Binding SelectedPageDensityColorMap}">
                                            <ComboBox.SelectionBoxItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <controls:ColorMapPreview Width="64" Height="14" ColorMap="{Binding}" />
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.SelectionBoxItemTemplate>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <controls:ColorMapPreview Width="64" Height="14" ColorMap="{Binding}" />
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="8" IsVisible="{Binding ShowSelectedPageDotplotStyleOptions}">
                                        <CheckBox Content="Draw large dots"
                                                  IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                                  IsChecked="{Binding SelectedPageElement.DrawLargeDots}" />
                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Dot color" />
                                        <ComboBox Classes="Small"
                                                  IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                                  ItemsSource="{Binding SelectedPageColorChoices}"
                                                  SelectedItem="{Binding SelectedPageDotColorChoice, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                                                        <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Color palette" />
                                        <ComboBox Classes="Small"
                                                  IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                                  ItemsSource="{Binding PlotColorMapChoices}"
                                                  SelectedItem="{Binding SelectedPageDotColorMap}">
                                            <ComboBox.SelectionBoxItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <controls:ColorMapPreview Width="64" Height="14" ColorMap="{Binding}" />
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.SelectionBoxItemTemplate>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <controls:ColorMapPreview Width="64" Height="14" ColorMap="{Binding}" />
                                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <CheckBox Content="Coloring in log scale"
                                                  IsEnabled="{Binding CanUseSelectedPageDotColorLogScale}"
                                                  IsChecked="{Binding SelectedPageElement.DotColor.UseLogScale}" />
                                        <controls:ColorMapRangeSlider Height="58"
                                                                      IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                                                      Settings="{Binding SelectedPageElement.DotColor}" />
                                    </StackPanel>

                                    <StackPanel Spacing="8" IsVisible="{Binding ShowSelectedPageContourDensityStyleOptions}">
                                        <CheckBox Content="Draw large dots"
                                                  IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                                  IsChecked="{Binding SelectedPageElement.DrawLargeDots}" />
                                        <CheckBox Content="Show outlier points"
                                                  IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                                  IsChecked="{Binding SelectedPageElement.ShowOutlierPoints}" />
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <StackPanel>
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Contours" />
                                                <TextBox IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                                         Text="{Binding SelectedPageElement.ContourLevelCount, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Smoothing" />
                                                <TextBox IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                                         Text="{Binding SelectedPageElement.DensitySmoothing, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <Expander Header="X axis" IsExpanded="False">
                                <StackPanel Spacing="8" Margin="0,8,0,16" IsEnabled="{Binding CanEditSelectedPageAxes}">
                                    <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Selected channel" />
                                    <ComboBox Classes="Small"
                                              ItemsSource="{Binding SelectedPageAxisChoices}"
                                              SelectedItem="{Binding SelectedPageXAxisChoice, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                                                    <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <StackPanel>
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Minimum" />
                                            <TextBox Text="{Binding SelectedPageElement.XAxis.Minimum, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Maximum" />
                                            <TextBox Text="{Binding SelectedPageElement.XAxis.Maximum, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Axis scale" />
                                    <ComboBox Classes="Small"
                                              ItemsSource="{Binding CoordinateScaleChoices}"
                                              SelectedItem="{Binding SelectedPageElement.XAxis.ScaleKind}" />

                                    <Grid IsVisible="{Binding SelectedPageElement.XAxis.IsLogicle}" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="8">
                                        <StackPanel>
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Top of scale (T)" />
                                            <TextBox Text="{Binding SelectedPageElement.XAxis.LogicleTopOfScale, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Number of decades (M)" />
                                            <TextBox Text="{Binding SelectedPageElement.XAxis.LogicleDecades, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Linearization width (W)" />
                                            <TextBox Text="{Binding SelectedPageElement.XAxis.LogicleLinearizationWidth, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Negative decades (A)" />
                                            <TextBox Text="{Binding SelectedPageElement.XAxis.LogicleNegativeDecades, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel IsVisible="{Binding SelectedPageElement.XAxis.IsArcsinh}">
                                        <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Arcsinh cofactor" />
                                        <TextBox Text="{Binding SelectedPageElement.XAxis.ArcsinhCofactor, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <Expander Header="Y axis" IsExpanded="False">
                                <StackPanel Spacing="8" Margin="0,8,0,16" IsEnabled="{Binding CanEditSelectedPageAxes}">
                                    <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Selected channel" />
                                    <ComboBox Classes="Small"
                                              ItemsSource="{Binding SelectedPageAxisChoices}"
                                              SelectedItem="{Binding SelectedPageYAxisChoice, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                                                    <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <StackPanel>
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Minimum" />
                                            <TextBox Text="{Binding SelectedPageElement.YAxis.Minimum, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Maximum" />
                                            <TextBox Text="{Binding SelectedPageElement.YAxis.Maximum, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Axis scale" />
                                    <ComboBox Classes="Small"
                                              ItemsSource="{Binding CoordinateScaleChoices}"
                                              SelectedItem="{Binding SelectedPageElement.YAxis.ScaleKind}" />

                                    <Grid IsVisible="{Binding SelectedPageElement.YAxis.IsLogicle}" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="8">
                                        <StackPanel>
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Top of scale (T)" />
                                            <TextBox Text="{Binding SelectedPageElement.YAxis.LogicleTopOfScale, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Number of decades (M)" />
                                            <TextBox Text="{Binding SelectedPageElement.YAxis.LogicleDecades, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Linearization width (W)" />
                                            <TextBox Text="{Binding SelectedPageElement.YAxis.LogicleLinearizationWidth, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Negative decades (A)" />
                                            <TextBox Text="{Binding SelectedPageElement.YAxis.LogicleNegativeDecades, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel IsVisible="{Binding SelectedPageElement.YAxis.IsArcsinh}">
                                        <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Arcsinh cofactor" />
                                        <TextBox Text="{Binding SelectedPageElement.YAxis.ArcsinhCofactor, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid Grid.Column="2"
                  IsVisible="{Binding IsSpilloverCompensationMode}"
                  Background="{DynamicResource AppBrushBackground1}">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24"
                                Spacing="14"
                                MaxWidth="750"
                                MinWidth="750"
                                HorizontalAlignment="Center">

                        <StackPanel Margin="0 12 0 12" Spacing="8">
                            <TextBlock Foreground="{DynamicResource AppBrushText2}" FontWeight="Bold" Text="Conventional Spillover Compensation" />
                            <TextBlock Foreground="{DynamicResource SemiColorText1}"  TextWrapping="Wrap" LineHeight="18"
                                       Text="Spillover occurs when fluorophores emit light that bleeds into adjacent detection channels. Compensation mathematically corrects this by subtracting the spillover signal from each channel based on single stained control measurements." />
                        </StackPanel>

                        <Grid ColumnDefinitions="280,*" ColumnSpacing="5" IsVisible="{Binding HasSpilloverControls}">
                            <Grid RowDefinitions="28, 250">
                                <Grid Grid.Row="1"
                                      Grid.Column="0"
                                      Height="250"
                                      Margin="0">
                                    <controls:ScatterGateView Sample="{Binding SpilloverScatterSample}"
                                                              XChannel="{Binding SpilloverFscChannel}"
                                                              YChannel="{Binding SpilloverSscChannel}"
                                                              XMinimum="{Binding SpilloverScatterXMinimum}"
                                                              XMaximum="{Binding SpilloverScatterXMaximum}"
                                                              XScale="{Binding SpilloverScatterXScale}"
                                                              YMinimum="{Binding SpilloverScatterYMinimum}"
                                                              YMaximum="{Binding SpilloverScatterYMaximum}"
                                                              YScale="{Binding SpilloverScatterYScale}"
                                                              Vertices="{Binding SpilloverPrimaryVertices}"
                                                              VerticesCommittedCommand="{Binding MarkSpilloverPreviewOutdatedCommand}" />
                                    <Border IsVisible="{Binding IsSpilloverPreparingRowCaches}"
                                            IsHitTestVisible="False"
                                            Width="96"
                                            Height="96"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            CornerRadius="10"
                                            Background="{DynamicResource AppBrushBackground5}"
                                            BorderBrush="{DynamicResource AppBrushBorder1}"
                                            BorderThickness="1"
                                            Opacity="0.6"
                                            Margin="72 10 18 42">
                                        <Grid HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Width="48" Height="48">
                                            <controls:SpinnerView Width="48"
                                                                  Height="48"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ComboBox Classes="Small" Width="120" Margin="52 0 0 0" ItemsSource="{Binding SpilloverGatePresets}" SelectedItem="{Binding SelectedSpilloverGatePreset}" />
                                    <Button Grid.Column="1" Classes="Small" Command="{Binding NewSpilloverGatePresetCommand}">
                                        <shared:ThemeIcon Width="16" Height="16" Icon="gate.svg" />
                                    </Button>
                                </Grid>
                            </Grid>
                            <Grid Grid.Column="1" RowDefinitions="28, 250">
                                <controls:HistogramView Grid.Row="1"
                                                        Height="250"
                                                        Margin="0 -14 0 14"
                                                        Series="{Binding SpilloverHistogramSeries}"
                                                        AxisScale="{Binding SpilloverHistogramAxisScale}"
                                                        LogicleTopOfScale="{Binding SpilloverHistogramLogicleT}"
                                                        LogicleLinearizationWidth="{Binding SpilloverHistogramLogicleW}"
                                                        LogicleDecades="{Binding SpilloverHistogramLogicleM}"
                                                        LogicleNegativeDecades="{Binding SpilloverHistogramLogicleA}"
                                                        BinSmoothing="3"
                                                        YMaximumFactor="1.1"
                                                        IsGatingEnabled="True"
                                                        Selection="{Binding SpilloverSelection, Mode=TwoWay}" />

                                <Grid ColumnDefinitions="Auto,150,Auto" Grid.Row="0" ColumnSpacing="8" VerticalAlignment="Center" HorizontalAlignment="Center" Height="32">
                                    <Button Classes="Small" Width="30" Command="{Binding SelectPreviousSpilloverChannelCommand}">
                                        <shared:ThemeIcon Width="16" Height="16" Icon="back.svg" />
                                    </Button>
                                    <ComboBox Grid.Column="1"
                                              Width="150"
                                              Classes="Small"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ItemsSource="{Binding SpilloverConfiguredParameterChoices}"
                                              SelectedItem="{Binding SelectedSpilloverParameterChoice, Mode=TwoWay}" />
                                    <Button Grid.Column="2" Classes="Small" Width="30" Command="{Binding SelectNextSpilloverChannelCommand}">
                                        <shared:ThemeIcon Width="16" Height="16" Icon="right.svg" />
                                    </Button>
                                </Grid>
                            </Grid>
                        </Grid>

                        <TextBlock Foreground="{DynamicResource SemiColorText1}"
                                   Text="Drag samples to the area for blank control and single-staining samples" />


                        <Border x:Name="spillover_control_drop_target" Height="300"
                                BorderBrush="{DynamicResource AppBrushBorder3}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Background="{DynamicResource AppBrushBackground3}"
                                ClipToBounds="True">
                            <DataGrid x:Name="spillover_control_table" Classes="ControlSampleGrid"
                                      AutoGenerateColumns="False" CanUserResizeColumns="True" SelectionMode="Single"
                                      ItemsSource="{Binding SpilloverRows}" SelectedItem="{Binding SelectedSpilloverRow, Mode=TwoWay}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Control sample" Width="*" MinWidth="150">
                                        <DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Classes="IconRow" Orientation="Horizontal" Spacing="7"><shared:ThemeIcon Width="15" Height="15" Icon="{Binding SampleIcon}" /><TextBlock Text="{Binding SampleName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Parameter" Width="150" MinWidth="100">
                                        <DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox Classes="Small" HorizontalAlignment="Stretch" ItemsSource="{Binding ParameterChoices}" SelectedItem="{Binding ParameterName, Mode=TwoWay}" /></DataTemplate></DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Population" Width="190" MinWidth="110">
                                        <DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Classes="IconRow" Orientation="Horizontal" Spacing="7"><shared:ThemeIcon Width="15" Height="15" Icon="{Binding PopulationIcon}" /><TextBlock Text="{Binding PositivePercentText}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="52" CanUserResize="False">
                                        <DataGridTemplateColumn.CellTemplate><DataTemplate><Button Classes="Small" HorizontalAlignment="Center" Command="{Binding RemoveCommand}" CommandParameter="{Binding}" ToolTip.Tip="Remove from plot"><shared:ThemeIcon Width="15" Height="15" Icon="{Binding RemoveIcon}" /></Button></DataTemplate></DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <StackPanel Margin="0 12 0 4" IsVisible="{Binding HasSpilloverControls}">
                            <TextBlock Foreground="{DynamicResource SemiColorText1}" TextWrapping="Wrap" LineHeight="18"
                                       Text="Calculate auto-compensation will overwrite matrix. You may calculate once and manually edit the table before applying it to the group. Once generated, the preview matrix plot will update real-time as you edit." />
                        </StackPanel>

                        <Grid Margin="0 4 0 6" ColumnDefinitions="Auto,220,*,Auto,Auto" ColumnSpacing="10" IsVisible="{Binding HasSpilloverControls}">
                            <TextBlock Text="Compensation Matrix"
                                       Foreground="{DynamicResource SemiColorText2}"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Classes="Small"
                                     Text="{Binding SpilloverMatrixName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <Button Grid.Column="3"
                                    Classes="Small"
                                    Command="{Binding CalculateSpilloverCompensationCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <shared:ThemeIcon Width="16" Height="16" Icon="ok.svg" />
                                    <TextBlock Text="Calculate Auto-compensation" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="4"
                                    Classes="Small"
                                    Command="{Binding ApplySpilloverCompensationCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <shared:ThemeIcon Width="16" Height="16" Icon="ok.svg" />
                                    <TextBlock Text="Apply" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border IsVisible="{Binding HasSpilloverPreviewMatrix}"
                                BorderBrush="{DynamicResource AppBrushBorder3}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Background="{DynamicResource AppBrushBackground3}"
                                Padding="8"
                                Margin="0,0,0,10">
                            <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock />
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding SpilloverPreviewChannels}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Width="100"
                                                           Text="{Binding}"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource SemiColorText1}"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,0,4,0"
                                                           TextTrimming="CharacterEllipsis" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding SpilloverPreviewMatrixRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="100,*" Margin="0,2">
                                                <TextBlock Text="{Binding ChannelName}"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource SemiColorText1}"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Right"
                                                           HorizontalAlignment="Stretch"
                                                           Margin="0,0,10,0"
                                                           TextTrimming="CharacterEllipsis" />
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Values}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBox Width="100"
                                                                     Margin="0,0,4,0"
                                                                     Classes="Small"
                                                                     Classes.SpilloverMatrixInvalid="{Binding IsInvalid}"
                                                                     FontSize="13"
                                                                     IsReadOnly="{Binding IsDiagonal}"
                                                                     IsEnabled="{Binding IsEditable}"
                                                                     Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Expander Header="Preview matrix"
                                  IsVisible="{Binding HasSpilloverPreviewMatrix}"
                                  IsExpanded="True"
                                  Margin="0 -8 0 24">
                            <ScrollViewer MaxHeight="750"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="10" Margin="0,8,0,0">
                                <Border IsVisible="{Binding IsSpilloverPreviewOutdated}"
                                        Background="{DynamicResource AppBrushWarningBackground}"
                                        BorderBrush="{DynamicResource AppBrushWarningBorderMuted}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,7">
                                    <TextBlock Text="Preview is outdated. Recalculate to update the matrix and plots."
                                               FontSize="13"
                                               Foreground="{DynamicResource AppBrushWarningTextStrong}" />
                                </Border>
                                <Border BorderBrush="{DynamicResource AppBrushBorder3}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Background="{DynamicResource AppBrushBackground3}"
                                        Padding="8">
                                    <StackPanel Spacing="6">
                                        <Grid ColumnDefinitions="30,*">
                                            <TextBlock />
                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding SpilloverPreviewChannels}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Width="150"
                                                                   Text="{Binding}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource SemiColorText1}"
                                                                   TextAlignment="Center"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,0,2,0"
                                                                   Padding="15,0,0,0"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding SpilloverPreviewPlotRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnDefinitions="30,*" Margin="0,0,0,2">
                                                        <LayoutTransformControl Margin="10 0 5 15">
                                                            <LayoutTransformControl.LayoutTransform>
                                                                <RotateTransform Angle="-90" />
                                                            </LayoutTransformControl.LayoutTransform>
                                                            <TextBlock Text="{Binding YChannel}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource SemiColorText1}"
                                                                   VerticalAlignment="Center"
                                                                   TextAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        </LayoutTransformControl>

                                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <controls:SpilloverPreviewScatterView Width="150"
                                                                                                          Height="150"
                                                                                                          Margin="0,0,2,0"
                                                                                                          Cell="{Binding}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            </ScrollViewer>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Column="2"
                  IsVisible="{Binding IsMassCompensationMode}"
                  Background="{DynamicResource AppBrushBackground1}">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24" Spacing="14" MaxWidth="750" MinWidth="750" HorizontalAlignment="Center">
                        <StackPanel Margin="0 12" Spacing="8">
                            <TextBlock Foreground="{DynamicResource AppBrushText2}" FontWeight="Bold" Text="Mass Cytometry Compensation" />
                            <TextBlock Foreground="{DynamicResource SemiColorText1}" TextWrapping="Wrap" LineHeight="18"
                                       Text="Mass compensation estimates isotopic impurity, adjacent-mass abundance sensitivity, and oxide spillover from ungated single-staining control tubes." />
                        </StackPanel>

                        <TextBlock Foreground="{DynamicResource SemiColorText1}"
                                   Text="Drag single-staining control samples into the table. Each tube is sampled deterministically at up to 5,000 events." />
                        <Border x:Name="mass_compensation_drop_target" Height="300"
                                BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource AppBrushBackground3}" ClipToBounds="True">
                            <DataGrid x:Name="mass_compensation_table" Classes="ControlSampleGrid"
                                      AutoGenerateColumns="False" CanUserResizeColumns="True" SelectionMode="Single"
                                      ItemsSource="{Binding MassCompensationPanel.Rows}" SelectedItem="{Binding MassCompensationPanel.SelectedRow, Mode=TwoWay}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Control sample name" Width="*" MinWidth="160">
                                        <DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Classes="IconRow" Orientation="Horizontal" Spacing="7"><shared:ThemeIcon Width="15" Height="15" Icon="{Binding SampleIcon}" /><TextBlock Text="{Binding SampleName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Single-staining isotope" Width="240" MinWidth="130">
                                        <DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox Classes="Small" HorizontalAlignment="Stretch" ItemsSource="{Binding IsotopeChoices}" SelectedValueBinding="{Binding ChannelName}" SelectedValue="{Binding SourceChannelName, Mode=TwoWay}" /></DataTemplate></DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="52" CanUserResize="False">
                                        <DataGridTemplateColumn.CellTemplate><DataTemplate><Button Classes="Small" HorizontalAlignment="Center" Command="{Binding RemoveCommand}" CommandParameter="{Binding}" ToolTip.Tip="Remove control tube"><shared:ThemeIcon Width="15" Height="15" Icon="{Binding RemoveIcon}" /></Button></DataTemplate></DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Grid ColumnDefinitions="Auto,220,*,Auto,Auto" ColumnSpacing="10"
                              IsVisible="{Binding MassCompensationPanel.HasRows}">
                            <TextBlock Text="Compensation Matrix" Foreground="{DynamicResource SemiColorText2}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Classes="Small"
                                     Text="{Binding MassCompensationPanel.MatrixName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <Button Grid.Column="3" Classes="Small" Command="{Binding MassCompensationPanel.CalculateCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <shared:ThemeIcon Width="16" Height="16" Icon="ok.svg" />
                                    <TextBlock Text="Calculate Auto-compensation" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="4" Classes="Small" Command="{Binding MassCompensationPanel.ApplyCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <shared:ThemeIcon Width="16" Height="16" Icon="ok.svg" />
                                    <TextBlock Text="Apply" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border Background="{DynamicResource AppBrushBackground3}" BorderBrush="{DynamicResource AppBrushBorder3}"
                                BorderThickness="1" CornerRadius="6" Padding="10,7">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding MassCompensationPanel.Status}" TextWrapping="Wrap"
                                           Foreground="{DynamicResource SemiColorText1}" VerticalAlignment="Center" />
                                <controls:SpinnerView Grid.Column="1" Width="24" Height="24"
                                                      IsVisible="{Binding MassCompensationPanel.IsBusy}" />
                            </Grid>
                        </Border>

                        <Expander Header="Spillover matrix" IsExpanded="True"
                                  IsVisible="{Binding MassCompensationPanel.HasMatrix}" Margin="0,0,0,24">
                            <StackPanel Margin="0,8,0,0" Spacing="10">
                                <Border IsVisible="{Binding MassCompensationPanel.IsStale}"
                                        Background="{DynamicResource AppBrushWarningBackground}"
                                        BorderBrush="{DynamicResource AppBrushWarningBorderMuted}" BorderThickness="1"
                                        CornerRadius="6" Padding="10,7">
                                    <TextBlock Text="The matrix is outdated. Recalculate after changing control assignments."
                                               Foreground="{DynamicResource AppBrushWarningTextStrong}" />
                                </Border>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="18">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Border Width="18" Height="18" BorderBrush="#70C99B" BorderThickness="3" />
                                            <TextBlock Text="Isotopic impurity" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Border Width="18" Height="18" BorderBrush="#3D43B8" BorderThickness="3" />
                                            <TextBlock Text="M±1" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Border Width="18" Height="18" BorderBrush="#C92C2C" BorderThickness="3" />
                                            <TextBlock Text="M+16" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                    <CheckBox x:Name="mass_compensation_matrix_annotate" Grid.Column="1"
                                              Content="Annotate" IsChecked="False"
                                              Foreground="{DynamicResource SemiColorText1}" />
                                </Grid>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <controls:SpectralMatrixView Rows="{Binding MassCompensationPanel.MatrixRows}"
                                                                 ColumnLabels="{Binding MassCompensationPanel.MatrixColumnLabels}"
                                                                 XAxisTitle="Receiving isotope"
                                                                 YAxisTitle="Source isotope"
                                                                 IgnoreDiagonal="True"
                                                                 IsEditMode="{Binding IsChecked, ElementName=mass_compensation_matrix_annotate}"
                                                                 ShowAnnotations="{Binding IsChecked, ElementName=mass_compensation_matrix_annotate}"
                                                                 Palette="GrayRed" />
                                </ScrollViewer>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Column="2"
                  IsVisible="{Binding IsSpectralUnmixingMode}"
                  Background="{DynamicResource AppBrushBackground1}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24"
                                Spacing="14"
                                MaxWidth="750"
                                MinWidth="750"
                                HorizontalAlignment="Center">

                        <StackPanel Margin="0 12 0 12" Spacing="8">
                            <TextBlock Foreground="{DynamicResource AppBrushText2}" FontWeight="Bold" Text="Spectral Unmixing" />
                            <TextBlock Foreground="{DynamicResource SemiColorText1}" TextWrapping="Wrap" LineHeight="18"
                                       Text="Spectral unmixing derives fluroscence signature for each stained flurochrome, and then decomposite the spectral measurement of samples into fractions for real staining channels." />
                        </StackPanel>

                        <Grid ColumnDefinitions="280,*" ColumnSpacing="5" IsVisible="{Binding SpectralPanel.HasControls}">
                            <Grid RowDefinitions="28, 250">
                                <Grid Grid.Row="1">
                                    <controls:ScatterGateView Sample="{Binding SpectralPanel.ScatterSample}"
                                                              XChannel="{Binding SpectralPanel.GateXChannel}" YChannel="{Binding SpectralPanel.GateYChannel}"
                                                              XMinimum="{Binding SpectralPanel.GateXMinimum}" XMaximum="{Binding SpectralPanel.GateXMaximum}" XScale="{Binding SpectralPanel.GateXScale}"
                                                              YMinimum="{Binding SpectralPanel.GateYMinimum}" YMaximum="{Binding SpectralPanel.GateYMaximum}" YScale="{Binding SpectralPanel.GateYScale}"
                                                              Vertices="{Binding SpectralPanel.GateVertices}"
                                                              VerticesCommittedCommand="{Binding SpectralPanel.GateCommittedCommand}" />
                                    <Border IsVisible="{Binding SpectralPanel.IsPreparingRowCaches}"
                                            IsHitTestVisible="False"
                                            Width="96"
                                            Height="96"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            CornerRadius="10"
                                            Background="{DynamicResource AppBrushBackground5}"
                                            BorderBrush="{DynamicResource AppBrushBorder1}"
                                            BorderThickness="1"
                                            Opacity="0.6"
                                            Margin="72 10 18 42">
                                        <Grid HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Width="48" Height="48">
                                            <controls:SpinnerView Width="48"
                                                                  Height="48"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ComboBox Classes="Small" Width="120" Margin="52 0 0 0" ItemsSource="{Binding SpectralPanel.GatePresets}" SelectedItem="{Binding SpectralPanel.SelectedGatePreset}" />
                                    <Button Grid.Column="1" Classes="Small" Command="{Binding SpectralPanel.NewGatePresetCommand}" >
                                        <shared:ThemeIcon Width="16" Height="16" Icon="gate.svg" />
                                    </Button>
                                </Grid>
                            </Grid>
                            <Grid Grid.Column="1" RowDefinitions="12, 250">
                                <controls:HistogramView Grid.Row="1" Height="250" Series="{Binding SpectralPanel.HistogramSeries}"
                                                        AxisScale="Logicle" IsGatingEnabled="True"
                                                        Selection="{Binding SpectralPanel.HistogramSelection, Mode=TwoWay}" />
                            </Grid>
                        </Grid>

                        <controls:SpectralPlotView Height="220" IsVisible="{Binding SpectralPanel.HasControls}" Data="{Binding SpectralPanel.SelectedPlotData}"
                                                   Signature="{Binding SpectralPanel.SelectedSignature}"
                                                   SignatureAmplitude="{Binding SpectralPanel.SelectedSignatureAmplitude}"
                                                   PlotBackground="Red"
                                                   PlotForeground="{DynamicResource SemiColorText0}" />

                        <TextBlock Foreground="{DynamicResource SemiColorText1}" Text="Drag blank and single-staining control samples into the table" />
                        <Border x:Name="spectral_control_drop_target" Height="300" BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource AppBrushBackground3}">
                            <DataGrid x:Name="spectral_control_table" Classes="ControlSampleGrid"
                                      AutoGenerateColumns="False" CanUserResizeColumns="True" SelectionMode="Single"
                                      ItemsSource="{Binding SpectralPanel.Rows}" SelectedItem="{Binding SpectralPanel.SelectedRow, Mode=TwoWay}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Control sample" Width="165" MinWidth="120"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Classes="IconRow" Orientation="Horizontal" Spacing="7"><shared:ThemeIcon Width="15" Height="15" Icon="{Binding SampleIcon}" /><TextBlock Text="{Binding SampleName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Unmixing molecule" Width="155" MinWidth="100"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBox Classes="Small" HorizontalAlignment="Stretch" Text="{Binding MoleculeName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Maximum channel" Width="150" MinWidth="100"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox Classes="Small" HorizontalAlignment="Stretch" ItemsSource="{Binding MaximumChannelChoices}" SelectedItem="{Binding MaximumChannel, Mode=TwoWay}" IsEnabled="{Binding !IsBackground}"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" /></DataTemplate></ComboBox.ItemTemplate></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Population" Width="*" MinWidth="130"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Classes="IconRow" Orientation="Horizontal" Spacing="7"><shared:ThemeIcon Width="15" Height="15" Icon="{Binding PopulationIcon}" /><TextBlock Text="{Binding PositivePercentText}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="52" CanUserResize="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><Button Classes="Small" HorizontalAlignment="Center" Command="{Binding RemoveCommand}" CommandParameter="{Binding}" ToolTip.Tip="Remove control"><shared:ThemeIcon Width="15" Height="15" Icon="{Binding RemoveIcon}" /></Button></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Grid ColumnDefinitions="Auto,220,Auto,*,Auto" ColumnSpacing="8" IsVisible="{Binding SpectralPanel.HasControls}">
                            <TextBlock Text="Output grouping"
                                       Foreground="{DynamicResource SemiColorText2}"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      Width="220"
                                      Classes="Small"
                                      ItemsSource="{Binding SpectralPanel.OutputGroupChoices}"
                                      SelectedItem="{Binding SpectralPanel.SelectedOutputGroupChoice, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <shared:ThemeIcon Width="15" Height="15" Icon="group.svg" />
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Column="2" Classes="Small" Content="Apply to grouping" Command="{Binding SpectralPanel.ApplyCommand}" />
                            <Button Grid.Column="4" Classes="Small" Content="Fit model" Command="{Binding SpectralPanel.FitCommand}" HorizontalAlignment="Right" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12"
                              IsVisible="{Binding SpectralPanel.IsApplying}">
                            <ProgressBar Minimum="0"
                                         Maximum="100"
                                         Height="8"
                                         VerticalAlignment="Center"
                                         Value="{Binding SpectralPanel.ApplyProgress}" />
                            <TextBlock Grid.Column="1"
                                       MinWidth="250"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource SemiColorText1}"
                                       Text="{Binding SpectralPanel.ApplyProgressText}" />
                        </Grid>

                        <Border IsVisible="{Binding SpectralPanel.HasWarning}"
                                BorderBrush="{DynamicResource AppBrushWarningBorder}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Background="{DynamicResource AppBrushWarningBackground}">
                            <TextBlock Foreground="{DynamicResource AppBrushWarningText}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SpectralPanel.WarningText}" />
                        </Border>

                        <Expander Header="Spectrum cosine similarity" IsExpanded="True" IsVisible="{Binding SpectralPanel.HasFitResults}">
                            <StackPanel Spacing="6">
                                <CheckBox x:Name="similarity_matrix_annotate" Content="Annotate" IsChecked="False" Foreground="{DynamicResource SemiColorText1}" />
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <controls:SpectralMatrixView Rows="{Binding SpectralPanel.SimilarityRows}"
                                                                 ColumnLabels="{Binding SpectralPanel.SimilarityColumnLabels}"
                                                                 XAxisTitle="Spectrum"
                                                                 YAxisTitle="Spectrum"
                                                                 StressAbove="0.95"
                                                                 ShowAnnotations="{Binding IsChecked, ElementName=similarity_matrix_annotate}"
                                                                 Palette="Auto"
                                                                 TextBrush="{DynamicResource SemiColorText0}"
                                                                 GridBrush="{DynamicResource SemiColorBorder}" />
                                </ScrollViewer>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Normalized spectrum signature" IsExpanded="True" IsVisible="{Binding SpectralPanel.HasFitResults}">
                            <StackPanel Spacing="6">
                                <CheckBox x:Name="signature_matrix_annotate" Content="Annotate" IsChecked="False" Foreground="{DynamicResource SemiColorText1}" />
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <controls:SpectralMatrixView Rows="{Binding SpectralPanel.SignatureRows}"
                                                                 ColumnLabels="{Binding SpectralPanel.DetectorColumnLabels}"
                                                                 XAxisTitle="Laser detector"
                                                                 YAxisTitle="Dye / AF"
                                                                 ShowAnnotations="{Binding IsChecked, ElementName=signature_matrix_annotate}"
                                                                 Palette="Auto"
                                                                 TextBrush="{DynamicResource SemiColorText0}"
                                                                 GridBrush="{DynamicResource SemiColorBorder}" />
                                </ScrollViewer>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Fitted weights of transform matrix" IsExpanded="True" IsVisible="{Binding SpectralPanel.HasFitResults}">
                            <StackPanel Spacing="6">
                                <CheckBox x:Name="coefficient_matrix_annotate" Content="Annotate" IsChecked="False" Foreground="{DynamicResource SemiColorText1}" />
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <controls:SpectralMatrixView Rows="{Binding SpectralPanel.CoefficientRows}"
                                                                 ColumnLabels="{Binding SpectralPanel.DetectorColumnLabels}"
                                                                 XAxisTitle="Raw detector"
                                                                 YAxisTitle="Unmixed output / AF"
                                                                 IsEditMode="{Binding IsChecked, ElementName=coefficient_matrix_annotate}"
                                                                 ShowAnnotations="{Binding IsChecked, ElementName=coefficient_matrix_annotate}"
                                                                 Palette="Auto"
                                                                 TextBrush="{DynamicResource SemiColorText0}"
                                                                 GridBrush="{DynamicResource SemiColorBorder}" />
                                </ScrollViewer>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Column="2"
                  IsVisible="{Binding IsMassNormalizationMode}"
                  Background="{DynamicResource AppBrushBackground1}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24" Spacing="14" MaxWidth="750" MinWidth="750" HorizontalAlignment="Center">
                        <StackPanel Margin="0 12" Spacing="8">
                            <TextBlock Foreground="{DynamicResource AppBrushText2}" FontWeight="Bold" Text="Mass normalization" />
                            <TextBlock Foreground="{DynamicResource SemiColorText1}" TextWrapping="Wrap" LineHeight="18"
                                       Text="Element bead signals provide a time-dependent reference for correcting acquisition drift in mass-cytometry channels. Add samples, verify the automatically detected bead gates, and write normalized copies to a separate grouping." />
                        </StackPanel>

                        <Grid ColumnDefinitions="280,*" ColumnSpacing="5" IsVisible="{Binding MassPanel.HasRows}">
                            <Grid RowDefinitions="28,250">
                                <Grid ColumnDefinitions="Auto,150,Auto" ColumnSpacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Classes="Small" Width="30" Command="{Binding MassPanel.SelectPreviousGatePlotCommand}">
                                        <shared:ThemeIcon Width="16" Height="16" Icon="back.svg" />
                                    </Button>
                                    <ComboBox Grid.Column="1" Width="150" Classes="Small"
                                              ItemsSource="{Binding MassPanel.GatePlots}"
                                              SelectedItem="{Binding MassPanel.SelectedGatePlot, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Button Grid.Column="2" Classes="Small" Width="30" Command="{Binding MassPanel.SelectNextGatePlotCommand}">
                                        <shared:ThemeIcon Width="16" Height="16" Icon="right.svg" />
                                    </Button>
                                </Grid>
                                <controls:ScatterGateView Grid.Row="1" Height="250" Margin="0 -12 0 12"
                                                          Sample="{Binding MassPanel.SelectedGatePlot.Sample}"
                                                          XChannel="{Binding MassPanel.SelectedGatePlot.XChannel}"
                                                          YChannel="{Binding MassPanel.SelectedGatePlot.YChannel}"
                                                          XMinimum="0" XMaximum="{Binding MassPanel.SelectedGatePlot.XMaximum}"
                                                          XScale="{Binding MassPanel.SelectedGatePlot.XScale}"
                                                          YMinimum="0" YMaximum="{Binding MassPanel.SelectedGatePlot.YMaximum}"
                                                          YScale="{Binding MassPanel.SelectedGatePlot.YScale}"
                                                          Vertices="{Binding MassPanel.SelectedGatePlot.Vertices}"
                                                          VerticesCommittedCommand="{Binding MassPanel.GateCommittedCommand}" />
                            </Grid>
                            <controls:TimeDynamicsView Grid.Column="1" Height="278" Margin="0 5 0 -5" Data="{Binding MassPanel.TimeDynamics}" />
                        </Grid>

                        <TextBlock Foreground="{DynamicResource SemiColorText1}" Margin="0 8 0 0" Text="Drag regular samples from this grouping into the table" />
                        <Border x:Name="mass_normalization_drop_target" Height="300" BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource AppBrushBackground3}">
                            <DataGrid x:Name="mass_normalization_table" Classes="ControlSampleGrid"
                                      AutoGenerateColumns="False" CanUserResizeColumns="True" SelectionMode="Single"
                                      ItemsSource="{Binding MassPanel.Rows}" SelectedItem="{Binding MassPanel.SelectedRow, Mode=TwoWay}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Sample" Width="165" MinWidth="120"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Classes="IconRow" Orientation="Horizontal" Spacing="7"><shared:ThemeIcon Width="15" Height="15" Icon="{Binding SampleIcon}" /><TextBlock Text="{Binding SampleName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Bead type" Width="120" MinWidth="90"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox Classes="Small" HorizontalAlignment="Stretch" ItemsSource="{Binding BeadTypes}" SelectedItem="{Binding SelectedBeadType, Mode=TwoWay}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Bead lot" Width="120" MinWidth="90"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox Classes="Small" HorizontalAlignment="Stretch" ItemsSource="{Binding BeadLots}" SelectedItem="{Binding SelectedBeadLot, Mode=TwoWay}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="DNA channel" Width="110" MinWidth="90"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox Classes="Small" HorizontalAlignment="Stretch" ItemsSource="{Binding DnaChannels}" SelectedItem="{Binding DnaChannel, Mode=TwoWay}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Bead detection" Width="*" MinWidth="150"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Classes="IconRow" Orientation="Horizontal" Spacing="7"><shared:ThemeIcon Width="15" Height="15" Icon="{Binding PopulationIcon}" /><TextBlock Text="{Binding PopulationText}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="52" CanUserResize="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><Button Classes="Small" HorizontalAlignment="Center" Command="{Binding RemoveCommand}" CommandParameter="{Binding}" ToolTip.Tip="Remove sample"><shared:ThemeIcon Width="15" Height="15" Icon="{Binding RemoveIcon}" /></Button></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <CheckBox Content="Remove beads and bead-associated doublets from output" IsChecked="{Binding MassPanel.RemoveBeadsAndDoublets, Mode=TwoWay}" />
                        <Grid ColumnDefinitions="Auto,220,*,Auto" ColumnSpacing="8" IsVisible="{Binding MassPanel.HasRows}">
                            <TextBlock Text="Output grouping" Foreground="{DynamicResource SemiColorText2}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" Width="220" Classes="Small" ItemsSource="{Binding MassPanel.OutputGroupChoices}" SelectedItem="{Binding MassPanel.SelectedOutputGroupChoice, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <shared:ThemeIcon Width="15" Height="15" Icon="group.svg" />
                                            <TextBlock Text="{Binding Name}" Margin="0 0 8 0" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Column="3" Classes="Small" Content="Apply to grouping" Command="{Binding MassPanel.ApplyCommand}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" IsVisible="{Binding MassPanel.IsApplying}">
                            <ProgressBar Minimum="0" Maximum="100" Height="8" VerticalAlignment="Center" Value="{Binding MassPanel.ApplyProgress}" />
                            <TextBlock Grid.Column="1" MinWidth="250" TextAlignment="Right" Foreground="{DynamicResource SemiColorText1}" Text="{Binding MassPanel.ApplyProgressText}" />
                        </Grid>
                        <Border IsVisible="{Binding MassPanel.HasWarning}" BorderBrush="{DynamicResource AppBrushWarningBorder}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{DynamicResource AppBrushWarningBackground}">
                            <TextBlock Foreground="{DynamicResource AppBrushWarningText}" TextWrapping="Wrap" Text="{Binding MassPanel.WarningText}" LineHeight="18"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Column="2"
                  IsVisible="{Binding IsIndexDemultiplexMode}"
                  Background="{DynamicResource AppBrushBackground1}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24" Spacing="14" MaxWidth="750" MinWidth="750" HorizontalAlignment="Center">
                        <StackPanel Margin="0 12" Spacing="8">
                            <TextBlock Foreground="{DynamicResource AppBrushText2}" FontWeight="Bold" Text="Index Demultiplex" />
                            <TextBlock Foreground="{DynamicResource SemiColorText1}" TextWrapping="Wrap" LineHeight="18"
                                       Text="Select index channels, review the automatically fitted raw-signal cutoffs, choose the desired positive/negative subsets, and split copies into a separate grouping." />
                        </StackPanel>

                        <Grid ColumnDefinitions="340,*" ColumnSpacing="12">
                            <Grid RowDefinitions="Auto,*" RowSpacing="8">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                        <ComboBox Classes="Small" PlaceholderText="(No channel)"
                                                  ItemsSource="{Binding DemultiplexPanel.AvailableChannels}"
                                                  SelectedItem="{Binding DemultiplexPanel.SelectedAvailableChannel, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" /></DataTemplate></ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Button Grid.Column="1" Classes="Small" Command="{Binding DemultiplexPanel.AddChannelCommand}" ToolTip.Tip="Add index channel">
                                            <shared:ThemeIcon Width="16" Height="16" Icon="add-isotope.svg" />
                                        </Button>
                                </Grid>
                                <Border Grid.Row="1" Height="260" VerticalAlignment="Top"
                                        BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="6"
                                        Background="{DynamicResource AppBrushBackground3}" ClipToBounds="True">
                                    <DataGrid x:Name="demultiplex_channel_table"
                                              Classes="ControlSampleGrid" AutoGenerateColumns="False" CanUserResizeColumns="True"
                                              SelectionMode="Single" IsReadOnly="True"
                                              ItemsSource="{Binding DemultiplexPanel.Channels}"
                                              SelectedItem="{Binding DemultiplexPanel.SelectedChannel, Mode=TwoWay}"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Channel" Width="*" MinWidth="85">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Classes="IconRow" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                                            <shared:ThemeIcon Width="15" Height="15" Icon="channel.svg" />
                                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Min" Binding="{Binding MinimumText}" Width="52" MinWidth="48" />
                                            <DataGridTextColumn Header="Max" Binding="{Binding MaximumText}" Width="58" MinWidth="52" />
                                            <DataGridTextColumn Header="Threshold" Binding="{Binding ThresholdText}" Width="76" MinWidth="68" />
                                            <DataGridTemplateColumn Width="52" CanUserResize="False">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Classes="Small" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                Command="{Binding RemoveCommand}" CommandParameter="{Binding}" ToolTip.Tip="Remove index channel">
                                                            <shared:ThemeIcon Width="14" Height="14" Icon="close.svg" />
                                                        </Button>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Grid>

                            <Grid Grid.Column="1" RowDefinitions="32,260" RowSpacing="4">
                                <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="Sample" VerticalAlignment="Center" Foreground="{DynamicResource SemiColorText1}" />
                                    <ComboBox Grid.Column="1" Classes="Small" ItemsSource="{Binding DemultiplexPanel.Rows}"
                                              SelectedItem="{Binding DemultiplexPanel.SelectedRow, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding SampleName}" TextTrimming="CharacterEllipsis" /></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Grid.Column="2" Text="Channel" VerticalAlignment="Center" Foreground="{DynamicResource SemiColorText1}" />
                                    <ComboBox Grid.Column="3" Classes="Small" ItemsSource="{Binding DemultiplexPanel.Channels}"
                                              SelectedItem="{Binding DemultiplexPanel.SelectedChannel, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" /></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                                <controls:HistogramView Grid.Row="1"
                                                        Series="{Binding DemultiplexPanel.HistogramSeries}"
                                                        Curves="{Binding DemultiplexPanel.HistogramCurves}"
                                                        Models="{Binding DemultiplexPanel.HistogramModels}"
                                                        Annotations="{Binding DemultiplexPanel.HistogramAnnotations}"
                                                        AnnotationCommittedCommand="{Binding DemultiplexPanel.AnnotationCommittedCommand}"
                                                        Minimum="{Binding DemultiplexPanel.HistogramMinimum}"
                                                        Maximum="{Binding DemultiplexPanel.HistogramMaximum}"
                                                        AxisScale="{Binding DemultiplexPanel.HistogramAxisScale}"
                                                        ArcsinhCofactor="5"
                                                        XTitle="{Binding DemultiplexPanel.HistogramXTitle}"
                                                        YTitle="Normalized frequency / yield"
                                                        YMinimum="0" YMaximum="1"
                                                        Margin="0 -20 0 20"/>
                            </Grid>
                        </Grid>

                        <TextBlock Foreground="{DynamicResource SemiColorText1}" Text="Drag regular, fully stained samples from this grouping into the sample table" />
                        <Border x:Name="demultiplex_sample_drop_target" Height="250"
                                BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource AppBrushBackground3}" ClipToBounds="True">
                            <controls:DemultiplexSampleDataGrid x:Name="demultiplex_sample_table" Classes="ControlSampleGrid"
                                                                   SelectedItem="{Binding DemultiplexPanel.SelectedRow, Mode=TwoWay}"
                                                                   ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                   ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </Border>

                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Foreground="{DynamicResource SemiColorText1}" Text="Subsets" VerticalAlignment="Center" />
                            <CheckBox Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      Content="Show presumed index only"
                                      IsChecked="{Binding DemultiplexPanel.ShowPresumedIndexOnly, Mode=TwoWay}" />
                        </Grid>
                        <Border Height="300" BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource AppBrushBackground3}" ClipToBounds="True">
                            <controls:DemultiplexSubsetDataGrid x:Name="demultiplex_subset_table" Classes="ControlSampleGrid"
                                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                  ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </Border>

                        <Grid ColumnDefinitions="Auto,240,*,Auto" ColumnSpacing="8" IsVisible="{Binding DemultiplexPanel.HasRows}">
                            <TextBlock Text="Output grouping" Foreground="{DynamicResource SemiColorText2}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" Classes="Small" ItemsSource="{Binding DemultiplexPanel.OutputGroupChoices}"
                                      SelectedItem="{Binding DemultiplexPanel.SelectedOutputGroupChoice, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <shared:ThemeIcon Width="15" Height="15" Icon="group.svg" />
                                            <TextBlock Margin="0 0 8 0" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Column="3" Classes="Small" Content="Split" Command="{Binding DemultiplexPanel.ApplyCommand}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12" IsVisible="{Binding DemultiplexPanel.IsApplying}">
                            <ProgressBar Minimum="0" Maximum="100" Height="8" VerticalAlignment="Center" Value="{Binding DemultiplexPanel.ApplyProgress}" />
                            <TextBlock Grid.Column="1" MinWidth="250" TextAlignment="Right" Foreground="{DynamicResource SemiColorText1}" Text="{Binding DemultiplexPanel.ApplyProgressText}" />
                            <Button Grid.Column="2" Classes="Small" Content="Cancel" Command="{Binding DemultiplexPanel.CancelApplyCommand}" />
                        </Grid>
                        <Border IsVisible="{Binding DemultiplexPanel.HasWarning}" BorderBrush="{DynamicResource AppBrushWarningBorder}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{DynamicResource AppBrushWarningBackground}">
                            <TextBlock Foreground="{DynamicResource AppBrushWarningText}" TextWrapping="Wrap" Text="{Binding DemultiplexPanel.WarningText}" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Column="2"
                  IsVisible="{Binding IsPlatformMode}"
                  Background="{DynamicResource AppBrushBackground1}">
                <ContentControl Content="{Binding SelectedPlatformEditor}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="{x:Type platforms:IntegrationPlatformEditorViewModel}">
                            <controls:IntegrationPlatformView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type platforms:CellCyclePlatformEditorViewModel}">
                            <controls:CellCyclePlatformView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type platforms:ProliferationPlatformEditorViewModel}">
                            <controls:ProliferationPlatformView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type platforms:IntensityComparisonPlatformEditorViewModel}">
                            <controls:IntensityComparisonPlatformView />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Grid>

            <Grid Grid.Column="2"
                  IsVisible="{Binding IsWorkspaceMetadataMode}"
                  Background="{DynamicResource AppBrushBackground1}">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24"
                                Spacing="14"
                                MaxWidth="650"
                                MinWidth="650"
                                HorizontalAlignment="Center">
                        <StackPanel Margin="0 12 0 0">
                            <TextBlock Foreground="{DynamicResource SemiColorText1}" Text="Workspace sample metadata" />
                        </StackPanel>

                        <WrapPanel Margin="0,0,0,2">
                            <Button Classes="Small" Margin="0,0,8,0" Command="{Binding AddStringMetadataColumnCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <shared:ThemeIcon Width="16" Height="16" Icon="table-edit.svg" />
                                    <TextBlock Text="String column" />
                                </StackPanel>
                            </Button>
                            <Button Classes="Small" Margin="0,0,8,0" Command="{Binding AddIntegerMetadataColumnCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <shared:ThemeIcon Width="16" Height="16" Icon="table-edit.svg" />
                                    <TextBlock Text="Integer column" />
                                </StackPanel>
                            </Button>
                            <Button Classes="Small" Margin="0,0,8,0" Command="{Binding AddFloatMetadataColumnCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <shared:ThemeIcon Width="16" Height="16" Icon="table-edit.svg" />
                                    <TextBlock Text="Floating point column" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <Border Height="430"
                                BorderBrush="{DynamicResource AppBrushBorder3}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Background="{DynamicResource AppBrushBackground3}"
                                Padding="8"
                                ClipToBounds="True">
                            <DataGrid x:Name="workspace_metadata_grid"
                                      AutoGenerateColumns="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="True"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      Background="{DynamicResource AppBrushBackground3}"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      ItemsSource="{Binding WorkspaceMetadataTableView}" />
                        </Border>

                        <Button Classes="Small" HorizontalAlignment="Left" Command="{Binding ApplyWorkspaceMetadataCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <shared:ThemeIcon Width="16" Height="16" Icon="ok.svg" />
                                <TextBlock Text="Apply metadata" />
                            </StackPanel>
                        </Button>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{DynamicResource SemiColorText1}"
                                   Text="Experiment overview" />

                        <StackPanel Spacing="6">
                            <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Purpose and hypothesis" />
                            <TextBox Height="112"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"
                                     TextWrapping="Wrap"
                                     Padding="4 8" LineHeight="19"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     Text="{Binding Workspace.PurposeAndHypothesis, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Experiment setup" />
                            <TextBox Height="112"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"
                                     TextWrapping="Wrap"
                                     Padding="4 8" LineHeight="19"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     Text="{Binding Workspace.ExperimentSetup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Conclusions" />
                            <TextBox Height="112"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"
                                     TextWrapping="Wrap"
                                     Padding="4 8" LineHeight="19"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     Text="{Binding Workspace.Conclusions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,24" Spacing="6">
                            <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Quality control" />
                            <TextBox Height="112"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"
                                     TextWrapping="Wrap"
                                     Padding="4 8" LineHeight="19"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     Text="{Binding Workspace.QualityControl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Column="2"
                  IsVisible="{Binding IsGroupMetadataMode}"
                  Background="{DynamicResource AppBrushBackground1}">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24"
                                Spacing="14"
                                MaxWidth="650"
                                MinWidth="650"
                                HorizontalAlignment="Center">
                        <StackPanel Margin="0 12 0 0">
                            <TextBlock Foreground="{DynamicResource SemiColorText1}" Text="Grouping channel metadata" />
                        </StackPanel>

                        <Border Height="510"
                                BorderBrush="{DynamicResource AppBrushBorder3}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Background="{DynamicResource AppBrushBackground3}"
                                Padding="8"
                                ClipToBounds="True">
                            <DataGrid AutoGenerateColumns="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      Background="{DynamicResource AppBrushBackground3}"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      ItemsSource="{Binding ChannelRows}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name"
                                                        Width="*"
                                                        Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    <DataGridTextColumn Header="Label"
                                                        Width="*"
                                                        FontWeight="Bold"
                                                        Binding="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn Header="Maximum"
                                                        Width="120"
                                                        IsReadOnly="True"
                                                        Binding="{Binding MaximumDisplay}" />
                                    <DataGridTemplateColumn Header=""
                                                            Width="42"
                                                            IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Classes="Quiet ChannelIconButton"
                                                        Command="{Binding RemoveCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding CanRemove}"
                                                        ToolTip.Tip="{Binding RemoveTooltip}">
                                                    <shared:ThemeIcon Width="15"
                                                           Height="15" Icon="delete.svg" />
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <controls:PythonScriptEditorView Grid.Column="2"
                                             IsVisible="{Binding IsPythonScriptEditorMode}" />
        </Grid>
    </DockPanel>
</Window>
