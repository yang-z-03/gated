<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:gated.Controls"
             xmlns:platforms="clr-namespace:gated.ViewModels.Platforms" xmlns:shared="using:gated.Shared"
             x:Class="gated.Controls.IntegrationPlatformView"
             x:DataType="platforms:IntegrationPlatformEditorViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24" Spacing="14" MaxWidth="650" Width="650" HorizontalAlignment="Center">
      <TextBlock Foreground="{DynamicResource SemiColorText1}" Text="{Binding KindName}" />
      <TextBox FontSize="20" Padding="6" FontWeight="Light" Text="{Binding Platform.Name}" IsEnabled="{Binding IsEditable}" />
      <Border IsVisible="{Binding HasWarning}" BorderBrush="{DynamicResource AppBrushWarningBorder}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{DynamicResource AppBrushWarningBackground}">
        <TextBlock Foreground="{DynamicResource AppBrushWarningText}" TextWrapping="Wrap" Text="{Binding Platform.WarningText}" />
      </Border>
      <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Select populations and channels" />
      <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
        <Border Height="300" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource AppBrushBackground3}" Padding="8" ClipToBounds="True">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <controls:IntegrationJobPopulationTreeView Nodes="{Binding Platform.Populations}"
                                                       SelectionChangedCommand="{Binding SelectionChangedCommand}"
                                                       IsReadOnly="{Binding IsSelectionReadOnly}" />
          </ScrollViewer>
        </Border>
        <Border Grid.Column="1" Height="300" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource AppBrushBackground3}" Padding="8" ClipToBounds="True">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <controls:IntegrationJobFeatureListView Items="{Binding Platform.Features}"
                                                    SelectionChangedCommand="{Binding FeatureSelectionChangedCommand}"
                                                    IsReadOnly="{Binding IsSelectionReadOnly}" />
          </ScrollViewer>
        </Border>
      </Grid>
      <StackPanel Spacing="8">
        <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Batch metadata column" />
        <ComboBox Classes="Small" Width="260" IsEnabled="{Binding IsEditable}" ItemsSource="{Binding BatchColumnChoices}" SelectedItem="{Binding SelectedBatchColumnName}" />
      </StackPanel>
      <Expander Header="Normalization and integration options" IsExpanded="True" IsEnabled="{Binding IsEditable}">
        <StackPanel Margin="0,8,0,12" Spacing="8">
          <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
            <StackPanel><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Logicle T" Margin="0 0 0 8"/><TextBox Text="{Binding LogicleT, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <StackPanel Grid.Column="1"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Logicle W" Margin="0 0 0 8"/><TextBox Text="{Binding LogicleW, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <StackPanel Grid.Column="2"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Logicle M" Margin="0 0 0 8"/><TextBox Text="{Binding LogicleM, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <StackPanel Grid.Column="3"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Logicle A" Margin="0 0 0 8"/><TextBox Text="{Binding LogicleA, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
          </Grid>
          <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
            <StackPanel><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Quantiles" Margin="0 0 0 8"/><NumericUpDown Classes="Small" Minimum="3" Maximum="1000" Value="{Binding CytoNormQuantileCount}" /></StackPanel>
            <StackPanel Grid.Column="1"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Minimum cells" Margin="0 0 0 8"/><NumericUpDown Classes="Small" Minimum="1" Maximum="1000000" Value="{Binding CytoNormMinimumCellsPerCluster}" /></StackPanel>
            <StackPanel Grid.Column="2"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Goal" Margin="0 0 0 8"/><ComboBox Classes="Small" ItemsSource="{Binding CytoNormGoalChoices}" SelectedItem="{Binding SelectedCytoNormGoalChoice}"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayLabel}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox></StackPanel>
          </Grid>
        </StackPanel>
      </Expander>
      <ProgressBar Height="5" Minimum="0" Maximum="1" Value="{Binding Platform.ProgressFraction}" IsVisible="{Binding Platform.IsRunning}" />
      <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Platform.ProgressText}" IsVisible="{Binding Platform.IsRunning}" />
      <Expander Header="Integration histogram preview" IsVisible="{Binding HasIntegrationHistogram}" IsExpanded="True">
        <StackPanel Margin="0,10,0,14" Spacing="0">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" HorizontalAlignment="Center" Width="390">
            <Button Classes="Small" Width="30" Command="{Binding PreviousHistogramChannelCommand}">
              <shared:ThemeIcon Width="16" Height="16" Icon="left.svg" />
            </Button>
            <ComboBox Grid.Column="1"
                      Classes="Small"
                      HorizontalAlignment="Stretch"
                      ItemsSource="{Binding IntegrationHistogramChannelChoices}"
                      SelectedItem="{Binding SelectedIntegrationHistogramChannel}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                    <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="2" Classes="Small" Width="30" Command="{Binding NextHistogramChannelCommand}">
              <shared:ThemeIcon Width="16" Height="16" Icon="right.svg" />
            </Button>
          </Grid>
          <controls:HistogramView Height="230" Margin="0 -5 0 5"
                                  Series="{Binding IntegrationHistogramSeries}"
                                  AxisScale="{Binding IntegrationHistogramAxisScale}"
                                  LogicleTopOfScale="{Binding IntegrationHistogramLogicleT}"
                                  LogicleLinearizationWidth="{Binding IntegrationHistogramLogicleW}"
                                  LogicleDecades="{Binding IntegrationHistogramLogicleM}"
                                  LogicleNegativeDecades="{Binding IntegrationHistogramLogicleA}"
                                  BinSmoothing="{Binding IntegrationHistogramSmoothing}"
                                  YMaximumFactor="1.1"
                                  IsGatingEnabled="False" />
          <CheckBox HorizontalAlignment="Center" IsChecked="{Binding ShowNormalizedHistogram}" Margin="0 25 0 0"
                    IsEnabled="{Binding CanShowNormalizedHistogram}" Content="Show normalized data post CytoNorm integration" />
        </StackPanel>
      </Expander>
      <Grid Margin="0 4 0 24" ColumnDefinitions="Auto,*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Classes="Small" Command="{Binding RunCommand}"><StackPanel Orientation="Horizontal" Spacing="6"><shared:ThemeIcon Width="16" Height="16" Icon="run.svg" /><TextBlock Text="{Binding RunCaption}" /></StackPanel></Button>
          <Button Classes="Small" Command="{Binding RunLeidenCommand}"><StackPanel Orientation="Horizontal" Spacing="6"><shared:ThemeIcon Width="16" Height="16" Icon="run.svg" /><TextBlock Text="Leiden" /></StackPanel></Button>
          <Button Classes="Small" Command="{Binding RunUmapCommand}"><StackPanel Orientation="Horizontal" Spacing="6"><shared:ThemeIcon Width="16" Height="16" Icon="run.svg" /><TextBlock Text="UMAP" /></StackPanel></Button>
        </StackPanel>
        <Button Grid.Column="2" Classes="Small Danger" Command="{Binding CancelCommand}"><StackPanel Orientation="Horizontal" Spacing="6"><shared:ThemeIcon Width="16" Height="16" Icon="stop.svg" /><TextBlock Text="Stop" /></StackPanel></Button>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
