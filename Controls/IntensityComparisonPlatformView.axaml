<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:gated.Controls"
             xmlns:platforms="clr-namespace:gated.ViewModels.Platforms" xmlns:shared="using:gated.Shared"
             x:Class="gated.Controls.IntensityComparisonPlatformView"
             x:DataType="platforms:IntensityComparisonPlatformEditorViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24" Spacing="14" MaxWidth="750" Width="750" HorizontalAlignment="Center">
      <StackPanel Margin="0,12" Spacing="8">
        <TextBlock Foreground="{DynamicResource AppBrushText2}" FontWeight="Bold" Text="{Binding KindName}" />
        <TextBlock Foreground="{DynamicResource SemiColorText1}" TextWrapping="Wrap" LineHeight="18" Text="{Binding KindDescription}" />
      </StackPanel>
      <Border IsVisible="{Binding HasWarning}" BorderBrush="{DynamicResource AppBrushWarningBorder}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{DynamicResource AppBrushWarningBackground}"><TextBlock Foreground="{DynamicResource AppBrushWarningText}" TextWrapping="Wrap" Text="{Binding Platform.WarningText}" /></Border>
      <Border Height="230" ClipToBounds="True">
        <controls:HistogramView Curves="{Binding PlatformHistogramCurves}"
                                Minimum="{Binding PlatformHistogramMinimum}"
                                Maximum="{Binding PlatformHistogramMaximum}"
                                AxisScale="{Binding PlatformHistogramAxisScale}"
                                LogicleTopOfScale="{Binding LogicleT}"
                                LogicleLinearizationWidth="{Binding LogicleW}"
                                LogicleDecades="{Binding LogicleM}"
                                LogicleNegativeDecades="{Binding LogicleA}"
                                ArcsinhCofactor="{Binding UnivariateArcsinhA}"
                                YMaximum="{Binding PlatformHistogramYMaximum}"
                                XTitle="{Binding PlatformHistogramXTitle}"
                                YTitle="{Binding PlatformHistogramYTitle}"
                                IsGatingEnabled="False" />
      </Border>
      <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Populations" />
      <Border Height="210" BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource AppBrushBackground3}" ClipToBounds="True">
        <controls:PlatformPopulationGrid ShowPopulationColors="True" />
      </Border>
      <Grid ColumnDefinitions="*,*" ColumnSpacing="40">
        <Expander Header="Transformation" IsExpanded="True">
          <StackPanel Margin="0,8,0,12" Spacing="10">
            <StackPanel Spacing="6">
              <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Compare channel" />
              <ComboBox Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" ItemsSource="{Binding ChannelChoices}" SelectedItem="{Binding SelectedChannel}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                      <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                    </StackPanel>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
            <StackPanel Spacing="6">
              <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Desired transformation" />
              <ComboBox Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" ItemsSource="{Binding IntensityTransformationChoices}" SelectedItem="{Binding SelectedIntensityTransformationChoice}">
                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayLabel}" /></DataTemplate></ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
            <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8" HorizontalAlignment="Left" IsVisible="{Binding IsLogicleTransformation}">
              <StackPanel Spacing="6"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Top of scale (T)" /><TextBox Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" Text="{Binding LogicleT, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Grid.Column="1" Spacing="6"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Linearization width (W)" /><TextBox Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" Text="{Binding LogicleW, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Grid.Row="1" Spacing="6"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Decades (M)" /><TextBox Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" Text="{Binding LogicleM, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Negative decades (A)" /><TextBox Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" Text="{Binding LogicleA, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            </Grid>
            <StackPanel Spacing="6" IsVisible="{Binding IsArcsinhTransformation}">
              <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Arcsinh cofactor (a)" />
              <NumericUpDown Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" Minimum="0.000001" Maximum="1000000" Increment="1" Value="{Binding UnivariateArcsinhA}" />
            </StackPanel>
          </StackPanel>
        </Expander>
        <StackPanel Grid.Column="1" Spacing="10">
          <Expander Header="Distribution fitting options" IsExpanded="True">
            <StackPanel Margin="0,8,0,12" Spacing="10">
              <CheckBox Content="Use data smoothing" IsChecked="{Binding SmoothBeforeFit}" />
              <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="12" HorizontalAlignment="Left">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Smoothing window size" />
                  <NumericUpDown Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" Minimum="0" Maximum="50" Value="{Binding SmoothingHalfWindow}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="6">
                  <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Distribution binning" />
                  <NumericUpDown Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" Minimum="16" Maximum="1000" Value="{Binding IntensityDistributionBinning}" />
                </StackPanel>
              </Grid>
            </StackPanel>
          </Expander>
          <Expander Header="Statistical test" IsExpanded="True">
            <StackPanel Margin="0,8,0,12" Spacing="6">
              <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Reference population" />
              <ComboBox Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" ItemsSource="{Binding DisplayChoices}" SelectedItem="{Binding IntensityReferenceSample}" />
            </StackPanel>
          </Expander>
        </StackPanel>
      </Grid>
      <StackPanel Spacing="8" IsVisible="{Binding HasIntensityComparisonResults}">
        <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Model results" />
        <Border Height="230" BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource AppBrushBackground3}" ClipToBounds="True">
          <DataGrid Classes="ControlSampleGrid" AutoGenerateColumns="False" ItemsSource="{Binding IntensityComparisonResultRows}"
                    GridLinesVisibility="Horizontal" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Sample" Width="Auto" Binding="{Binding Sample, Mode=TwoWay}" />
              <DataGridTextColumn Header="Population" Width="Auto" Binding="{Binding Population, Mode=TwoWay}" />
              <DataGridTextColumn Header="Events" Width="Auto" Binding="{Binding Events, Mode=TwoWay}" />
              <DataGridTextColumn Header="Mean" Width="Auto" Binding="{Binding Mean, Mode=TwoWay}" />
              <DataGridTextColumn Header="Median" Width="Auto" Binding="{Binding Median, Mode=TwoWay}" />
              <DataGridTextColumn Header="Geometric mean" Width="Auto" Binding="{Binding GeometricMean, Mode=TwoWay}" />
              <DataGridTextColumn Header="Mean fold" Width="Auto" Binding="{Binding MeanFold, Mode=TwoWay}" />
              <DataGridTextColumn Header="Median fold" Width="Auto" Binding="{Binding MedianFold, Mode=TwoWay}" />
              <DataGridTextColumn Header="Geomean fold" Width="Auto" Binding="{Binding GeomeanFold, Mode=TwoWay}" />
              <DataGridTextColumn Header="Chi-square p" Width="Auto" Binding="{Binding ChiSquareP, Mode=TwoWay}" />
              <DataGridTextColumn Header="Normality p" Width="Auto" Binding="{Binding NormalityP, Mode=TwoWay}" />
              <DataGridTextColumn Header="Z-test p" Width="Auto" Binding="{Binding ZTestP, Mode=TwoWay}" />
              <DataGridTextColumn Header="Mann-Whitney p" Width="Auto" Binding="{Binding MannWhitneyP, Mode=TwoWay}" />
              <DataGridTextColumn Header="KS p" Width="Auto" Binding="{Binding KsP, Mode=TwoWay}" />
            </DataGrid.Columns>
          </DataGrid>
        </Border>
      </StackPanel>
      <ProgressBar Height="5" Minimum="0" Maximum="1" Value="{Binding Platform.ProgressFraction}" IsVisible="{Binding Platform.IsRunning}" />
      <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Platform.ProgressText}" IsVisible="{Binding Platform.IsRunning}" />
      <Grid Margin="0 4 0 18" ColumnDefinitions="Auto,*,Auto"><Button Classes="Small" Command="{Binding RunCommand}"><StackPanel Orientation="Horizontal" Spacing="6"><shared:ThemeIcon Width="16" Height="16" Icon="run.svg" /><TextBlock Text="{Binding RunCaption}" /></StackPanel></Button><Button Grid.Column="2" Classes="Small Danger" Command="{Binding CancelCommand}"><StackPanel Orientation="Horizontal" Spacing="6"><shared:ThemeIcon Width="16" Height="16" Icon="stop.svg" /><TextBlock Text="Stop" /></StackPanel></Button></Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
