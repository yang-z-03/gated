<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="gated.SplitSampleWindow"
        x:CompileBindings="False"
        Width="760"
        Height="560"
        MinWidth="640"
        MinHeight="460"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Title="Split sample"
        Background="{DynamicResource AppBrushBackground4}">
    <Grid Margin="18" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
        <StackPanel Spacing="5">
            <TextBlock Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="Split a sample by time" />
            <TextBlock Foreground="{DynamicResource SemiColorText2}" TextWrapping="Wrap"
                       Text="Click the time strip to add split points. Each partition becomes a new sample in the same grouping." />
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource AppBrushBackground3}" Padding="10">
            <ContentControl x:Name="partitionHost" Height="74" />
        </Border>

        <Border Grid.Row="2" BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource AppBrushBackground3}" Padding="8">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="fragmentPanel" Spacing="8" />
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Row="3">
            <TextBlock x:Name="statusText" DockPanel.Dock="Left" Foreground="{DynamicResource AppBrushErrorText}" VerticalAlignment="Center" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button x:Name="clearButton" Classes="Small" Content="Clear splits" MinWidth="92" />
                <Button x:Name="cancelButton" Classes="Small" Content="Cancel" MinWidth="84" />
                <Button x:Name="okButton" Classes="Small" Content="Create" MinWidth="84" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
