            <RemoveFolder Directory="INSTALLFOLDER" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\Xornent\Gated\gated-core" Name="installed" Type="integer" Value="1" KeyPath="yes" />
            <RegistryValue Root="HKCU" Key="Software\Xornent\Gated\gated-core" Name="python" Type="string" Value="[INSTALLFOLDER]python" />

            <ProgId Id="gated-workspace" Description="Gated Workspace" Icon="wspicon">
                <Extension Id="gated" ContentType="application/binary">
                    <Verb Id="open" Command="open" TargetFile="exec"
