<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ───────────────────── CHECK BOX ───────────────────── -->

  <Style Selector="CheckBox">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Foreground" Value="#d0d0d8"/>
    <Setter Property="Padding" Value="6,0,0,0"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="MinHeight" Value="0"/>
    <Setter Property="Height" Value="26"/>
  </Style>

  <Style Selector="CheckBox /template/ Border#NormalRectangle">
    <Setter Property="BorderBrush" Value="#3a3a4a"/>
    <Setter Property="Background" Value="#141418"/>
    <Setter Property="CornerRadius" Value="2"/>
    <Setter Property="Width" Value="14"/>
    <Setter Property="Height" Value="14"/>
  </Style>

  <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
    <Setter Property="Background" Value="#3d5a9a"/>
    <Setter Property="BorderBrush" Value="#5b80c4"/>
  </Style>

  <!-- ───────────────────── SLIDER ───────────────────── -->

  <Style Selector="Slider">
    <Setter Property="MinHeight" Value="0"/>
    <Setter Property="Height" Value="20"/>
    <Setter Property="Foreground" Value="#5b80c4"/>
    <Setter Property="Background" Value="#2c2c3a"/>
  </Style>

  <Style Selector="Slider /template/ Track > Thumb">
    <Setter Property="Width" Value="10"/>
    <Setter Property="Height" Value="16"/>
    <Setter Property="CornerRadius" Value="2"/>
    <Setter Property="Background" Value="#8090b8"/>
    <Setter Property="BorderBrush" Value="#5b80c4"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <!-- ───────────────────── NUMERIC UP-DOWN ───────────────────── -->

  <Style Selector="NumericUpDown">
    <Setter Property="Height" Value="26"/>
    <Setter Property="MinHeight" Value="0"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="CornerRadius" Value="3"/>
    <Setter Property="Background" Value="#141418"/>
    <Setter Property="Foreground" Value="#d0d0d8"/>
    <Setter Property="BorderBrush" Value="#3a3a4a"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <Style Selector="NumericUpDown /template/ ButtonSpinner">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="6,0"/>
  </Style>

  <Style Selector="NumericUpDown /template/ TextBox">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Height" Value="24"/>
    <Setter Property="MinHeight" Value="0"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Padding" Value="4,0"/>
  </Style>

  <!-- ───────────────────── LABEL / TEXTBLOCK ───────────────────── -->

  <Style Selector="TextBlock">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Foreground" Value="#d0d0d8"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <Style Selector="TextBlock.dim">
    <Setter Property="Foreground" Value="#888896"/>
  </Style>

  <Style Selector="TextBlock.accent">
    <Setter Property="Foreground" Value="#5b80c4"/>
  </Style>

  <Style Selector="TextBlock.section-header">
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="Foreground" Value="#888896"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Margin" Value="0,6,0,2"/>
  </Style>

  <!-- ───────────────────── SCROLL BAR ───────────────────── -->

  <Style Selector="ScrollBar">
    <Setter Property="Background" Value="Transparent"/>
  </Style>

  <Style Selector="ScrollBar[Orientation=Vertical]">
    <Setter Property="Width" Value="8"/>
  </Style>

  <Style Selector="ScrollBar[Orientation=Horizontal]">
    <Setter Property="Height" Value="8"/>
  </Style>

  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="Background" Value="#3a3a4a"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Margin" Value="1"/>
  </Style>

  <Style Selector="ScrollBar /template/ Thumb:pointerover">
    <Setter Property="Background" Value="#4a4a60"/>
  </Style>

  <!-- ───────────────────── SEPARATOR ───────────────────── -->

  <Style Selector="Separator">
    <Setter Property="Background" Value="#3a3a4a"/>
  </Style>

  <!-- ───────────────────── EXPANDER ───────────────────── -->

  <Style Selector="Expander">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="#3a3a4a"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Foreground" Value="#d0d0d8"/>
    <Setter Property="Padding" Value="6,4"/>
  </Style>

  <Style Selector="Expander /template/ ToggleButton">
    <Setter Property="Height" Value="26"/>
    <Setter Property="MinHeight" Value="0"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="#d0d0d8"/>
    <Setter Property="Padding" Value="6,0"/>
    <Setter Property="FontSize" Value="11"/>
  </Style>

</Styles>
