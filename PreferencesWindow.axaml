<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:shared="using:gated.Shared"
        x:Class="gated.PreferencesWindow"
        x:CompileBindings="False"
        Width="850"
        Height="575"
        MinWidth="820"
        MinHeight="560"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Title="Preferences"
        Background="{DynamicResource AppBrushWindowBackground}">

    <Window.Styles>
        <Style Selector="ListBox ListBoxItem">
            <Setter Property="Margin" Value="0,2" />
        </Style>
    </Window.Styles>

    <Grid Margin="18" ColumnDefinitions="170,*" RowDefinitions="*,Auto" ColumnSpacing="24" RowSpacing="18">
        <Border BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource AppBrushBackground3}" Padding="8">
            <ListBox x:Name="preferencePageList">
                <ListBox.Resources>
                    <Thickness x:Key="ListBoxItemDefaultPadding">0</Thickness>
                    <CornerRadius x:Key="ListBoxItemCornerRadius">6</CornerRadius>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="4" Padding="8,3">
                            <TextBlock Foreground="{DynamicResource SemiColorText0}" Text="{Binding}" />
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Column="1">
            <Grid x:Name="cytometryPage" RowDefinitions="Auto,*" RowSpacing="10" IsVisible="False">

                <TextBlock Foreground="{DynamicResource SemiColorText0}" TextWrapping="Wrap" LineHeight="18"
                           Text="Define and modify channel default dimension setups for indicated cytometer platforms. Cytometer settings are automatically matched from FCS files experienced." />

                <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="10">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalAlignment="Bottom">
                    <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="6">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{DynamicResource SemiColorText2}"
                                   Text="Cytometer" />
                        <ComboBox x:Name="cytometerCombo"
                                  Grid.Column="1"
                                  Classes="Small"
                                  MinWidth="240">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="5" Orientation="Horizontal">
                                        <shared:ThemeIcon Width="16" Height="16" Icon="controls.svg" />
                                        <TextBlock Text="{Binding Name}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Bottom">
                        <Button x:Name="addCytometerButton" Classes="Small" Width="30" ToolTip.Tip="Add cytometer preset">
                            <shared:ThemeIcon Width="16" Height="16" Icon="add-file.svg" />
                        </Button>
                        <Button x:Name="resetButton" Classes="Small" Width="30" ToolTip.Tip="Reset cytometer presets">
                            <shared:ThemeIcon Width="16" Height="16" Icon="refresh.svg" />
                        </Button>
                        <Button x:Name="addChannelButton" Classes="Small" Width="30" ToolTip.Tip="Add channel preset">
                            <shared:ThemeIcon Width="16" Height="16" Icon="channel.svg" />
                        </Button>
                        <Button x:Name="removeChannelButton" Classes="Small" Width="30" ToolTip.Tip="Remove selected channel preset">
                            <shared:ThemeIcon Width="16" Height="16" Icon="delete.svg" />
                        </Button>
                    </StackPanel>
                    </Grid>
                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource AppBrushBorder3}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Background="{DynamicResource AppBrushBackground2}"
                            Padding="8"
                            ClipToBounds="True">
                        <DataGrid x:Name="channelGrid"
                                  AutoGenerateColumns="False"
                                  CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Channel" Binding="{Binding ChannelName}" Width="*" />
                                <DataGridTextColumn Header="Element" Binding="{Binding ElementSymbol}" Width="78" />
                                <DataGridTextColumn Header="Mass" Binding="{Binding MassNumber}" Width="68" />
                                <DataGridTemplateColumn Header="Kind" Width="125">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox Classes="Small" Margin="6 2 0 0"
                                                      ItemsSource="{Binding $parent[Window].Tag.KindChoices}"
                                                      SelectedItem="{Binding Kind}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Scale" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox Classes="Small" Margin="6 2 0 0"
                                                      ItemsSource="{Binding $parent[Window].Tag.ScaleChoices}"
                                                      SelectedItem="{Binding Scale}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Excitation" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox Classes="Small" Margin="6 2 0 0"
                                                      ItemsSource="{Binding $parent[Window].Tag.ExcitationChoices}"
                                                      SelectedItem="{Binding ExcitationLight}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Plot order" Binding="{Binding PlotOrder}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="elementBeadsPage" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10" IsVisible="False">
                <TextBlock Foreground="{DynamicResource SemiColorText0}" TextWrapping="Wrap" LineHeight="18"
                           Text="Define element bead isotope sets and manufacturer lot reference intensities used by mass normalization." />

                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <StackPanel Spacing="8" Orientation="Horizontal" HorizontalAlignment="Left">
                    <StackPanel Spacing="6">
                        <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Bead type" />
                        <ComboBox x:Name="beadTypeCombo" Classes="Small" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Bead lot" />
                        <ComboBox x:Name="beadLotCombo" Classes="Small" />
                    </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Bottom">
                        <Button x:Name="addBeadTypeButton" Classes="Small" Width="30" ToolTip.Tip="Add bead type">
                            <shared:ThemeIcon Width="16" Height="16" Icon="add-type.svg" />
                        </Button>
                        <Button x:Name="addLotButton" Classes="Small" Width="30" ToolTip.Tip="Add lot definition">
                            <shared:ThemeIcon Width="16" Height="16" Icon="add-lot.svg" />
                        </Button>
                        <Button x:Name="addIsotopeButton" Classes="Small" Width="30" ToolTip.Tip="Add isotope definition">
                            <shared:ThemeIcon Width="16" Height="16" Icon="add-isotope.svg" />
                        </Button>
                        <Button x:Name="removeLotButton" Classes="Small" Width="30" ToolTip.Tip="Remove selected lot">
                            <shared:ThemeIcon Width="16" Height="16" Icon="delete.svg" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8">
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource SemiColorText2}" Text="Type name" />
                    <TextBox x:Name="beadTypeNameBox" Grid.Column="1" Classes="Small" />
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{DynamicResource SemiColorText2}" Text="Lot name" />
                    <TextBox x:Name="beadLotNameBox" Grid.Column="3" Classes="Small" />
                </Grid>

                <Border Grid.Row="3" BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="6"
                        Background="{DynamicResource AppBrushBackground2}" Padding="8" ClipToBounds="True">
                    <DataGrid x:Name="beadReferenceGrid" AutoGenerateColumns="False" CanUserResizeColumns="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Channel" Binding="{Binding MassNumber}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Reference intensity" Binding="{Binding ReferenceIntensity}" Width="2*" />
                            <DataGridTemplateColumn Width="42" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Classes="Small" Width="30" HorizontalAlignment="Center"
                                                ToolTip.Tip="Remove isotope definition"
                                                Click="remove_isotope_from_row">
                                            <shared:ThemeIcon Width="16" Height="16" Icon="delete.svg" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <Grid x:Name="isotopesPage" RowDefinitions="Auto,Auto,*" RowSpacing="10" IsVisible="False">
                <TextBlock Foreground="{DynamicResource SemiColorText0}" TextWrapping="Wrap" LineHeight="18"
                           Text="Define elements and isotope masses that may cross-talk through isotopic impurity. Adjacent-mass and oxide interactions are inferred independently." />
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
                    <TextBlock Foreground="{DynamicResource SemiColorText2}" VerticalAlignment="Center"
                               Text="Element isotope definitions" />
                    <Button x:Name="addIsotopeElementButton" Grid.Column="1" Classes="Small" Width="30"
                            ToolTip.Tip="Add element definition">
                        <shared:ThemeIcon Width="16" Height="16" Icon="add-isotope.svg" />
                    </Button>
                </Grid>
                <Border Grid.Row="2" BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="6"
                        Background="{DynamicResource AppBrushBackground2}" Padding="8" ClipToBounds="True">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="isotopeElementList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="0,0,0,1" Padding="3,7">
                                        <Grid ColumnDefinitions="105,*,34" ColumnSpacing="8">
                                            <TextBox Classes="Small" Text="{Binding ElementSymbol, Mode=TwoWay}" Watermark="Element" />
                                            <StackPanel Grid.Column="1" Spacing="5">
                                                <ItemsControl ItemsSource="{Binding Tags}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border CornerRadius="5" Margin="0,0,5,4" Padding="7,2,2,2"
                                                                    Background="{DynamicResource AppBrushBackground4}"
                                                                    BorderBrush="{DynamicResource AppBrushBorder2}" BorderThickness="1">
                                                                <StackPanel Orientation="Horizontal" Spacing="3">
                                                                    <TextBlock Text="{Binding Mass}" VerticalAlignment="Center" />
                                                                    <Button Classes="Quiet ChannelIconButton" Width="22" Height="22"
                                                                            ToolTip.Tip="Remove isotope mass"
                                                                            Click="remove_isotope_mass_from_tag">
                                                                        <shared:ThemeIcon Width="12" Height="12" Icon="cross.svg" />
                                                                    </Button>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <TextBox Classes="Small" Width="90" Watermark="Mass"
                                                             Text="{Binding PendingMass, Mode=TwoWay}" />
                                                    <Button Classes="Small" Width="30" ToolTip.Tip="Add isotope mass"
                                                            Click="add_isotope_mass_from_row">
                                                        <shared:ThemeIcon Width="14" Height="14" Icon="add-isotope.svg" />
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="2" Classes="Quiet ChannelIconButton" Width="30"
                                                    ToolTip.Tip="Remove element definition"
                                                    Click="remove_isotope_element_from_row">
                                                <shared:ThemeIcon Width="16" Height="16" Icon="delete.svg" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <StackPanel x:Name="appearancePage"
                        Spacing="18">
                <TextBlock Foreground="{DynamicResource SemiColorText0}" TextWrapping="Wrap" LineHeight="18"
                           Text="Global appearance of the application. Some settings requires restarting the application" />

                <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto" ColumnSpacing="18" RowSpacing="8">
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Foreground="{DynamicResource SemiColorText0}"
                               Text="Theme" />
                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="14">
                        <RadioButton x:Name="lightThemeRadio"
                                     GroupName="ApplicationTheme"
                                     Content="Light" />
                        <RadioButton x:Name="darkThemeRadio"
                                     GroupName="ApplicationTheme"
                                     Content="Dark" />
                    </StackPanel>
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Foreground="{DynamicResource SemiColorText2}"
                               TextWrapping="Wrap"
                               Text="Requires restart" />
                </Grid>
            </StackPanel>
        </Grid>

        <DockPanel Grid.Row="1" Grid.ColumnSpan="2">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button x:Name="cancelButton" Classes="Small" MinWidth="84">
                    Cancel
                </Button>
                <Button x:Name="saveButton" Classes="Small" MinWidth="84">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <shared:ThemeIcon Width="16" Height="16" Icon="save.svg" />
                        <TextBlock Text="Save" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
