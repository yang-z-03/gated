<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:gated.Controls"
        x:Class="gated.ConcatenateSamplesWindow"
        x:CompileBindings="False"
        Width="620"
        Height="620"
        MinWidth="620"
        MinHeight="520"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Title="Concatenate samples"
        Background="{DynamicResource AppBrushWindowBackground}">
    <Grid Margin="18" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
        <StackPanel Spacing="5">
            <TextBlock Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="Concatenate events into a new sample" />
            <TextBlock Foreground="{DynamicResource SemiColorText2}" TextWrapping="Wrap" LineHeight="18"
                       Text="Select sample roots for all events, or select populations to include only those gated events. The new sample is added to the same grouping." />
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="140,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
            <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Sample name" VerticalAlignment="Center" />
            <TextBox x:Name="sampleNameBox" Grid.Column="1" Classes="Small" />
            <TextBlock Grid.Row="1" Foreground="{DynamicResource SemiColorText2}" Text="Time axis" VerticalAlignment="Center" />
            <ComboBox x:Name="timeModeBox" Grid.Row="1" Grid.Column="1" Classes="Small" SelectedIndex="1">
                <ComboBoxItem Content="Direct concat" />
                <ComboBoxItem Content="Join time" />
            </ComboBox>
        </Grid>

        <Border Grid.Row="2" BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource AppBrushBackground3}" ClipToBounds="True">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Margin="8">
                <controls:IntegrationJobPopulationTreeView x:Name="populationTree" />
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Row="3">
            <TextBlock x:Name="statusText" DockPanel.Dock="Left" Foreground="{DynamicResource AppBrushErrorText}" VerticalAlignment="Center" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button x:Name="cancelButton" Classes="Small" Content="Cancel" MinWidth="84" />
                <Button x:Name="okButton" Classes="Small" Content="Create" MinWidth="84" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
