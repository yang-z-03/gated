                </Extension>
            </ProgId>
            <RegistryValue Root="HKCU" Key="Software\Classes\Applications\gated.exe" Type="string" Value="Gated Analyzer" />
            <RegistryValue Root="HKCU" Key="Software\Classes\Applications\gated.exe" Type="string" Name="FriendlyAppName" Value="Gated Analyzer" />
            <RegistryValue Root="HKCU" Key="Software\Classes\Applications\gated.exe\SupportedTypes\.gated" Type="string" Value="" />
