<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="gated.PreferencesWindow"
        x:CompileBindings="False"
        Width="1120"
        Height="560"
        MinWidth="720"
        MinHeight="460"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Title="Preferences"
        Background="#252525">

    <Window.Styles>
        <Style Selector="ListBox#cytometerList ListBoxItem">
            <Setter Property="Margin" Value="0,2" />
        </Style>
    </Window.Styles>

    <Grid Margin="18" ColumnDefinitions="220,*" RowDefinitions="*,Auto" ColumnSpacing="14" RowSpacing="12">
        <Border BorderBrush="#505050" BorderThickness="1" CornerRadius="6" Background="#1e1e1e" Padding="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Foreground="{DynamicResource SemiColorText2}" Margin="4,0,0,8" Text="Cytometers" />
                <ListBox x:Name="cytometerList">
                    <ListBox.Resources>
                        <Thickness x:Key="ListBoxItemDefaultPadding">0</Thickness>
                        <CornerRadius x:Key="ListBoxItemCornerRadius">6</CornerRadius>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="6" Padding="8,5">
                                <TextBlock Foreground="{DynamicResource SemiColorText0}" Text="{Binding Name}" />
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="*" RowSpacing="10">
            <DataGrid x:Name="channelGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Channel" Binding="{Binding ChannelName}" Width="*" />
                    <DataGridTemplateColumn Header="Kind" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox Classes="Small" Margin="6 2 0 0"
                                          ItemsSource="{Binding $parent[Window].Tag.KindChoices}"
                                          SelectedItem="{Binding Kind}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Scale" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox Classes="Small" Margin="6 2 0 0"
                                          ItemsSource="{Binding $parent[Window].Tag.ScaleChoices}"
                                          SelectedItem="{Binding Scale}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridCheckBoxColumn Header="Observed range" Binding="{Binding UseObservedRange}" Width="120" />
                    <DataGridCheckBoxColumn Header="Spectral" Binding="{Binding IsSpectral}" Width="80" />
                    <DataGridTemplateColumn Header="Excitation" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox Classes="Small" Margin="6 2 0 0"
                                          ItemsSource="{Binding $parent[Window].Tag.ExcitationChoices}"
                                          SelectedItem="{Binding ExcitationLight}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Plot order" Binding="{Binding PlotOrder}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <DockPanel Grid.Row="1" Grid.ColumnSpan="2">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
                <Button x:Name="addCytometerButton" Classes="Small" Content="Add cytometer" />
                <Button x:Name="resetButton" Classes="Small" Content="Reset defaults" />
                <Button x:Name="addChannelButton" Classes="Small" Content="Add channel" />
                <Button x:Name="removeChannelButton" Classes="Small" Content="Remove selected" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button x:Name="cancelButton" Classes="Small" Content="Cancel" MinWidth="84" />
                <Button x:Name="saveButton" Classes="Small" Content="Save" MinWidth="84" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
