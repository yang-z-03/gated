<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:gated.Controls"
        x:Class="gated.MainWindow"
        x:CompileBindings="False"
        Width="1500" Height="850"
        MinWidth="1100" MinHeight="700"
        Title="Gated"

        ExtendClientAreaChromeHints="Default"
        SystemDecorations="Full"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="0"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SemiColorBackground0}">
        
    <Window.Styles>
        <Style Selector="ToggleButton.PageModeSwitch">
            <Setter Property="Width" Value="164" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="PART_Track"
                            Width="164"
                            Height="28"
                            CornerRadius="7"
                            Background="#1A1B22"
                            BorderBrush="#4A4D58"
                            BorderThickness="1"
                            ClipToBounds="True">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.16" />
                                <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
                            </Transitions>
                        </Border.Transitions>
                        <Grid ColumnDefinitions="*,*">
                            <Border x:Name="PART_Thumb"
                                    Grid.ColumnSpan="2"
                                    Width="76"
                                    Height="20"
                                    Margin="3,3,0,3"
                                    HorizontalAlignment="Left"
                                    CornerRadius="5"
                                    Background="#ECEEF5"
                                    BoxShadow="0 1 5 0 #80000000">
                                <Border.Transitions>
                                    <Transitions>
                                        <ThicknessTransition Property="Margin" Duration="0:0:0.20" />
                                        <BrushTransition Property="Background" Duration="0:0:0.16" />
                                    </Transitions>
                                </Border.Transitions>
                            </Border>
                            <TextBlock x:Name="PART_AnalysisText"
                                       Grid.Column="0"
                                       Text="Analysis"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#20232C"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Transitions>
                                    <Transitions>
                                        <BrushTransition Property="Foreground" Duration="0:0:0.16" />
                                    </Transitions>
                                </TextBlock.Transitions>
                            </TextBlock>
                            <TextBlock x:Name="PART_LayoutText"
                                       Grid.Column="1"
                                       Text="Layout"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#B9BDCA"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Transitions>
                                    <Transitions>
                                        <BrushTransition Property="Foreground" Duration="0:0:0.16" />
                                    </Transitions>
                                </TextBlock.Transitions>
                            </TextBlock>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.PageModeSwitch:pointerover /template/ Border#PART_Track">
            <Setter Property="Background" Value="#20222B" />
            <Setter Property="BorderBrush" Value="#656A78" />
        </Style>
        <Style Selector="ToggleButton.PageModeSwitch:pointerover /template/ Border#PART_Thumb">
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>
        <Style Selector="ToggleButton.PageModeSwitch:checked /template/ Border#PART_Thumb">
            <Setter Property="Margin" Value="83,3,0,3" />
        </Style>
        <Style Selector="ToggleButton.PageModeSwitch:checked /template/ TextBlock#PART_AnalysisText">
            <Setter Property="Foreground" Value="#B9BDCA" />
        </Style>
        <Style Selector="ToggleButton.PageModeSwitch:checked /template/ TextBlock#PART_LayoutText">
            <Setter Property="Foreground" Value="#20232C" />
        </Style>
        <Style Selector="ToggleButton.PageModeSwitch:pressed /template/ Border#PART_Thumb">
            <Setter Property="Background" Value="#D8DBE5" />
        </Style>
        
        <Style Selector="RadioButton.GateToolButton">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.GateToolButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource SemiColorBackground2}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}" />
        </Style>
        <Style Selector="RadioButton.GateToolButton:checked">
            <Setter Property="Background" Value="#2D5FA8" />
            <Setter Property="BorderBrush" Value="#6EA8FE" />
        </Style>
        <Style Selector="RadioButton.GateToolButton:checked:pointerover">
            <Setter Property="Background" Value="#356DBD" />
            <Setter Property="BorderBrush" Value="#9DC4FF" />
        </Style>
        <Style Selector="RadioButton.GateToolButton:disabled">
            <Setter Property="Opacity" Value="0.32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="No" />
        </Style>
        <Style Selector="ComboBox.SampleSwitcher">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="ComboBox.SampleSwitcher:pointerover">
            <Setter Property="Background" Value="{DynamicResource SemiColorBackground2}" />
        </Style>
    </Window.Styles>

    <DockPanel x:Name="window">
        <Border x:Name="titleBar" DockPanel.Dock="Top" Background="#252530" BorderThickness="0,0,0,0" BorderBrush="#505050">
          <Grid Height="40">
            <Rectangle Fill="#252530" PointerPressed="title_bar_pressed"/>
            <DockPanel>
              <Border BorderBrush="#252530" BorderThickness="0 0 0 0"/>
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <ToggleButton Margin="5 6 8 6" x:Name="pageModeSwitch"
                              Classes="PageModeSwitch"
                              IsChecked="{Binding IsPageEditorMode, Mode=OneWay}"
                              Click="page_mode_switch_click" />
                <Button x:Name="minimizeButton" Width="30" Height="30" Margin="5 5 0 5" Click="window_minimize" Classes="Title">
                  <TextBlock IsHitTestVisible="False" FontFamily="{DynamicResource SemiFontFamilyIcon}" Text="&#xe1d8;" 
                             HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                </Button>
                <Button Width="30" Height="30" Margin="5 5 5 5" Click="window_close" Classes="Close">
                  <TextBlock IsHitTestVisible="False" FontFamily="{DynamicResource SemiFontFamilyIcon}" Text="&#xe10a;" 
                             HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                </Button>
              </StackPanel>
              <Grid>
                <StackPanel IsHitTestVisible="False" Margin="2 5 2 2" Orientation="Horizontal" 
                            HorizontalAlignment="Center" VerticalAlignment="Stretch">
                  <Image Width="16" Height="16" Source="avares://gated/Resources/gated16.png"/>
                  <Grid Width="10"/>
                  <TextBlock Text="Gated · Flow Cytometry Analyser" VerticalAlignment="Center"
                             FontWeight="Bold" Foreground="White" FontSize="13"/>
                </StackPanel>
              </Grid>
            </DockPanel>
          </Grid>
        </Border>

        <Menu x:Name="main_menu" DockPanel.Dock="Top" Background="#252530">
            <MenuItem Header="_File">
                <MenuItem Header="Open workspace ..." InputGesture="Ctrl + Shift + O" Click="open_workspace_menu_item_click" />
                <MenuItem Header="Open FCS ..." InputGesture="Ctrl + O" Click="open_fcs_menu_item_click" />
                <MenuItem Header="Save workspace ..." InputGesture="Ctrl + S" Click="save_workspace_menu_item_click" />
                <MenuItem Header="Rename workspace" Command="{Binding RenameWorkspaceCommand}" InputGesture="F2" />
                <MenuItem Header="Close workspace" Click="close_workspace_menu_item_click" />
                <Separator />
                <MenuItem x:Name="recent_items_menu" Header="Recent items" />
            </MenuItem>
            <MenuItem Header="_Samples">
                <MenuItem Header="Create group" Command="{Binding CreateGroupCommand}" InputGesture="Ctrl + G"/>
                <MenuItem Header="Rename group" Command="{Binding RenameGroupCommand}" InputGesture="F2"/>
                <MenuItem Header="Delete group" Command="{Binding DeleteSelectedCommand}" InputGesture="Delete"/>
                <Separator />
                <MenuItem Header="Append samples to groups" Click="open_fcs_menu_item_click" />
                <MenuItem Header="Delete selected samples" Command="{Binding DeleteSelectedCommand}" InputGesture="Delete"/>
                <MenuItem Header="Delete selected embedding" Command="{Binding DeleteSelectedCommand}" InputGesture="Delete"/>
                <MenuItem Header="Concatenate" Click="concatenate_samples_menu_item_click" />
                <MenuItem Header="Copy hierarchy view options to group" Command="{Binding CopyHierarchyViewOptionsToGroupCommand}" />
                <MenuItem Header="Select equivalent nodes" IsEnabled="False" />
                <MenuItem Header="Expand" Command="{Binding ExpandProjectTreeCommand}" InputGesture="Ctrl + E"/>
                <MenuItem Header="Collapse" Command="{Binding CollapseProjectTreeCommand}" />
                <MenuItem Header="Preferences ..." Click="preferences_menu_item_click" />
            </MenuItem>
            <MenuItem Header="_Plotting" IsEnabled="{Binding IsDefaultAnalysisMode}">
                <MenuItem Header="Density" ToggleType="Radio" IsChecked="{Binding IsDensityPlotMode, Mode=OneWay}" Click="density_menu_item_click" />
                <MenuItem Header="Dotplot" ToggleType="Radio" IsChecked="{Binding IsDotplotPlotMode, Mode=OneWay}" Click="dotplot_menu_item_click" />
                <MenuItem Header="Contour" ToggleType="Radio" IsChecked="{Binding IsContourPlotMode, Mode=OneWay}" Click="contour_menu_item_click" />
                <MenuItem Header="Zebra" ToggleType="Radio" IsChecked="{Binding IsZebraPlotMode, Mode=OneWay}" Click="zebra_menu_item_click" />
                <MenuItem Header="Histogram" ToggleType="Radio" IsChecked="{Binding IsHistogramPlotMode, Mode=OneWay}" Click="histogram_menu_item_click" />
                <Separator />
                <MenuItem Header="Show outlier points" ToggleType="CheckBox" IsChecked="{Binding ShowOutlierPoints, Mode=TwoWay}" />
                <MenuItem Header="Draw large dots" ToggleType="CheckBox" IsChecked="{Binding DrawLargeDots, Mode=TwoWay}" />
                <MenuItem Header="Show gridlines" ToggleType="CheckBox" IsChecked="{Binding ShowGridlines, Mode=TwoWay}" />
                <MenuItem Header="Show gate annotations" ToggleType="CheckBox" IsChecked="{Binding ShowGateAnnotations, Mode=TwoWay}" />
                <MenuItem Header="Show gate annotation names" ToggleType="CheckBox" IsChecked="{Binding ShowGateAnnotationNames, Mode=TwoWay}" />
                <Separator />
                <MenuItem x:Name="toggle_plot_properties_menu_item" Header="Show properties panel" ToggleType="CheckBox" IsChecked="True" InputGesture="Ctrl + R" Click="toggle_plot_properties_menu_item_click" />
                <Separator />
                <MenuItem x:Name="editor_x_channel_menu" Header="X selected channel" />
                <MenuItem x:Name="editor_y_channel_menu" Header="Y selected channel" />
                <MenuItem x:Name="editor_color_channel_menu" Header="Dot color" />
                <MenuItem Header="Coloring in log scale" ToggleType="CheckBox" IsChecked="{Binding DotColor.UseLogScale, Mode=TwoWay}" />
                <MenuItem Header="Dot color palette">
                    <MenuItem Header="Viridis" Click="viridis_color_menu_item_click" />
                    <MenuItem Header="Plasma" Click="plasma_color_menu_item_click" />
                    <MenuItem Header="Turbo" Click="turbo_color_menu_item_click" />
                    <MenuItem Header="Gray" Click="gray_color_menu_item_click" />
                </MenuItem>
                <MenuItem Header="X axis scale">
                    <MenuItem Header="Linear" ToggleType="Radio" IsChecked="{Binding IsEditorXAxisLinearScale, Mode=TwoWay}" />
                    <MenuItem Header="Logicle" ToggleType="Radio" IsChecked="{Binding IsEditorXAxisLogicleScale, Mode=TwoWay}" />
                </MenuItem>
                <MenuItem Header="Y axis scale">
                    <MenuItem Header="Linear" ToggleType="Radio" IsChecked="{Binding IsEditorYAxisLinearScale, Mode=TwoWay}" />
                    <MenuItem Header="Logicle" ToggleType="Radio" IsChecked="{Binding IsEditorYAxisLogicleScale, Mode=TwoWay}" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Layouts" IsEnabled="{Binding IsPageEditorMode}">
                <MenuItem Header="Create layout" Command="{Binding CreateLayoutCommand}" InputGesture="Ctrl + L"/>
                <MenuItem Header="Rename layout" Command="{Binding RenameLayoutCommand}" InputGesture="F2"/>
                <Separator />
                <MenuItem Header="Density" ToggleType="Radio" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding IsLayoutDensityPlotMode, Mode=TwoWay}" />
                <MenuItem Header="Dotplot" ToggleType="Radio" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding IsLayoutDotplotPlotMode, Mode=TwoWay}" />
                <MenuItem Header="Contour" ToggleType="Radio" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding IsLayoutContourPlotMode, Mode=TwoWay}" />
                <MenuItem Header="Zebra" ToggleType="Radio" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding IsLayoutZebraPlotMode, Mode=TwoWay}" />
                <MenuItem Header="Histogram" ToggleType="Radio" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding IsLayoutHistogramPlotMode, Mode=TwoWay}" />
                <Separator />
                <MenuItem Header="Show outlier points" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.ShowOutlierPoints, Mode=TwoWay}" />
                <MenuItem Header="Draw large dots" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.DrawLargeDots, Mode=TwoWay}" />
                <MenuItem Header="Show gridlines" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.ShowGridlines, Mode=TwoWay}" />
                <MenuItem Header="Show tick labels" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.ShowTickLabels, Mode=TwoWay}" />
                <MenuItem Header="Density pseudocolor" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.UsePseudocolor, Mode=TwoWay}" />
                <MenuItem Header="Show gates" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.ShowGates, Mode=TwoWay}" />
                <MenuItem Header="Show gate annotations" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.ShowGateAnnotations, Mode=TwoWay}" />
                <MenuItem Header="Show gate annotation names" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.ShowGateAnnotationNames, Mode=TwoWay}" />
                <Separator />
                <MenuItem x:Name="toggle_layout_properties_menu_item" Header="Show properties panel" ToggleType="CheckBox" IsChecked="True" InputGesture="Ctrl + R" Click="toggle_plot_properties_menu_item_click" />
                <Separator />
                <MenuItem x:Name="layout_x_channel_menu" Header="X selected channel" IsEnabled="{Binding HasSelectedPageElement}" />
                <MenuItem x:Name="layout_y_channel_menu" Header="Y selected channel" IsEnabled="{Binding HasSelectedPageElement}" />
                <MenuItem x:Name="layout_color_channel_menu" Header="Dot color" IsEnabled="{Binding HasSelectedPageElement}" />
                <MenuItem Header="Coloring in log scale" ToggleType="CheckBox" IsEnabled="{Binding HasSelectedPageElement}" IsChecked="{Binding SelectedPageElement.DotColor.UseLogScale, Mode=TwoWay}" />
                <MenuItem Header="Dot color palette" IsEnabled="{Binding HasSelectedPageElement}">
                    <MenuItem Header="Viridis" Click="layout_viridis_color_menu_item_click" />
                    <MenuItem Header="Plasma" Click="layout_plasma_color_menu_item_click" />
                    <MenuItem Header="Turbo" Click="layout_turbo_color_menu_item_click" />
                    <MenuItem Header="Gray" Click="layout_gray_color_menu_item_click" />
                </MenuItem>
                <MenuItem Header="X axis scale" IsEnabled="{Binding HasSelectedPageElement}">
                    <MenuItem Header="Linear" ToggleType="Radio" IsChecked="{Binding IsLayoutXAxisLinearScale, Mode=TwoWay}" />
                    <MenuItem Header="Logicle" ToggleType="Radio" IsChecked="{Binding IsLayoutXAxisLogicleScale, Mode=TwoWay}" />
                </MenuItem>
                <MenuItem Header="Y axis scale" IsEnabled="{Binding HasSelectedPageElement}">
                    <MenuItem Header="Linear" ToggleType="Radio" IsChecked="{Binding IsLayoutYAxisLinearScale, Mode=TwoWay}" />
                    <MenuItem Header="Logicle" ToggleType="Radio" IsChecked="{Binding IsLayoutYAxisLogicleScale, Mode=TwoWay}" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Gating" IsEnabled="{Binding IsDefaultAnalysisMode}">
                <MenuItem Header="View" ToggleType="Radio" IsChecked="{Binding IsViewTool, Mode=OneWay}" Click="view_tool_menu_item_click" />
                <MenuItem Header="Polygon gate" ToggleType="Radio" IsEnabled="{Binding CanCreateTwoDimensionalGate}" IsChecked="{Binding IsPolygonTool, Mode=OneWay}" Click="polygon_tool_menu_item_click" />
                <MenuItem Header="Rectangle gate" ToggleType="Radio" IsEnabled="{Binding CanCreateTwoDimensionalGate}" IsChecked="{Binding IsRectangleTool, Mode=OneWay}" Click="rectangle_tool_menu_item_click" />
                <MenuItem Header="Quad gate" ToggleType="Radio" IsEnabled="{Binding CanCreateTwoDimensionalGate}" IsChecked="{Binding IsQuadrantTool, Mode=OneWay}" Click="quadrant_tool_menu_item_click" />
                <MenuItem Header="Curly quad gate" ToggleType="Radio" IsEnabled="{Binding CanCreateTwoDimensionalGate}" IsChecked="{Binding IsCurlyQuadrantTool, Mode=OneWay}" Click="curly_quadrant_tool_menu_item_click" />
                <MenuItem Header="Offset quad gate" ToggleType="Radio" IsEnabled="{Binding CanCreateTwoDimensionalGate}" IsChecked="{Binding IsOffsetQuadrantTool, Mode=OneWay}" Click="offset_quadrant_tool_menu_item_click" />
                <MenuItem Header="Threshold gate" ToggleType="Radio" IsEnabled="{Binding CanCreateOneDimensionalGate}" IsChecked="{Binding IsThresholdTool, Mode=OneWay}" Click="threshold_tool_menu_item_click" />
                <MenuItem Header="Range gate" ToggleType="Radio" IsEnabled="{Binding CanCreateOneDimensionalGate}" IsChecked="{Binding IsRangeTool, Mode=OneWay}" Click="range_tool_menu_item_click" />
                <Separator />
                <MenuItem Header="Merge" Command="{Binding AddMergeGateCommand}" />
                <MenuItem Header="Exclude" Command="{Binding AddExcludeGateCommand}" />
                <MenuItem Header="Overlap" Command="{Binding AddOverlapGateCommand}" />
                <Separator />
                <MenuItem Header="Rename gate" Command="{Binding RenameGateCommand}" InputGesture="F2"/>
                <MenuItem Header="Delete selected gate" Command="{Binding DeleteSelectedCommand}" InputGesture="Delete"/>
            </MenuItem>
            <MenuItem Header="_Compensation">
                <MenuItem Header="Apply selected compensation" Command="{Binding ApplyCompensationCommand}"/>
                <MenuItem Header="Compensation table editor ..." Command="{Binding EditCompensationCommand}" InputGesture="Ctrl + P"/>
            </MenuItem>
            <MenuItem Header="_Statistics">
                <MenuItem Header="Mean" Command="{Binding AddMeanStatisticCommand}" />
                <MenuItem Header="Median" Command="{Binding AddMedianStatisticCommand}" />
                <MenuItem Header="Geometric mean" Command="{Binding AddGeometricMeanStatisticCommand}" />
                <MenuItem Header="Coefficient of variation (CV)" Command="{Binding AddCoefficientOfVariationStatisticCommand}" />
                <MenuItem Header="Standard deviation (SD)" Command="{Binding AddStandardDeviationStatisticCommand}" />
                <MenuItem Header="Frequency of parent population" Command="{Binding AddFrequencyOfParentStatisticCommand}" />
                <MenuItem Header="Frequency of all" Command="{Binding AddFrequencyOfAllStatisticCommand}" />
                <MenuItem Header="Number of events" Command="{Binding AddCountStatisticCommand}" />
                <MenuItem Header="Delete selected statistic" Command="{Binding DeleteSelectedCommand}" InputGesture="Delete" />
                <Separator />
                <MenuItem Header="Create macro" InputGesture="Ctrl + Shift + P" Click="create_macro_menu_item_click" />
                <MenuItem x:Name="run_macros_menu" Header="Run macros" />
                <MenuItem x:Name="edit_macros_menu" Header="Edit macros" />
                <Separator />
                <MenuItem Header="Create Python statistic" Click="create_statistic_script_menu_item_click" />
                <MenuItem x:Name="python_statistics_menu" Header="Python statistics" />
                <MenuItem x:Name="edit_python_statistics_menu" Header="Edit Python statistics" />
                <Separator />
                <MenuItem Header="Create platform">
                    <MenuItem Header="Integration" Command="{Binding CreateIntegrationJobCommand}" CommandParameter="Integration" />
                    <MenuItem Header="Cell cycle" Command="{Binding CreateIntegrationJobCommand}" CommandParameter="CellCycle" />
                    <MenuItem Header="Proliferation" Command="{Binding CreateIntegrationJobCommand}" CommandParameter="Proliferation" />
                    <MenuItem Header="Intensity comparison" Command="{Binding CreateIntegrationJobCommand}" CommandParameter="IntensityComparison" />
                    <!-- <MenuItem Header="Kinetics" Command="{Binding CreateIntegrationJobCommand}" CommandParameter="Kinetics" /> -->
                </MenuItem>
                <MenuItem Header="Rename platform" Command="{Binding RenameIntegrationJobCommand}" InputGesture="F2"/>
                <MenuItem Header="Delete platform" Command="{Binding DeleteSelectedCommand}" InputGesture="Delete"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Check for updates ..." Click="check_for_updates_menu_item_click" />
                <MenuItem Header="About Gated ..." Click="about_menu_item_click" />
            </MenuItem>
        </Menu>

        <Grid DockPanel.Dock="Top" Height="6" Background="{DynamicResource SemiColorSplits}" />

        <Border DockPanel.Dock="Bottom"
                Height="28"
                BorderBrush="#505050"
                BorderThickness="0,1,0,0"
                Background="{DynamicResource SemiColorBackground2}">
            <Grid ColumnDefinitions="*,Auto"
                  Margin="10,0,10,2">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SemiColorText2}"
                           Text="{Binding StatusText}" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{DynamicResource SemiColorText2}"
                               Text="{Binding PythonEngineStatusText}" />
                    <ProgressBar Width="120"
                                 Height="5"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsPythonEngineProgressVisible}"
                                 IsIndeterminate="{Binding IsPythonEngineProgressIndeterminate}"
                                 Value="{Binding PythonEngineProgress}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="main_workspace_grid" ColumnDefinitions="500,5,*">
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource SemiColorSplits}"
                    BorderThickness="0,0,1,0"
                    Background="{DynamicResource SemiColorBackground0}">
                <Grid RowDefinitions="30,*" Margin="8">
                    <Grid Grid.Row="0" ColumnDefinitions="*,100">
                        <TextBlock Text="Workspace"
                                   Foreground="{DynamicResource SemiColorText2}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0" />
                        <TextBlock Grid.Column="1"
                                   Text="Statistics"
                                   Foreground="{DynamicResource SemiColorText2}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0" />
                    </Grid>
                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <controls:ProjectTreeView x:Name="project_tree"
                                                  Nodes="{Binding ProjectNodes}"
                                                  SelectNodeCommand="{Binding SelectProjectNodeCommand}"
                                                  ToggleNodeCommand="{Binding ToggleProjectNodeCommand}" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource SemiColorSplits}"
                          ResizeDirection="Columns" />

            <Grid x:Name="analysis_mode_grid"
                  Grid.Column="2"
                  IsVisible="{Binding IsDefaultAnalysisMode}"
                  RowDefinitions="*,5,250"
                  Background="{DynamicResource SemiColorBackground1}">
                <Grid x:Name="analysis_plot_grid"
                      Grid.Row="0"
                      ColumnDefinitions="*,336">
                    <Grid Grid.Column="0"
                          RowDefinitions="Auto,*">
                        <Border Grid.Row="0"
                                HorizontalAlignment="Center"
                                Margin="0,16,0,8"
                                Padding="10"
                                CornerRadius="8"
                                BorderBrush="{DynamicResource SemiColorBorder}"
                                BorderThickness="1"
                                Background="{DynamicResource SemiColorBackground0}">
                            <DockPanel LastChildFill="False">
                              <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
                                <RadioButton GroupName="GateTools" Classes="GateToolButton" IsChecked="{Binding IsViewTool, Mode=OneWay}" Click="view_tool_menu_item_click">
                                    <Image Width="28" Height="28" Source="{SvgImage avares://gated/Resources/pointer.svg}" />
                                </RadioButton>
                                <RadioButton GroupName="GateTools" Classes="GateToolButton" IsChecked="{Binding IsPolygonTool, Mode=OneWay}" IsEnabled="{Binding CanCreateTwoDimensionalGate}" Click="polygon_tool_menu_item_click">
                                    <Image Width="28" Height="28" Source="{SvgImage avares://gated/Resources/polygon.svg}" />
                                </RadioButton>
                                <RadioButton GroupName="GateTools" Classes="GateToolButton" IsChecked="{Binding IsQuadrantTool, Mode=OneWay}" IsEnabled="{Binding CanCreateTwoDimensionalGate}" Click="quadrant_tool_menu_item_click">
                                    <Image Width="28" Height="28" Source="{SvgImage avares://gated/Resources/cross.svg}" />
                                </RadioButton>
                                <RadioButton GroupName="GateTools" Classes="GateToolButton" IsChecked="{Binding IsThresholdTool, Mode=OneWay}" IsEnabled="{Binding CanCreateOneDimensionalGate}" Click="threshold_tool_menu_item_click">
                                    <Image Width="28" Height="28" Source="{SvgImage avares://gated/Resources/threshold.svg}" />
                                </RadioButton>
                                <RadioButton GroupName="GateTools" Classes="GateToolButton" IsChecked="{Binding IsRangeTool, Mode=OneWay}" IsEnabled="{Binding CanCreateOneDimensionalGate}" Click="range_tool_menu_item_click">
                                    <Image Width="28" Height="28" Source="{SvgImage avares://gated/Resources/range.svg}" />
                                </RadioButton>
                              </StackPanel>
                              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" Margin="18,0,0,0" VerticalAlignment="Center">
                                <Button Classes="Small" Width="32" Height="32" Padding="6" Command="{Binding SelectPreviousEquivalentSampleCommand}">
                                    <Image Width="18" Height="18" Source="{SvgImage avares://gated/Resources/left.svg}" />
                                </Button>
                                <ComboBox Width="210"
                                          Classes="SampleSwitcher"
                                          VerticalAlignment="Center"
                                          ItemsSource="{Binding EquivalentSampleChoices}"
                                          SelectedItem="{Binding SelectedEquivalentSampleChoice, Mode=TwoWay}">
                                    <ComboBox.SelectionBoxItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SampleName}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource SemiColorText0}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding CountText}"
                                                           IsVisible="{Binding HasCount}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SemiColorText2}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.SelectionBoxItemTemplate>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding SampleName}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SemiColorText0}" />
                                                <TextBlock Text="{Binding CountText}"
                                                           IsVisible="{Binding HasCount}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SemiColorText2}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Classes="Small" Width="32" Height="32" Padding="6" Command="{Binding SelectNextEquivalentSampleCommand}">
                                    <Image Width="18" Height="18" Source="{SvgImage avares://gated/Resources/right.svg}" />
                                </Button>
                              </StackPanel>
                            </DockPanel>
                        </Border>

                        <Grid Grid.Row="1" Margin="16">
                            <controls:FlowPlotView Group="{Binding SelectedGroup}"
                                                   Sample="{Binding SelectedSample}"
                                                   Gate="{Binding PlotGate}"
                                                   Gates="{Binding PlotGates}"
                                                   Population="{Binding PlotPopulation}"
                                                   XAxis="{Binding XAxis}"
                                                   YAxis="{Binding YAxis}"
                                                   DotColor="{Binding DotColor}"
                                                   PlotMode="{Binding EffectivePlotMode}"
                                                   ShowOutlierPoints="{Binding ShowOutlierPoints}"
                                                   DrawLargeDots="{Binding DrawLargeDots}"
                                                   ShowGridlines="{Binding ShowGridlines}"
                                                   ShowGateAnnotations="{Binding ShowGateAnnotations}"
                                                   ShowGateAnnotationNames="{Binding ShowGateAnnotationNames}"
                                                   ContourLevelCount="{Binding ContourLevelCount}"
                                                   DensitySmoothing="{Binding DensitySmoothing}"
                                                   ActiveTool="{Binding ActiveTool}"
                                                   GateCreatedCommand="{Binding AddCanvasGateCommand}"
                                                   GateEditedCommand="{Binding GateEditedCommand}"
                                                   TransformPreparing="{Binding IsEditorPlotCalculating}" />
                            <Border HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="60,0,0,40"
                                    Padding="10,10"
                                    CornerRadius="10"
                                    Background="#262830"
                                    BorderBrush="#5F6678"
                                    BorderThickness="1"
                                    Opacity="0.5"
                                    IsHitTestVisible="False"
                                    IsVisible="{Binding IsEditorPlotCalculating}">
                                <StackPanel Orientation="Horizontal">
                                    <controls:SpinnerView Width="48"
                                                          Height="48"
                                                          VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <Border x:Name="analysis_properties_panel"
                            Grid.Column="1"
                            BorderBrush="{DynamicResource SemiColorSplits}"
                            BorderThickness="1,0,0,0"
                            Background="{DynamicResource SemiColorBackground0}"
                            Padding="8">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="8" Margin="16, 8, 16, 16"
                                        Grid.IsSharedSizeScope="True">
                                <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Properties" />

                                <Expander Header="Channels" IsExpanded="False">
                                    <StackPanel Spacing="6" Margin="-10,8,0,16">
                                        <DataGrid MaxHeight="200"
                                                  AutoGenerateColumns="False"
                                                  CanUserReorderColumns="False"
                                                  CanUserResizeColumns="True"
                                                  CanUserSortColumns="False"
                                                  GridLinesVisibility="Horizontal"
                                                  HeadersVisibility="Column"
                                                  ItemsSource="{Binding ChannelRows}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Channel"
                                                                    Width="95"
                                                                    IsReadOnly="True"
                                                                    Binding="{Binding Name}" />
                                                <DataGridTextColumn Header="Label"
                                                                    Width="95"
                                                                    FontWeight="Bold"
                                                                    Binding="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <DataGridTextColumn Header="Maximum"
                                                                    Width="90"
                                                                    IsReadOnly="True"
                                                                    Binding="{Binding MaximumDisplay}" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="X axis" IsExpanded="False">
                                    <StackPanel Spacing="8" Margin="0,8,0,16">
                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Selected channel" />
                                        <ComboBox Classes='Small'
                                                  ItemsSource="{Binding AxisChoices}"
                                                  SelectedItem="{Binding SelectedXAxisChoice}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                                                        <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <StackPanel>
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Minimum" />
                                                <TextBox Text="{Binding XAxis.Minimum, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Maximum" />
                                                <TextBox Text="{Binding XAxis.Maximum, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Axis scale" />
                                        <ComboBox Classes='Small'
                                                  ItemsSource="{Binding CoordinateScaleChoices}"
                                                  SelectedItem="{Binding XAxis.ScaleKind}" />

                                        <Grid IsVisible="{Binding XAxis.IsLogicle}" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="8">
                                            <StackPanel>
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Top of scale (T)" />
                                                <TextBox Text="{Binding XAxis.LogicleTopOfScale, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Number of decades (M)" />
                                                <TextBox Text="{Binding XAxis.LogicleDecades, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Linearization width (W)" />
                                                <TextBox Text="{Binding XAxis.LogicleLinearizationWidth, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Negative decades (A)" />
                                                <TextBox Text="{Binding XAxis.LogicleNegativeDecades, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Y axis" IsExpanded="False">
                                    <StackPanel Spacing="8" Margin="0,8,0,16">
                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Selected channel" />
                                        <ComboBox Classes='Small'
                                                  IsEnabled="{Binding IsYAxisEnabled}"
                                                  ItemsSource="{Binding AxisChoices}"
                                                  SelectedItem="{Binding SelectedYAxisChoice}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                                                        <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <StackPanel>
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Minimum" />
                                                <TextBox IsEnabled="{Binding IsYAxisEnabled}" Text="{Binding YAxis.Minimum, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Maximum" />
                                                <TextBox IsEnabled="{Binding IsYAxisEnabled}" Text="{Binding YAxis.Maximum, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Axis scale" />
                                        <ComboBox Classes='Small'
                                                  IsEnabled="{Binding IsYAxisEnabled}"
                                                  ItemsSource="{Binding CoordinateScaleChoices}"
                                                  SelectedItem="{Binding YAxis.ScaleKind}" />

                                        <Grid IsVisible="{Binding YAxis.IsLogicle}" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="8">
                                            <StackPanel>
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Top of scale (T)" />
                                                <TextBox IsEnabled="{Binding IsYAxisEnabled}" Text="{Binding YAxis.LogicleTopOfScale, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Number of decades (M)" />
                                                <TextBox IsEnabled="{Binding IsYAxisEnabled}" Text="{Binding YAxis.LogicleDecades, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Linearization width (W)" />
                                                <TextBox IsEnabled="{Binding IsYAxisEnabled}" Text="{Binding YAxis.LogicleLinearizationWidth, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Negative decades (A)" />
                                                <TextBox IsEnabled="{Binding IsYAxisEnabled}" Text="{Binding YAxis.LogicleNegativeDecades, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Plot style" IsExpanded="True">
                                    <StackPanel Spacing="8" Margin="0,8,0,16">
                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Plot type" />
                                        <ComboBox Classes='Small'
                                                  ItemsSource="{Binding PlotModeChoices}"
                                                  SelectedItem="{Binding SelectedPlotMode}" />

                                        <StackPanel Margin="0,4,0,0" Spacing="8">
                                            <CheckBox Content="Show outlier points" Margin="0,0,12,0"
                                                      IsChecked="{Binding ShowOutlierPoints}" />
                                            <CheckBox Content="Draw large dots" Margin="0,0,12,0"
                                                      IsChecked="{Binding DrawLargeDots}" />
                                            <CheckBox Content="Show gridlines" Margin="0,0,12,0"
                                                      IsChecked="{Binding ShowGridlines}" />
                                            <CheckBox Content="Show gate annotations" Margin="0,0,12,0"
                                                      IsChecked="{Binding ShowGateAnnotations}" />
                                            <CheckBox Content="Show annotation names" Margin="0,0,12,0"
                                                      IsChecked="{Binding ShowGateAnnotationNames}" />
                                        </StackPanel>

                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Dot color" />
                                        <ComboBox Classes='Small'
                                                  ItemsSource="{Binding ColorChoices}"
                                                  SelectedItem="{Binding SelectedDotColorChoice}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                                                        <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Color palette" />
                                        <ComboBox Classes='Small'
                                                  ItemsSource="{Binding PlotColorPaletteChoices}"
                                                  SelectedItem="{Binding DotColor.Palette}" />
                                        <CheckBox Content="Coloring in log scale" Margin="0,4,0,0"
                                                  IsChecked="{Binding DotColor.UseLogScale}" />

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <StackPanel>
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Contour levels" />
                                                <TextBox Text="{Binding ContourLevelCount, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Density smoothing" />
                                                <TextBox Text="{Binding DensitySmoothing, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <GridSplitter Grid.Row="1"
                              Height="5"
                              HorizontalAlignment="Stretch"
                              Background="{DynamicResource SemiColorSplits}"
                              ResizeDirection="Rows" />

                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource SemiColorSplits}"
                        BorderThickness="0,1,0,0"
                        Background="{DynamicResource SemiColorBackground0}"
                        Padding="16">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Gate statistics" />
                        <TextBlock Grid.Row="1"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource SemiColorText0}"
                                   Text="{Binding SelectedGateName}"
                                   FontWeight="SemiBold" />
                        <DataGrid Grid.Row="2"
                                  Margin="0,12,0,0"
                                  x:Name="statistics"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  ItemsSource="{Binding StatisticTableView}" />
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="layout_mode_grid"
                  Grid.Column="2"
                  IsVisible="{Binding IsPageEditorMode}"
                  ColumnDefinitions="*,336"
                  Background="{DynamicResource SemiColorBackground1}">
                <controls:PageEditorView x:Name="page_editor"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         Elements="{Binding PageElements}"
                                         SelectedElement="{Binding SelectedPageElement, Mode=TwoWay}"
                                         RefreshRevision="{Binding LayoutRefreshRevision}"
                                         AddElementCommand="{Binding AddPageElementCommand}" />

                <Border x:Name="layout_properties_panel"
                        Grid.Column="1"
                        BorderBrush="{DynamicResource SemiColorSplits}"
                        BorderThickness="1,0,0,0"
                        Background="{DynamicResource SemiColorBackground0}"
                        Padding="8">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="10" Margin="16 8 16 16">
                            <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Page layout" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="export_page_png_click" Classes="Small">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                    <Image Width="16" Height="16" Source="{SvgImage avares://gated/Resources/export.svg}" />
                                    <TextBlock VerticalAlignment="Center" Text="PNG" />
                                    </StackPanel>
                                </Button>
                                <Button Click="export_page_jpg_click" Classes="Small">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                    <Image Width="16" Height="16" Source="{SvgImage avares://gated/Resources/export.svg}" />
                                    <TextBlock VerticalAlignment="Center" Text="JPG" />
                                    </StackPanel>
                                </Button>
                                <Button Click="export_page_svg_click" Classes="Small">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                    <Image Width="16" Height="16" Source="{SvgImage avares://gated/Resources/export.svg}" />
                                    <TextBlock VerticalAlignment="Center" Text="SVG" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding DeletePageElementCommand}" Classes="Small Danger">
                                    <Image Width="16" Height="16" Source="{SvgImage avares://gated/Resources/delete.svg}" />
                                </Button>
                            </StackPanel>
                            
                            <CheckBox Content="Rasterization resolution for density scatter" Margin="0 8 0 0"
                                      IsChecked="{Binding ExportBitmapApplyRasterizationResolution}" />
                            <CheckBox Content="Background transparency"
                                      IsChecked="{Binding ExportBitmapTransparentBackground}" />
                            <Grid ColumnDefinitions="Auto,100" ColumnSpacing="8" Margin="0 4 0 0">
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{DynamicResource SemiColorText2}"
                                           Text="Bitmap DPI" />
                                <NumericUpDown Grid.Column="1"
                                               Classes="Small"
                                               Minimum="72"
                                               Maximum="1200"
                                               Increment="25"
                                               Value="{Binding ExportBitmapDpi}" />
                            </Grid>

                            <Expander Header="Selected plot" Margin="0 8 0 0" IsExpanded="True">
                                <StackPanel Spacing="8" Margin="0,8,0,16" IsEnabled="{Binding HasSelectedPageElement}">
                                    <StackPanel>
                                        <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Title" />
                                        <TextBox IsEnabled="{Binding CanEditSelectedPageTitle}"
                                                 Text="{Binding SelectedPageElement.Title, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                                        <StackPanel>
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="X" />
                                            <TextBox Text="{Binding SelectedPageElement.X, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Y" />
                                            <TextBox Text="{Binding SelectedPageElement.Y, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Width" />
                                            <TextBox IsEnabled="{Binding CanEditSelectedPageWidth}"
                                                     Text="{Binding SelectedPageElement.Width, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Height" />
                                            <TextBox IsEnabled="{Binding CanEditSelectedPageHeight}"
                                                     Text="{Binding SelectedPageElement.Height, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel>
                                    <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Plot mode" />
                                    <ComboBox Classes="Small" Margin="0 0 0 4"
                                              IsEnabled="{Binding CanEditSelectedPagePlotMode}"
                                              ItemsSource="{Binding PlotModeChoices}"
                                              SelectedItem="{Binding SelectedPageElement.PlotMode}" />
                                    </StackPanel>

                                    <CheckBox Content="Show gridlines"
                                              IsEnabled="{Binding CanEditSelectedPageGridTickOptions}"
                                              IsChecked="{Binding SelectedPageElement.ShowGridlines}" />
                                    <CheckBox Content="Show outlier points"
                                              IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                              IsChecked="{Binding SelectedPageElement.ShowOutlierPoints}" />
                                    <CheckBox Content="Draw large dots"
                                              IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                              IsChecked="{Binding SelectedPageElement.DrawLargeDots}" />
                                    <CheckBox Content="Show tick labels"
                                              IsEnabled="{Binding CanEditSelectedPageGridTickOptions}"
                                              IsChecked="{Binding SelectedPageElement.ShowTickLabels}" />
                                    <CheckBox Content="Density pseudocolor"
                                              IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                              IsChecked="{Binding SelectedPageElement.UsePseudocolor}" />
                                    <CheckBox Content="Show gates"
                                              IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                              IsChecked="{Binding SelectedPageElement.ShowGates}" />
                                    <CheckBox Content="Show gate annotations"
                                              IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                              IsChecked="{Binding SelectedPageElement.ShowGateAnnotations}" />
                                    <CheckBox Content="Show annotation names"
                                              IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                              IsChecked="{Binding SelectedPageElement.ShowGateAnnotationNames}" />

                                    <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Dot color" />
                                    <ComboBox Classes="Small"
                                              IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                              ItemsSource="{Binding SelectedPageColorChoices}"
                                              SelectedItem="{Binding SelectedPageDotColorChoice, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                                                    <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Color palette" />
                                    <ComboBox Classes="Small"
                                              IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                              ItemsSource="{Binding PlotColorPaletteChoices}"
                                              SelectedItem="{Binding SelectedPageElement.DotColor.Palette}" />
                                    <CheckBox Content="Coloring in log scale"
                                              IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                              IsChecked="{Binding SelectedPageElement.DotColor.UseLogScale}" />

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <StackPanel>
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Contours" />
                                            <TextBox IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                                     Text="{Binding SelectedPageElement.ContourLevelCount, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Smoothing" />
                                            <TextBox IsEnabled="{Binding CanEditSelectedPageFlowOptions}"
                                                     Text="{Binding SelectedPageElement.DensitySmoothing, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                            <Expander Header="X axis" IsExpanded="False">
                                <StackPanel Spacing="8" Margin="0,8,0,16" IsEnabled="{Binding CanEditSelectedPageAxes}">
                                    <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Selected channel" />
                                    <ComboBox Classes="Small"
                                              ItemsSource="{Binding SelectedPageAxisChoices}"
                                              SelectedItem="{Binding SelectedPageXAxisChoice, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                                                    <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <StackPanel>
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Minimum" />
                                            <TextBox Text="{Binding SelectedPageElement.XAxis.Minimum, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Maximum" />
                                            <TextBox Text="{Binding SelectedPageElement.XAxis.Maximum, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Axis scale" />
                                    <ComboBox Classes="Small"
                                              ItemsSource="{Binding CoordinateScaleChoices}"
                                              SelectedItem="{Binding SelectedPageElement.XAxis.ScaleKind}" />

                                    <Grid IsVisible="{Binding SelectedPageElement.XAxis.IsLogicle}" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="8">
                                        <StackPanel>
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Top of scale (T)" />
                                            <TextBox Text="{Binding SelectedPageElement.XAxis.LogicleTopOfScale, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Number of decades (M)" />
                                            <TextBox Text="{Binding SelectedPageElement.XAxis.LogicleDecades, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Linearization width (W)" />
                                            <TextBox Text="{Binding SelectedPageElement.XAxis.LogicleLinearizationWidth, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Negative decades (A)" />
                                            <TextBox Text="{Binding SelectedPageElement.XAxis.LogicleNegativeDecades, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                            <Expander Header="Y axis" IsExpanded="False">
                                <StackPanel Spacing="8" Margin="0,8,0,16" IsEnabled="{Binding CanEditSelectedPageAxes}">
                                    <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Selected channel" />
                                    <ComboBox Classes="Small"
                                              ItemsSource="{Binding SelectedPageAxisChoices}"
                                              SelectedItem="{Binding SelectedPageYAxisChoice, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" />
                                                    <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <StackPanel>
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Minimum" />
                                            <TextBox Text="{Binding SelectedPageElement.YAxis.Minimum, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Maximum" />
                                            <TextBox Text="{Binding SelectedPageElement.YAxis.Maximum, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Margin="0,4,0,-4" Foreground="{DynamicResource SemiColorText2}" Text="Axis scale" />
                                    <ComboBox Classes="Small"
                                              ItemsSource="{Binding CoordinateScaleChoices}"
                                              SelectedItem="{Binding SelectedPageElement.YAxis.ScaleKind}" />

                                    <Grid IsVisible="{Binding SelectedPageElement.YAxis.IsLogicle}" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="8">
                                        <StackPanel>
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Top of scale (T)" />
                                            <TextBox Text="{Binding SelectedPageElement.YAxis.LogicleTopOfScale, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Number of decades (M)" />
                                            <TextBox Text="{Binding SelectedPageElement.YAxis.LogicleDecades, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Linearization width (W)" />
                                            <TextBox Text="{Binding SelectedPageElement.YAxis.LogicleLinearizationWidth, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <TextBlock Margin="0,4" Foreground="{DynamicResource SemiColorText2}" Text="Negative decades (A)" />
                                            <TextBox Text="{Binding SelectedPageElement.YAxis.LogicleNegativeDecades, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid Grid.Column="2"
                  IsVisible="{Binding IsIntegrationJobMode}"
                  Background="{DynamicResource SemiColorBackground1}">
                <controls:PlatformEditorHost Workspace="{Binding Workspace}"
                                             Platform="{Binding SelectedIntegrationJob}" />
            </Grid>

            <Grid Grid.Column="2"
                  IsVisible="{Binding IsWorkspaceMetadataMode}"
                  Background="{DynamicResource SemiColorBackground1}">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24"
                                Spacing="14"
                                MaxWidth="650"
                                MinWidth="650"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource SemiColorBackground1}">
                        <StackPanel Margin="0 12 0 0">
                            <TextBlock Foreground="{DynamicResource SemiColorText1}" Text="Workspace sample metadata" />
                        </StackPanel>

                        <WrapPanel Margin="0,0,0,2">
                            <Button Classes="Small" Margin="0,0,8,0" Command="{Binding AddStringMetadataColumnCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Image Width="16" Height="16" Source="{SvgImage avares://gated/Resources/table-edit.svg}" />
                                    <TextBlock Text="String column" />
                                </StackPanel>
                            </Button>
                            <Button Classes="Small" Margin="0,0,8,0" Command="{Binding AddIntegerMetadataColumnCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Image Width="16" Height="16" Source="{SvgImage avares://gated/Resources/table-edit.svg}" />
                                    <TextBlock Text="Integer column" />
                                </StackPanel>
                            </Button>
                            <Button Classes="Small" Margin="0,0,8,0" Command="{Binding AddFloatMetadataColumnCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Image Width="16" Height="16" Source="{SvgImage avares://gated/Resources/table-edit.svg}" />
                                    <TextBlock Text="Floating point column" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <Border Height="430"
                                BorderBrush="#505050"
                                BorderThickness="1"
                                CornerRadius="8"
                                Background="#1e1e1e"
                                Padding="8"
                                ClipToBounds="True">
                            <DataGrid x:Name="workspace_metadata_grid"
                                      AutoGenerateColumns="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="True"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      Background="#1e1e1e"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      ItemsSource="{Binding WorkspaceMetadataTableView}" />
                        </Border>

                        <Button Classes="Small" HorizontalAlignment="Left" Margin="0,0,0,24" Command="{Binding ApplyWorkspaceMetadataCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Width="16" Height="16" Source="{SvgImage avares://gated/Resources/ok.svg}" />
                                <TextBlock Text="Apply metadata" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <controls:PythonScriptEditorView Grid.Column="2"
                                             IsVisible="{Binding IsPythonScriptEditorMode}" />
        </Grid>
    </DockPanel>
</Window>
