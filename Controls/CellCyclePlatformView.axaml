<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:gated.Controls"
             xmlns:platforms="clr-namespace:gated.ViewModels.Platforms" xmlns:shared="using:gated.Shared"
             x:Class="gated.Controls.CellCyclePlatformView"
             x:DataType="platforms:CellCyclePlatformEditorViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24" Spacing="14" MaxWidth="750" Width="750" HorizontalAlignment="Center">
      <StackPanel Margin="0,12" Spacing="8">
        <TextBlock Foreground="{DynamicResource AppBrushText2}" FontWeight="Bold" Text="{Binding KindName}" />
        <TextBlock Foreground="{DynamicResource SemiColorText1}" TextWrapping="Wrap" LineHeight="18" Text="{Binding KindDescription}" />
      </StackPanel>
      <Border IsVisible="{Binding HasWarning}" BorderBrush="{DynamicResource AppBrushWarningBorder}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{DynamicResource AppBrushWarningBackground}"><TextBlock Foreground="{DynamicResource AppBrushWarningText}" TextWrapping="Wrap" Text="{Binding Platform.WarningText}" /></Border>
      <Border Height="230" ClipToBounds="True">
        <controls:HistogramView Curves="{Binding PlatformHistogramCurves}" Minimum="{Binding PlatformHistogramMinimum}" Maximum="{Binding PlatformHistogramMaximum}"
                                AxisScale="{Binding PlatformHistogramAxisScale}" LogicleTopOfScale="{Binding LogicleT}" LogicleLinearizationWidth="{Binding LogicleW}"
                                LogicleDecades="{Binding LogicleM}" LogicleNegativeDecades="{Binding LogicleA}" ArcsinhCofactor="{Binding UnivariateArcsinhA}"
                                YMaximum="{Binding PlatformHistogramYMaximum}" XTitle="{Binding PlatformHistogramXTitle}" YTitle="{Binding PlatformHistogramYTitle}" IsGatingEnabled="False" />
      </Border>
      <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Populations" />
      <Border Height="210" BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource AppBrushBackground3}" ClipToBounds="True">
        <controls:PlatformPopulationGrid ShowPopulationColors="True" />
      </Border>
      <Grid ColumnDefinitions="*,*" ColumnSpacing="40">
        <Expander Header="Transformation" IsExpanded="True">
          <StackPanel Margin="0,8,0,12" Spacing="10">
            <StackPanel Spacing="6">
              <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Fit channel" />
              <ComboBox Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" ItemsSource="{Binding ChannelChoices}" SelectedItem="{Binding SelectedChannel}">
                <ComboBox.ItemTemplate><DataTemplate><StackPanel Orientation="Horizontal" Spacing="8"><TextBlock IsVisible="{Binding HasLabel}" Foreground="{DynamicResource SemiColorText0}" FontWeight="SemiBold" Text="{Binding Label}" /><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" /></StackPanel></DataTemplate></ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
            <StackPanel Spacing="6"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Desired transformation" /><ComboBox Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" ItemsSource="{Binding IntensityTransformationChoices}" SelectedItem="{Binding SelectedIntensityTransformationChoice}"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayLabel}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox></StackPanel>
            <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8" HorizontalAlignment="Left" IsVisible="{Binding IsLogicleTransformation}">
              <StackPanel Spacing="6"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Top of scale (T)" /><TextBox Classes="Small" MinWidth="155" MaxWidth="155" Text="{Binding LogicleT, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Grid.Column="1" Spacing="6"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Linearization width (W)" /><TextBox Classes="Small" MinWidth="155" MaxWidth="155" Text="{Binding LogicleW, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Grid.Row="1" Spacing="6"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Decades (M)" /><TextBox Classes="Small" MinWidth="155" MaxWidth="155" Text="{Binding LogicleM, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Negative decades (A)" /><TextBox Classes="Small" MinWidth="155" MaxWidth="155" Text="{Binding LogicleA, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            </Grid>
            <StackPanel Spacing="6" IsVisible="{Binding IsArcsinhTransformation}"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Arcsinh cofactor (a)" /><NumericUpDown Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" Minimum="0.000001" Maximum="1000000" Increment="1" Value="{Binding UnivariateArcsinhA}" /></StackPanel>
          </StackPanel>
        </Expander>
        <StackPanel Grid.Column="1" Spacing="10">
          <Expander Header="Distribution fitting options" IsExpanded="True">
            <StackPanel Margin="0,8,0,12" Spacing="10">
              <CheckBox Content="Use data smoothing" IsChecked="{Binding SmoothBeforeFit}" />
              <StackPanel Spacing="6"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Smoothing window size" /><NumericUpDown Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" Minimum="0" Maximum="50" Value="{Binding SmoothingHalfWindow}" /></StackPanel>
            </StackPanel>
          </Expander>
          <Expander Header="Statistical test" IsExpanded="True">
            <StackPanel Margin="0,8,0,12" Spacing="10">
              <StackPanel Spacing="6"><TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Cell-cycle model" /><ComboBox Classes="Small" MinWidth="155" MaxWidth="155" HorizontalAlignment="Left" ItemsSource="{Binding CellCycleModelChoices}" SelectedItem="{Binding SelectedCellCycleModelChoice}"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayLabel}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox></StackPanel>
              <CheckBox Content="Show overall model" IsChecked="{Binding CellCycleDrawModelSum}" />
              <CheckBox Content="Show individual component" IsChecked="{Binding CellCycleDrawComponents}" />
              <CheckBox Content="Filled model curve" IsChecked="{Binding CellCycleFillComponents}" />
            </StackPanel>
          </Expander>
        </StackPanel>
      </Grid>
      <StackPanel Spacing="8" IsVisible="{Binding HasCellCycleResults}">
        <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="Model results" />
        <Border Height="230" BorderBrush="{DynamicResource AppBrushBorder3}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource AppBrushBackground3}" ClipToBounds="True">
          <DataGrid Classes="ControlSampleGrid" AutoGenerateColumns="False" ItemsSource="{Binding CellCycleResultRows}" GridLinesVisibility="Horizontal" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Sample" Width="Auto" Binding="{Binding Sample, Mode=TwoWay}" /><DataGridTextColumn Header="Population" Width="Auto" Binding="{Binding Population, Mode=TwoWay}" /><DataGridTextColumn Header="Events" Width="Auto" Binding="{Binding Events, Mode=TwoWay}" />
              <DataGridTextColumn Header="G1 %" Width="Auto" Binding="{Binding G1Percent, Mode=TwoWay}" /><DataGridTextColumn Header="S %" Width="Auto" Binding="{Binding SPercent, Mode=TwoWay}" /><DataGridTextColumn Header="G2/M %" Width="Auto" Binding="{Binding G2MPercent, Mode=TwoWay}" />
              <DataGridTextColumn Header="G1 mean" Width="Auto" Binding="{Binding G1Mean, Mode=TwoWay}" /><DataGridTextColumn Header="G1 CV %" Width="Auto" Binding="{Binding G1CvPercent, Mode=TwoWay}" /><DataGridTextColumn Header="G2/M mean" Width="Auto" Binding="{Binding G2MMean, Mode=TwoWay}" /><DataGridTextColumn Header="G2/M CV %" Width="Auto" Binding="{Binding G2MCvPercent, Mode=TwoWay}" /><DataGridTextColumn Header="G2/G1 ratio" Width="Auto" Binding="{Binding G2G1Ratio, Mode=TwoWay}" />
            </DataGrid.Columns>
          </DataGrid>
        </Border>
      </StackPanel>
      <ProgressBar Height="5" Minimum="0" Maximum="1" Value="{Binding Platform.ProgressFraction}" IsVisible="{Binding Platform.IsRunning}" />
      <TextBlock Foreground="{DynamicResource SemiColorText2}" Text="{Binding Platform.ProgressText}" IsVisible="{Binding Platform.IsRunning}" />
      <Grid Margin="0 4 0 18" ColumnDefinitions="Auto,*,Auto"><Button Classes="Small" Command="{Binding RunCommand}"><StackPanel Orientation="Horizontal" Spacing="6"><shared:ThemeIcon Width="16" Height="16" Icon="run.svg" /><TextBlock Text="{Binding RunCaption}" /></StackPanel></Button><Button Grid.Column="2" Classes="Small Danger" Command="{Binding CancelCommand}"><StackPanel Orientation="Horizontal" Spacing="6"><shared:ThemeIcon Width="16" Height="16" Icon="stop.svg" /><TextBlock Text="Stop" /></StackPanel></Button></Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
