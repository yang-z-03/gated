<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="gated.ProgressDialog"
        MinWidth="250"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        x:CompileBindings="False"
        Title="Please wait"
        Background="#303030">
    <Border Padding="22" MinWidth="420">
        <StackPanel Spacing="10">
            <TextBlock Text="{Binding DialogTitle}" TextAlignment="Center"
                       Foreground="{DynamicResource SemiColorText0}"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding Subtitle}" TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="560" Margin="0 -4 0 4"
                       Foreground="{DynamicResource SemiColorText2}" />
        </StackPanel>
    </Border>
</Window>
