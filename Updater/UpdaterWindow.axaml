<Window x:Class="gated.Updater.UpdaterWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gated Updater"
        Width="680"
        Height="500"
        MinWidth="680"
        MinHeight="500"
        MaxWidth="680"
        MaxHeight="500"
        WindowStartupLocation="CenterScreen"
        FontFamily="Adobe Clean, Roboto, Inter, SF Pro Text, Arial"
        Background="#282828">
    <Window.Resources>
        <LinearGradientBrush x:Key="RightFadeMask"
                             StartPoint="0%,0%"
                             EndPoint="100%,0%">
            <GradientStop Color="Black" Offset="0" />
            <GradientStop Color="Black" Offset="0.86" />
            <GradientStop Color="Transparent" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BottomFadeMask"
                             StartPoint="0%,0%"
                             EndPoint="0%,100%">
            <GradientStop Color="Black" Offset="0" />
            <GradientStop Color="Black" Offset="0.88" />
            <GradientStop Color="Transparent" Offset="1" />
        </LinearGradientBrush>
    </Window.Resources>

    <Grid RowDefinitions="Auto,*,Auto"  Background="#1e1e1e">
        <StackPanel Spacing="8" Margin="24 24 24 12">
            <TextBlock x:Name="TitleText"
                       Text="Checking for updates"
                       FontSize="20"
                       FontWeight="Light"
                       Foreground="White"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="SubtitleText"
                       Text="Preparing updater."
                       FontSize="13"
                       Foreground="#d7dce6"
                       TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" IsVisible="True"
                        Spacing="8"
                        Margin="0,8,0,0">
                <Border x:Name="StepPrepare"
                        CornerRadius="4" Background="#2D3139"
                        Padding="10,4">
                    <TextBlock Text="Prepare"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#d7dce6" />
                </Border>
                <Border x:Name="StepReview"
                        CornerRadius="4" Background="#2D3139"
                        Padding="10,4">
                    <TextBlock Text="Review"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#d7dce6" />
                </Border>
                <Border x:Name="StepInstall"
                        CornerRadius="4" Background="#2D3139"
                        Padding="10,4">
                    <TextBlock Text="Install"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#d7dce6" />
                </Border>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1" Background="#303030">
            <Border BorderThickness="0 1 0 1" BorderBrush="#505050" />
            
            <StackPanel x:Name="SummaryPage"
                        Margin="24 24 24 24"
                        Spacing="12"
                        IsVisible="False">
                <Border Background="#282c34"
                        BorderBrush="#444954"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,9">
                    <Grid ColumnDefinitions="150,*">
                        <TextBlock Text="Base package"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#d7dce6"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="SummaryBasePackage"
                                   Grid.Column="1"
                                   FontSize="12"
                                   Foreground="#d7dce6"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <Border Background="#282c34"
                        BorderBrush="#444954"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,9">
                    <Grid ColumnDefinitions="150,*">
                        <TextBlock Text="Embedded Python"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#d7dce6"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="SummaryPython"
                                   Grid.Column="1"
                                   FontSize="12"
                                   Foreground="#d7dce6"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <Border Background="#282c34"
                        BorderBrush="#444954"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,9">
                    <Grid ColumnDefinitions="150,*">
                        <TextBlock Text="Python packages"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#d7dce6"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="SummaryPythonPackages"
                                   Grid.Column="1"
                                   FontSize="12"
                                   Foreground="#d7dce6"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <Border Background="#282c34"
                        BorderBrush="#444954"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,9">
                    <Grid ColumnDefinitions="150,*">
                        <TextBlock Text="Macros and statistics"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#d7dce6"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="SummaryScripts"
                                   Grid.Column="1"
                                   FontSize="12"
                                   Foreground="#d7dce6"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>
            </StackPanel>

            <ScrollViewer x:Name="ReviewPage"
                          Margin="24 12 24 12"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          OpacityMask="{StaticResource BottomFadeMask}"
                          IsVisible="False">
                <StackPanel x:Name="ReviewContent"
                            Spacing="14" />
            </ScrollViewer>

            <StackPanel x:Name="InstallPage"
                        Margin="24 24 24 24"
                        Spacing="4"
                        IsVisible="False">
                <TextBlock Text="Applying update. This window will restart Gated when finished."
                           FontSize="13"
                           Foreground="#d7dce6"
                           TextWrapping="Wrap" />
                <TextBlock Text="Do not launch Gated manually until the updater has completed."
                           FontSize="13"
                           Foreground="#d7dce6"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel x:Name="FailurePage"
                        Margin="24 24 24 24"
                        Spacing="12"
                        IsVisible="False">
                <TextBlock x:Name="FailurePrimary"
                           FontSize="13"
                           Foreground="#d7dce6"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="FailureSecondary"
                           FontSize="13"
                           Foreground="#d7dce6"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto,Auto,Auto"
              Margin="24,24,24,24"
              Background="#1e1e1e">
            <StackPanel Spacing="5"
                        Margin="0,0,25,0">
                <ProgressBar x:Name="Progress"
                             Minimum="0"
                             Maximum="100"
                             Height="8" />
                <TextBlock x:Name="ProgressDetail"
                           FontSize="12"
                           Foreground="#d7dce6"
                           TextWrapping="NoWrap"
                           TextTrimming="None"
                           MaxLines="1"
                           ClipToBounds="True"
                           OpacityMask="{StaticResource RightFadeMask}" />
            </StackPanel>

            <Button x:Name="BackButton"
                    Grid.Column="1"
                    Content="Back"
                    IsEnabled="False"
                    Margin="0,0,8,0" />
            <Button x:Name="CancelButton"
                    Grid.Column="2"
                    Content="Cancel"
                    Margin="0,0,8,0" />
            <Button x:Name="NextButton"
                    Grid.Column="3"
                    Content="Next"
                    Classes="Primary"
                    IsEnabled="False" />
        </Grid>
    </Grid>
</Window>
